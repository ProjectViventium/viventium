# ===== TELEGRAM BACKEND CONFIGURATION =====
# Choose which backend powers Telegram:
# - librechat (default): Uses LibreChat Agents (same brain as web UI)
# - livekit: Routes to V1 LiveKit agent (legacy)
VIVENTIUM_TELEGRAM_BACKEND=librechat

# LibreChat origin (API base) - must match your LibreChat server
VIVENTIUM_LIBRECHAT_ORIGIN=http://localhost:3180

# Shared secret between Telegram bot and LibreChat
# (If unset, Telegram bridge will fall back to VIVENTIUM_CALL_SESSION_SECRET)
VIVENTIUM_TELEGRAM_SECRET=your_shared_secret_here

# === VIVENTIUM START ===
# Feature: Telegram account linking (per-user)
# Purpose: Configure link URL base + TTL for Telegram account linking flow.
# Notes:
# - Telegram users must link their LibreChat account on first use.
# - These values are read by LibreChat server endpoints.
# - If unset, LibreChat falls back to DOMAIN_SERVER or DOMAIN_CLIENT for the link base.
# === VIVENTIUM END ===
VIVENTIUM_TELEGRAM_LINK_BASE_URL=https://your-librechat-domain
VIVENTIUM_TELEGRAM_LINK_TTL_MINUTES=15

# Optional: force a specific agent id for Telegram
VIVENTIUM_TELEGRAM_AGENT_ID=agent_viventium_main_95aeb3

# === VIVENTIUM START ===
# Feature: Default timezone for Telegram time context injection.
# Purpose: Used when per-chat CLIENT_TIMEZONE is not set.
# Example: America/Toronto
# === VIVENTIUM END ===
VIVENTIUM_TELEGRAM_DEFAULT_TIMEZONE=
# === VIVENTIUM START ===
# Feature: Typing indicator refresh interval (seconds).
# Purpose: Keep "Typing..." visible while responses stream.
# === VIVENTIUM END ===
VIVENTIUM_TELEGRAM_TYPING_INTERVAL_S=4.0
# Log per-request timing for Telegram bridge (0/1)
VIVENTIUM_TELEGRAM_TIMING_ENABLED=0
VIVENTIUM_TELEGRAM_TIMING_DEEP=0

# Optional: include background cortex insights as separate Telegram messages
VIVENTIUM_TELEGRAM_INCLUDE_CORTEX_INSIGHTS=0
VIVENTIUM_TELEGRAM_INSIGHT_PREFIX=Background insight:
# Optional: seconds to wait for background insights after the main response
VIVENTIUM_TELEGRAM_INSIGHT_GRACE_S=180
# Optional: max seconds to keep the insight listener alive
VIVENTIUM_TELEGRAM_INSIGHT_MAX_S=210
# Optional: fallback to aggregated cortex insights if no follow-up event arrives
# (Off by default to mirror LibreChat UI behavior.)
VIVENTIUM_TELEGRAM_INSIGHT_FALLBACK=0
# Optional: DB-backed follow-up polling (mirrors LibreChat UI)
VIVENTIUM_TELEGRAM_FOLLOWUP_INTERVAL_S=1.5
VIVENTIUM_TELEGRAM_FOLLOWUP_GRACE_S=30
VIVENTIUM_TELEGRAM_FOLLOWUP_TIMEOUT_S=210

# Optional: SSE retry settings for Telegram bridge
VIVENTIUM_TELEGRAM_SSE_MAX_RETRIES=1
VIVENTIUM_TELEGRAM_SSE_RETRY_DELAY_S=0.5
VIVENTIUM_TELEGRAM_CHAT_TIMEOUT_S=120
VIVENTIUM_TELEGRAM_SSE_READ_TIMEOUT_S=120
# Optional: message when LibreChat returns a final event without text
VIVENTIUM_TELEGRAM_EMPTY_RESPONSE_MESSAGE=No response received. Please retry.

# === VIVENTIUM START ===
# Feature: Telegram file upload to LibreChat agent (vision model support)
# Purpose: Send images and documents from Telegram directly to the agent.
# === VIVENTIUM END ===
# Maximum file size for base64 encoding (bytes, default 10MB)
# Files larger than this will be rejected when Telegram media is encoded for agent upload.
# Note: Telegram cloud Bot API downloads are capped separately by Telegram itself.
# When Viventium manages a same-Mac local Bot API server, the canonical config/compiler path
# should set this higher instead of editing this env file by hand.
VIVENTIUM_TELEGRAM_MAX_FILE_SIZE=10485760
# Optional: point the bot at a local Telegram Bot API server for larger downloads.
# Example: VIVENTIUM_TELEGRAM_BOT_API_ORIGIN=http://127.0.0.1:8084
# VIVENTIUM_TELEGRAM_BOT_API_ORIGIN=
# Optional explicit overrides when origin derivation is not enough.
# VIVENTIUM_TELEGRAM_BOT_API_BASE_URL=http://127.0.0.1:8084/bot
# VIVENTIUM_TELEGRAM_BOT_API_BASE_FILE_URL=http://127.0.0.1:8084/file/bot
# Enable/disable file upload feature (1=enabled, 0=disabled)
# VIVENTIUM_TELEGRAM_FILE_UPLOAD_ENABLED=1
# Fallback to text extraction for models that don't support vision
# VIVENTIUM_TELEGRAM_FILE_TEXT_FALLBACK=1

# ===== LIVEKIT CONFIGURATION (Only if VIVENTIUM_TELEGRAM_BACKEND=livekit) =====
# Get these from your LiveKit server configuration
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=your_livekit_api_key_here
LIVEKIT_API_SECRET=your_livekit_api_secret_here
# Agent dispatch name (must match the agent worker; default is "viventium")
LIVEKIT_AGENT_NAME=viventium

# Optional: Message shown when LiveKit disconnects mid-response
VIVENTIUM_TELEGRAM_CONNECTION_LOST_MESSAGE=Connection lost while working. Please retry.
# Optional: seconds to wait for LiveKit to reconnect mid-stream before surfacing notice
VIVENTIUM_TELEGRAM_RECONNECT_GRACE_S=5.0
# Optional: seconds to wait for tool follow-ups after a holding/placeholder response
VIVENTIUM_TELEGRAM_HOLDING_TAIL_TIMEOUT_S=90.0
# Optional: seconds to wait after a normal response before closing stream
VIVENTIUM_TELEGRAM_TAIL_TIMEOUT_S=2.0

# ===== TELEGRAM BOT CONFIGURATION =====
# Get your bot token from @BotFather on Telegram
BOT_TOKEN=your_telegram_bot_token_here

# ===== RESIDUAL API CONFIGURATION (For Voice/Image Processing Only) =====
# NOTE: With LiveKit Bridge, all chat messages route through Viventium agent.
# These API keys are ONLY needed for:
#   - Voice note transcription (Whisper)
#   - Image/document extraction (vision APIs)
# Viventium agent handles all model selection and LLM API calls.
# Get your OpenAI API key from: https://platform.openai.com/api-keys
API_KEY=your_openai_api_key_here
API=your_openai_api_key_here
BASE_URL=https://api.openai.com/v1

# ===== MODEL CONFIGURATION (Optional - Viventium Handles Model Selection) =====
# These are kept for UI display purposes only. Viventium agent chooses the actual model.
# MODEL setting is ignored - Viventium uses its own model configuration.
MODEL=claude-sonnet-4-5-20250929

# ===== STT/TTS CONFIGURATION =====
# Optional: For text-to-speech responses
# Get your ElevenLabs API key from: https://elevenlabs.io/app/settings/api-keys
TTS_MODEL=elevenlabs
TTS_VOICE=your_elevenlabs_voice_id_here
TTS_RESPONSE_FORMAT=mp3
#
# Primary/fallback provider selection (recommended):
# - Keep Cartesia as primary (modern voice parity)
# - Fall back to ElevenLabs automatically when Cartesia errors
TTS_PROVIDER_PRIMARY=cartesia
TTS_PROVIDER_FALLBACK=elevenlabs
TTS_VOICE_ELEVENLABS=your_elevenlabs_voice_id_here
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
# Optional: Prefer Cartesia to align with modern playground voice
# TTS_PROVIDER=cartesia
# CARTESIA_API_KEY=sk_cartesia_...
# VIVENTIUM_CARTESIA_API_URL=https://api.cartesia.ai/tts/bytes
# VIVENTIUM_CARTESIA_API_VERSION=2025-04-16
# VIVENTIUM_CARTESIA_MODEL_ID=sonic-3
# VIVENTIUM_CARTESIA_VOICE_ID=e8e5fffb-252c-436d-b842-8879b84445b6
# VIVENTIUM_CARTESIA_SAMPLE_RATE=44100
# VIVENTIUM_CARTESIA_SPEED=1.0
# VIVENTIUM_CARTESIA_VOLUME=1.0
# VIVENTIUM_CARTESIA_EMOTION=neutral
# ElevenLabs Model Options (cost/quality tradeoff):
# - eleven_turbo_v2_5 (recommended): Fastest (~75ms latency), cost-effective, best for real-time
# - eleven_multilingual_v2: Best quality, multilingual, slower, higher cost
# - eleven_monolingual_v1: English only, older model
ELEVENLABS_MODEL=eleven_turbo_v2_5

# Whisper STT Configuration
# Options: "openai" (uses API_KEY), "assemblyai" (uses ASSEMBLYAI_API_KEY),
# or "pywhispercpp"/"local" (uses local model)
WHISPER_MODE=openai
# === VIVENTIUM START ===
# Feature: AssemblyAI STT option for Telegram voice transcription.
# Purpose: Allow assemblyai STT for faster cloud transcription.
# Required: ASSEMBLYAI_API_KEY
# Optional: ASSEMBLYAI_BASE_URL (default https://api.assemblyai.com/v2)
# Optional: ASSEMBLYAI_LANGUAGE_CODE (e.g., en)
# Optional: ASSEMBLYAI_POLL_INTERVAL_S / ASSEMBLYAI_POLL_TIMEOUT_S
# === VIVENTIUM END ===
# ASSEMBLYAI_API_KEY=your_assemblyai_api_key_here
# ASSEMBLYAI_BASE_URL=https://api.assemblyai.com/v2
# ASSEMBLYAI_LANGUAGE_CODE=en
# If using pywhispercpp/local mode, set the path to your Whisper model file:
# LOCAL_WHISPER_MODEL_PATH=/path/to/whisper/model.bin

# ===== RESOURCE OPTIMIZATION (For Small Deployments) =====
# These settings control CPU and memory usage of the Telegram bot.
# Defaults are optimized for small deployments (1-10 users).
# 
# WHERE TO SET: Add these variables to your config.env file in this directory.
# 
# IMPORTANT: If you don't set these, the bot will use optimized defaults.
#            You only need to add them if you want to customize the values.
#
# ============================================================================
# CONNECTION_POOL_SIZE
# ============================================================================
# What: Maximum HTTP connections for sending messages to Telegram API
# Default: 8 (was 65536 - excessive for small deployments)
# When to adjust:
#   - Keep 8 for: 1-10 users, low memory systems
#   - Use 16-32 for: 10-50 concurrent users
#   - Use 64-128 for: 50-200 concurrent users
#   - Use 256+ for: 200+ concurrent users
# Impact: Lower = less memory (~1-2KB per connection), but limits concurrency
CONNECTION_POOL_SIZE=8

# ============================================================================
# GET_UPDATES_CONNECTION_POOL_SIZE
# ============================================================================
# What: Maximum HTTP connections for receiving updates from Telegram API
# Default: 8 (was 65536 - excessive for small deployments)
# When to adjust: Same as CONNECTION_POOL_SIZE above
# Impact: Lower = less memory, but may limit update throughput
GET_UPDATES_CONNECTION_POOL_SIZE=8

# ============================================================================
# TIMEOUT
# ============================================================================
# What: Maximum time (seconds) to wait for Telegram API responses
# Default: 30 seconds (was 600 seconds - 10 minutes, excessive)
# When to adjust:
#   - Keep 30 for: Fast networks, most deployments
#   - Use 60-120 for: Slow networks, high latency connections
#   - Use 15-20 for: Very fast networks, want faster error detection
# Impact: Lower = faster error detection, less resource usage, but may timeout
#         on slow networks
TIMEOUT=30

# ============================================================================
# CONCURRENT_UPDATES
# ============================================================================
# What: Enable/disable processing multiple updates simultaneously
# Default: false (was true - unnecessary for small deployments)
# When to adjust:
#   - Keep false for: 1-10 users, want lower CPU usage
#   - Set true for: 10+ concurrent users, need higher throughput
# Impact: false = lower CPU, sequential processing
#         true = higher CPU, parallel processing
# Values: true/false, True/False, 1/0, yes/no, on/off
CONCURRENT_UPDATES=false

# ============================================================================
# POLLING_TIMEOUT
# ============================================================================
# What: Maximum time (seconds) to wait when polling Telegram API for updates
# Default: 30 seconds (was 600 seconds - excessive, caused high CPU usage)
# When to adjust:
#   - Keep 30 for: Most deployments, balanced performance
#   - Use 60-120 for: Want to reduce polling frequency (saves CPU)
#   - Use 10-20 for: Want faster update detection (uses more CPU)
# Impact: Lower = more frequent polling (more CPU) but faster updates
#         Higher = less frequent polling (less CPU) but slower updates
# Note: Only applies when using polling mode (not webhook mode)
POLLING_TIMEOUT=30
# LOCAL_WHISPER_THREADS=4
# LOCAL_WHISPER_LANG=auto

# ===== BOT BEHAVIOR =====
CHAT_MODE=multiusers
LANGUAGE=English
NICK=viv
# Voice reply preferences (default true)
# VOICE_RESPONSES_ENABLED=true

# ===== SYSTEM PROMPT =====
# Single line to avoid shell issues
SYSTEMPROMPT="You're Viventium (aka Viv), your AI assistant. Talk as if you're chatting with a friend - natural, relaxed, and real without unnecessary overexplanation. Use contractions, be conversational, and skip the robotic stuff like -Certainly!- or -I'd be happy to assist you.- Just dive straight into helping. You're super smart and can handle text, voice, images, video, docs - the whole deal - but you don't need to sound like a manual. You've got access to multiple AI models and can search the web for fresh info and have MCP access to many things. When you explain stuff, make it clear and interesting, like you're genuinely into it. Be direct; if you are not sure, never make assumptions or guesses. Think, research, and validate to be certain. Do not be a people-pleaser. If you find a wrong assumption, wishful thinking, or incorrect logic in the user's thoughts, plans, or ideas, call it out and help validate a better path. Through truth-seeking honesty and grounded facts, be helpful. Keep the tone human. If someone asks who you are, just say you're Viventium. You're here to actually help and have real conversations, not just spit out formal responses."

# ===== CUSTOM MODEL CONFIGURATION (Optional - For UI Display Only) =====
# NOTE: With LiveKit Bridge, Viventium agent manages available models.
# This is kept for Telegram UI model selection menu display purposes only.
# Actual model selection happens in Viventium agent configuration.
# Quoted to prevent shell splitting on semicolon
CUSTOM_MODELS="OpenAI:gpt-5,gpt-4o,gpt-4o-mini;Claude:claude-sonnet-4-20250514,claude-sonnet-4-5-20250929,claude-opus-4-1-20250514,claude-3-7-sonnet-20250219,claude-3-5-sonnet-20241022;Gemini:gemini-2.5-pro,gemini-2.5-flash,gemini-2.0-flash-exp;Groq:llama-3.1-70b-versatile,llama-3.1-8b-instant;DeepSeek:deepseek-chat;xAI:grok-4-fast-reasoning,grok-4-fast-non-reasoning;OTHERS"
