#!/usr/bin/env bash
set -euo pipefail

resolve_script_source() {
  local source_path="${BASH_SOURCE[0]}"
  while [[ -L "$source_path" ]]; do
    local source_dir
    source_dir="$(cd -P "$(dirname "$source_path")" && pwd)"
    source_path="$(readlink "$source_path")"
    if [[ "$source_path" != /* ]]; then
      source_path="${source_dir}/${source_path}"
    fi
  done
  printf '%s\n' "$source_path"
}

SCRIPT_SOURCE="$(resolve_script_source)"
SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_SOURCE")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
WORKSPACE_ROOT="$(cd "$REPO_ROOT/.." && pwd)"

# shellcheck source=/dev/null
source "$REPO_ROOT/scripts/viventium/common.sh"
ensure_brew_paths_on_path

sanitize_macos_locale() {
  [[ "$(uname -s)" == "Darwin" ]] || return 0

  local needs_sanitization=0
  case "${LC_ALL:-}" in
    C.UTF-8|c.utf-8) needs_sanitization=1 ;;
  esac
  case "${LC_CTYPE:-}" in
    C.UTF-8|c.utf-8) needs_sanitization=1 ;;
  esac
  case "${LANG:-}" in
    C.UTF-8|c.utf-8) needs_sanitization=1 ;;
  esac
  (( needs_sanitization == 1 )) || return 0

  local available_locales=""
  local fallback_locale=""
  available_locales="$(locale -a 2>/dev/null || true)"

  if printf '%s\n' "$available_locales" | grep -Eiq '^C\.UTF-8$'; then
    return 0
  fi

  fallback_locale="$(
    printf '%s\n' "$available_locales" | grep -Ei 'utf-8$|utf8$' | head -n 1 || true
  )"

  [[ "${LC_ALL:-}" == "C.UTF-8" || "${LC_ALL:-}" == "c.utf-8" ]] && unset LC_ALL
  [[ "${LC_CTYPE:-}" == "C.UTF-8" || "${LC_CTYPE:-}" == "c.utf-8" ]] && unset LC_CTYPE

  if [[ -n "$fallback_locale" ]]; then
    export LANG="$fallback_locale"
  elif [[ "${LANG:-}" == "C.UTF-8" || "${LANG:-}" == "c.utf-8" ]]; then
    unset LANG
  fi
}

sanitize_macos_locale

refresh_repo_python() {
  ensure_brew_paths_on_path
  PYTHON_BIN="$(resolve_repo_python)"
  export PYTHON_BIN
  if declare -F ensure_python_requirements_file >/dev/null 2>&1; then
    local prepared_python=""
    prepared_python="$(ensure_python_requirements_file "$PYTHON_BIN" "$REPO_ROOT/scripts/viventium/requirements-installer.txt")"
    if [[ -n "$prepared_python" ]]; then
      PYTHON_BIN="$prepared_python"
      export PYTHON_BIN
    fi
  fi
}

APP_SUPPORT_DIR="${VIVENTIUM_APP_SUPPORT_DIR:-$HOME/Library/Application Support/Viventium}"
CONFIG_FILE="${VIVENTIUM_CONFIG_FILE:-$APP_SUPPORT_DIR/config.yaml}"
RUNTIME_DIR="${VIVENTIUM_RUNTIME_DIR:-$APP_SUPPORT_DIR/runtime}"
GENERATED_ENV="$RUNTIME_DIR/runtime.env"
GENERATED_LOCAL_ENV="$RUNTIME_DIR/runtime.local.env"
GENERATED_LIBRECHAT_YAML="$RUNTIME_DIR/librechat.yaml"
GENERATED_LIBRECHAT_ENV="$RUNTIME_DIR/service-env/librechat.env"
LOCK_FILE="${VIVENTIUM_COMPONENTS_LOCK_FILE:-$REPO_ROOT/components.lock.json}"
CLI_LOCK_DIR="${VIVENTIUM_CLI_LOCK_DIR:-$APP_SUPPORT_DIR/state/cli-operation.lock}"
CLI_LOCK_OWNER=0
DETACHED_START_PID=""
DETACHED_START_LOG_OFFSET=0
INSTALL_WAIT_PROGRESS_ACTIVE=0
INSTALL_WAIT_PROGRESS_LINES=0
INSTALL_WAIT_LAST_MESSAGE=""
