PRIVATE_REPO_DIR_DEFAULT=""
PRIVATE_CURATED_DIR_DEFAULT=""

refresh_private_repo_defaults() {
  if declare -F discover_private_repo_dir >/dev/null 2>&1; then
    PRIVATE_REPO_DIR_DEFAULT="$(discover_private_repo_dir "$WORKSPACE_ROOT" "$REPO_ROOT" || true)"
  else
    PRIVATE_REPO_DIR_DEFAULT=""
  fi

  if declare -F discover_private_curated_dir >/dev/null 2>&1; then
    PRIVATE_CURATED_DIR_DEFAULT="$(discover_private_curated_dir "$PRIVATE_REPO_DIR_DEFAULT" || true)"
  else
    PRIVATE_CURATED_DIR_DEFAULT=""
  fi
}

refresh_private_repo_defaults

helper_config_file() {
  printf '%s\n' "$APP_SUPPORT_DIR/helper-config.json"
}

runtime_checkout_file() {
  active_runtime_checkout_file "$APP_SUPPORT_DIR"
}

refresh_runtime_paths() {
  CONFIG_FILE="${VIVENTIUM_CONFIG_FILE:-$APP_SUPPORT_DIR/config.yaml}"
  RUNTIME_DIR="${VIVENTIUM_RUNTIME_DIR:-$APP_SUPPORT_DIR/runtime}"
  GENERATED_ENV="$RUNTIME_DIR/runtime.env"
  GENERATED_LOCAL_ENV="$RUNTIME_DIR/runtime.local.env"
  GENERATED_LIBRECHAT_YAML="$RUNTIME_DIR/librechat.yaml"
  GENERATED_LIBRECHAT_ENV="$RUNTIME_DIR/service-env/librechat.env"
  CLI_LOCK_DIR="${VIVENTIUM_CLI_LOCK_DIR:-$APP_SUPPORT_DIR/state/cli-operation.lock}"
}

run_shell_init() {
  refresh_repo_python
  "$PYTHON_BIN" "$REPO_ROOT/scripts/viventium/shell_init.py" --target "$REPO_ROOT/bin/viventium" "$@"
}

parse_global_options() {
  local original_args=("$@")
  PARSED_ARGS=()
  local index=0
  local arg=""

  while [[ $index -lt ${#original_args[@]} ]]; do
    arg="${original_args[$index]}"
    case "$arg" in
      --app-support-dir)
        if [[ $((index + 1)) -ge ${#original_args[@]} ]]; then
          echo "Missing value for $arg" >&2
          exit 1
        fi
        APP_SUPPORT_DIR="${original_args[$((index + 1))]}"
        export VIVENTIUM_APP_SUPPORT_DIR="$APP_SUPPORT_DIR"
        refresh_runtime_paths
        index=$((index + 2))
        ;;
      --config-file)
        if [[ $((index + 1)) -ge ${#original_args[@]} ]]; then
          echo "Missing value for $arg" >&2
          exit 1
        fi
        CONFIG_FILE="${original_args[$((index + 1))]}"
        export VIVENTIUM_CONFIG_FILE="$CONFIG_FILE"
        index=$((index + 2))
        ;;
      --runtime-dir)
        if [[ $((index + 1)) -ge ${#original_args[@]} ]]; then
          echo "Missing value for $arg" >&2
          exit 1
        fi
        RUNTIME_DIR="${original_args[$((index + 1))]}"
        export VIVENTIUM_RUNTIME_DIR="$RUNTIME_DIR"
        refresh_runtime_paths
        index=$((index + 2))
        ;;
      --lock-file)
        if [[ $((index + 1)) -ge ${#original_args[@]} ]]; then
          echo "Missing value for $arg" >&2
          exit 1
        fi
        LOCK_FILE="${original_args[$((index + 1))]}"
        export VIVENTIUM_COMPONENTS_LOCK_FILE="$LOCK_FILE"
        index=$((index + 2))
        ;;
      *)
        PARSED_ARGS+=("$arg")
        index=$((index + 1))
        ;;
    esac
  done
}

bootstrap_components() {
  refresh_repo_python
  local args=(
    --repo-root "$REPO_ROOT"
    --lock-file "$LOCK_FILE"
  )
  if [[ -f "$CONFIG_FILE" ]]; then
    args+=(--config "$CONFIG_FILE")
  fi
  VIVENTIUM_DISABLE_PRIVATE_SNAPSHOTS=1 "$PYTHON_BIN" "$REPO_ROOT/scripts/viventium/bootstrap_components.py" \
    "${args[@]}" \
    "$@"
}

bootstrap_components_upgrade_checked() {
  local bootstrap_output=""
  if ! bootstrap_output="$(bootstrap_components "$@")"; then
    printf '%s\n' "$bootstrap_output"
    return 1
  fi

  printf '%s\n' "$bootstrap_output"
  local alignment_args=(
    --repo-root "$REPO_ROOT"
    --app-support-dir "$APP_SUPPORT_DIR"
    --no-fetch
    --json
  )
  if [[ -f "$CONFIG_FILE" ]]; then
    alignment_args+=(--config-file "$CONFIG_FILE")
  fi
  if [[ "${ALLOW_DIRTY:-0}" == "1" ]]; then
    alignment_args+=(--allow-dirty-parent)
  fi
  local alignment_json=""
  alignment_json="$("$PYTHON_BIN" "$REPO_ROOT/scripts/viventium/upgrade_check.py" "${alignment_args[@]}")" || true
  if ! "$PYTHON_BIN" - "$alignment_json" <<'PY'
import json
import sys

try:
    report = json.loads(sys.argv[1])
except (IndexError, json.JSONDecodeError):
    print("Structured component alignment verification failed: unreadable report.", file=sys.stderr)
    raise SystemExit(1)

drift = report.get("component_lock_drift")
if not isinstance(drift, list):
    print("Structured component alignment verification failed: invalid component result.", file=sys.stderr)
    raise SystemExit(1)
blockers = report.get("blockers")
ready = report.get("ready_to_upgrade")
if not isinstance(blockers, list) or any(not isinstance(item, str) or not item for item in blockers):
    print("Structured component alignment verification failed: invalid blocker result.", file=sys.stderr)
    raise SystemExit(1)
if not isinstance(ready, bool) or ready != (len(blockers) == 0):
    print("Structured component alignment verification failed: inconsistent readiness result.", file=sys.stderr)
    raise SystemExit(1)
if drift:
    for item in drift:
        if isinstance(item, dict):
            name = str(item.get("name") or "managed component")
            status = str(item.get("status") or "not_aligned")
            print(f"Managed component is not aligned: {name} ({status})", file=sys.stderr)
    raise SystemExit(1)
if not ready:
    for blocker in blockers:
        print(f"Upgrade readiness blocker remains after component bootstrap: {blocker}", file=sys.stderr)
    raise SystemExit(1)
PY
  then
    echo "Upgrade aborted because selected components did not reach their declared pinned state." >&2
    return 1
  fi
}

cleanup_cli_lock() {
  if [[ "${CLI_LOCK_OWNER:-0}" != "1" ]]; then
    return 0
  fi
  rm -f "$CLI_LOCK_DIR/pid" "$CLI_LOCK_DIR/command" "$CLI_LOCK_DIR/process_command" "$CLI_LOCK_DIR/created_at" >/dev/null 2>&1 || true
  rmdir "$CLI_LOCK_DIR" >/dev/null 2>&1 || true
  CLI_LOCK_OWNER=0
  export VIVENTIUM_CLI_LOCK_HELD=0
  unset VIVENTIUM_CLI_LOCK_DIR
}

stack_owner_state_file() {
  local runtime_profile="${VIVENTIUM_RUNTIME_PROFILE:-isolated}"
  printf '%s\n' "$APP_SUPPORT_DIR/state/runtime/${runtime_profile}/stack-owner.json"
}

detached_launch_process_group_file() {
  local runtime_profile="${VIVENTIUM_RUNTIME_PROFILE:-isolated}"
  printf '%s\n' "$APP_SUPPORT_DIR/state/runtime/${runtime_profile}/detached-launch.pgid"
}

read_detached_launch_process_group() {
  local pgid_file=""
  pgid_file="$(detached_launch_process_group_file)"
  if [[ -f "$pgid_file" ]]; then
    tr -d '[:space:]' <"$pgid_file"
  fi
}

detached_launch_process_group_running() {
  local recorded_pgid=""
  local running_pids=""

  recorded_pgid="$(read_detached_launch_process_group)"
  [[ "$recorded_pgid" =~ ^[0-9]+$ ]] || return 1

  running_pids="$(
    ps -Ao pid=,pgid=,state= 2>/dev/null | \
      awk -v target="$recorded_pgid" '$2 == target && $3 !~ /Z/ { print $1 }' | \
      xargs 2>/dev/null || true
  )"
  [[ -n "$running_pids" ]]
}

install_process_group_matches_scope() {
  local recorded_pgid="${1:-}"
  [[ "$recorded_pgid" =~ ^[0-9]+$ ]] || return 1
  ps -Ao pgid=,command= 2>/dev/null | awk \
    -v target="$recorded_pgid" \
    -v app_support="$APP_SUPPORT_DIR" \
    -v repo_root="$REPO_ROOT" '
      $1 == target {
        matched_group = 1
        $1 = ""
        if (index($0, app_support) || index($0, repo_root)) {
          matched_scope = 1
        }
      }
      END { exit(matched_group && matched_scope ? 0 : 1) }
    '
}

terminate_install_owned_process_group() {
  local recorded_pgid="${1:-}"
  [[ "$recorded_pgid" =~ ^[0-9]+$ ]] || return 0
  local current_pgid=""
  current_pgid="$(ps -p $$ -o pgid= 2>/dev/null | tr -d '[:space:]' || true)"
  [[ "$recorded_pgid" != "$current_pgid" ]] || return 1
  install_process_group_matches_scope "$recorded_pgid" || return 1

  kill -TERM -- "-$recorded_pgid" >/dev/null 2>&1 || true
  local tries=0
  while [[ "$tries" -lt 50 ]] && ps -Ao pgid= 2>/dev/null | awk -v target="$recorded_pgid" '$1 == target { found=1 } END { exit(found ? 0 : 1) }'; do
    sleep 0.1
    tries=$((tries + 1))
  done
  if ps -Ao pgid= 2>/dev/null | awk -v target="$recorded_pgid" '$1 == target { found=1 } END { exit(found ? 0 : 1) }'; then
    kill -KILL -- "-$recorded_pgid" >/dev/null 2>&1 || true
  fi
}

drain_failed_install_runtime() {
  local candidate=""
  local recorded_pgid=""
  local seen_pgids=" "
  local candidates=()
  if [[ "${DETACHED_START_PID:-}" =~ ^[0-9]+$ ]]; then
    candidates+=("$DETACHED_START_PID")
  fi
  if [[ -d "$APP_SUPPORT_DIR/state/runtime" ]]; then
    while IFS= read -r candidate; do
      [[ -f "$candidate" && ! -L "$candidate" ]] || continue
      recorded_pgid="$(tr -d '[:space:]' <"$candidate" 2>/dev/null || true)"
      [[ "$recorded_pgid" =~ ^[0-9]+$ ]] && candidates+=("$recorded_pgid")
    done < <(find "$APP_SUPPORT_DIR/state/runtime" -type f -name detached-launch.pgid -print 2>/dev/null)
  fi

  for recorded_pgid in "${candidates[@]}"; do
    if [[ "$seen_pgids" == *" $recorded_pgid "* ]]; then
      continue
    fi
    seen_pgids+="$recorded_pgid "
    if terminate_install_owned_process_group "$recorded_pgid"; then
      echo "Drained failed install process group: $recorded_pgid" >&2
    else
      echo "Refused to terminate unverified failed install process group: $recorded_pgid" >&2
    fi
  done

  if [[ -d "$APP_SUPPORT_DIR/state/runtime" ]]; then
    find "$APP_SUPPORT_DIR/state/runtime" -type f \( -name detached-launch.pgid -o -name mongodb-native.pid \) -delete 2>/dev/null || true
  fi
}

write_stack_owner_state() {
  local command_name="${1:-unknown}"
  local owner_file=""
  owner_file="$(stack_owner_state_file)"
  mkdir -p "$(dirname "$owner_file")"
  "$PYTHON_BIN" - "$owner_file" "$REPO_ROOT" "$APP_SUPPORT_DIR" "${VIVENTIUM_RUNTIME_PROFILE:-isolated}" "$command_name" <<'PY'
import json
import sys
from datetime import datetime, timezone
from pathlib import Path

owner_file, repo_root, app_support_dir, runtime_profile, command_name = sys.argv[1:]
payload = {
    "repoRoot": repo_root,
    "appSupportDir": app_support_dir,
    "runtimeProfile": runtime_profile,
    "command": command_name,
    "updatedAt": datetime.now(timezone.utc).isoformat(),
}
Path(owner_file).write_text(json.dumps(payload, indent=2) + "\n", encoding="utf-8")
PY
}

set_helper_status_bar_visibility() {
  local enabled="${1:-1}"
  local helper_config=""
  local helper_runtime_repo_root=""
  local allow_protected_repo_root=0
  helper_config="$(helper_config_file)"
  helper_runtime_repo_root="$(resolve_helper_runtime_repo_root "$REPO_ROOT" "$APP_SUPPORT_DIR")"
  if active_runtime_checkout_allows_repo_root "$APP_SUPPORT_DIR" "$helper_runtime_repo_root"; then
    allow_protected_repo_root=1
  fi
  refresh_repo_python
  "$PYTHON_BIN" - "$helper_config" "$helper_runtime_repo_root" "$APP_SUPPORT_DIR" "$enabled" "$allow_protected_repo_root" <<'PY'
import json
import sys
from pathlib import Path

helper_config, repo_root, app_support_dir, enabled, allow_protected_repo_root = sys.argv[1:]
path = Path(helper_config)
payload = {}
if path.exists():
    try:
        payload = json.loads(path.read_text(encoding="utf-8"))
    except json.JSONDecodeError:
        payload = {}

payload["repoRoot"] = repo_root
payload["appSupportDir"] = app_support_dir
payload["allowProtectedRepoRoot"] = allow_protected_repo_root == "1"
payload["showInStatusBar"] = enabled == "1"

path.parent.mkdir(parents=True, exist_ok=True)
path.write_text(json.dumps(payload, indent=2) + "\n", encoding="utf-8")
PY
}

helper_status_bar_enabled() {
  local helper_config=""
  helper_config="$(helper_config_file)"
  if [[ ! -f "$helper_config" ]]; then
    return 0
  fi

  refresh_repo_python
  local status=""
  status="$("$PYTHON_BIN" - "$helper_config" <<'PY'
import json
import sys
from pathlib import Path

path = Path(sys.argv[1])
try:
    payload = json.loads(path.read_text(encoding="utf-8"))
except Exception:
    print("on")
    raise SystemExit(0)

print("on" if payload.get("showInStatusBar", True) else "off")
PY
)"
  [[ "$status" == "on" ]]
}

read_cli_lock_metadata() {
  local pid_file="$CLI_LOCK_DIR/pid"
  local command_file="$CLI_LOCK_DIR/command"
  local pid=""
  local command=""
  if [[ -f "$pid_file" ]]; then
    pid="$(tr -d '[:space:]' <"$pid_file" 2>/dev/null || true)"
  fi
  if [[ -f "$command_file" ]]; then
    command="$(tr -d '\r\n' <"$command_file" 2>/dev/null || true)"
  fi
  printf '%s\n%s\n' "$pid" "$command"
}

cli_lock_active() {
  local pid="$1"
  if [[ -z "$pid" || ! "$pid" =~ ^[0-9]+$ ]]; then
    return 1
  fi
  kill -0 "$pid" >/dev/null 2>&1
}

cli_lock_process_command() {
  local pid="$1"
  ps -p "$pid" -o command= 2>/dev/null | sed 's/^[[:space:]]*//' || true
}

cli_lock_active_owner() {
  local pid="$1"
  if ! cli_lock_active "$pid"; then
    return 1
  fi

  local current_command=""
  current_command="$(cli_lock_process_command "$pid")"

  local recorded_command_file="$CLI_LOCK_DIR/process_command"
  if [[ -f "$recorded_command_file" ]]; then
    local recorded_command=""
    recorded_command="$(tr -d '\r' <"$recorded_command_file" 2>/dev/null || true)"
    if [[ -z "$current_command" ]]; then
      [[ -n "$recorded_command" ]]
      return
    fi
    [[ -n "$recorded_command" && "$current_command" == "$recorded_command" ]]
    return
  fi

  if [[ -z "$current_command" ]]; then
    return 0
  fi

  # Legacy lock files stored only a PID and command. Treat a reused PID from an
  # unrelated process as stale instead of blocking every CLI command.
  [[ "$current_command" == *"bin/viventium"* ]]
}

acquire_cli_lock() {
  local command_name="${1:-unknown}"

  if [[ "${VIVENTIUM_CLI_LOCK_HELD:-0}" == "1" && "${VIVENTIUM_CLI_LOCK_DIR:-}" == "$CLI_LOCK_DIR" ]]; then
    return 0
  fi

  ensure_app_support_layout "$APP_SUPPORT_DIR"
  mkdir -p "$(dirname "$CLI_LOCK_DIR")"

  while ! mkdir "$CLI_LOCK_DIR" 2>/dev/null; do
    local existing_pid existing_command
    local lock_metadata
    lock_metadata="$(read_cli_lock_metadata)"
    existing_pid="$(printf '%s\n' "$lock_metadata" | sed -n '1p')"
    existing_command="$(printf '%s\n' "$lock_metadata" | sed -n '2p')"
    if [[ -z "$existing_command" ]]; then
      existing_command="unknown"
    fi
    if ! cli_lock_active_owner "$existing_pid"; then
      rm -f "$CLI_LOCK_DIR/pid" "$CLI_LOCK_DIR/command" "$CLI_LOCK_DIR/process_command" "$CLI_LOCK_DIR/created_at" >/dev/null 2>&1 || true
      rmdir "$CLI_LOCK_DIR" >/dev/null 2>&1 || true
      continue
    fi
    echo "Another Viventium CLI operation is already running (${existing_command}, pid ${existing_pid})." >&2
    echo "Wait for it to finish or stop the current run before retrying." >&2
    exit 1
  done

  printf '%s\n' "$$" >"$CLI_LOCK_DIR/pid"
  printf '%s\n' "$command_name" >"$CLI_LOCK_DIR/command"
  cli_lock_process_command "$$" >"$CLI_LOCK_DIR/process_command"
  date -u '+%Y-%m-%dT%H:%M:%SZ' >"$CLI_LOCK_DIR/created_at"
  export VIVENTIUM_CLI_LOCK_HELD=1
  export VIVENTIUM_CLI_LOCK_DIR="$CLI_LOCK_DIR"
  CLI_LOCK_OWNER=1
  trap cleanup_cli_lock EXIT INT TERM
}

run_preflight() {
  refresh_repo_python
  local apply_mode="${1:-check}"
  local args=(
    --config "$CONFIG_FILE"
  )
  if [[ "$apply_mode" == "apply" ]]; then
    args+=(--apply)
    if [[ "${VIVENTIUM_AUTO_APPROVE_PREREQS:-false}" == "true" || "${HEADLESS:-0}" == "1" ]]; then
      args+=(--non-interactive)
    else
      reattach_stdin_from_tty_if_available || true
    fi
  fi
  ensure_brew_paths_on_path
  "$PYTHON_BIN" "$REPO_ROOT/scripts/viventium/preflight.py" "${args[@]}"
  refresh_repo_python
  ensure_brew_paths_on_path
}

reattach_stdin_from_tty_if_available() {
  # `curl ... | bash` leaves stdin on the consumed bootstrap pipe even though the
  # user still has a controlling terminal. Reattach before any interactive prompt.
  if [[ -t 0 ]]; then
    return 0
  fi
  if [[ ! -t 1 && ! -t 2 ]]; then
    return 1
  fi
  if ! exec </dev/tty; then
    return 1
  fi
}

usage() {
  cat <<'USAGE'
Usage:
  bin/viventium <command> [options]

Commands:
  install           Run the first-run wizard, compile config, and print next steps.
                    Supports --preset/--config/--config-input <file> and --headless.
  upgrade           Pull the current branch, refresh prerequisites/components, and recompile config.
  update            Alias for upgrade.
  configure         Re-run the wizard and overwrite the generated config file.
                    Supports --preset/--config/--config-input <file> and --headless.
  shell-init        Print or apply the optional shell setup for global `viventium` / `viv` commands.
  launch            Start the current Viventium stack in the background.
  bootstrap-components
                    Fetch pinned public component repos from components.lock.json.
  compile-config    Render runtime env/yaml files from config.yaml.
  doctor            Run preflight checks against the current config.
  register-link     Register this public Viventium instance under a viventium.ai vanity link.
  password-reset-link
                    Print a one-time password reset link locally without enabling public reset.
  install-helper    Install or refresh the macOS Viventium status-bar helper.
  uninstall-helper  Remove the macOS Viventium status-bar helper.
  status-bar        Turn the macOS Viventium status-bar helper on or off.
  runtime-checkout  Show or choose the checkout used by helper/start commands.
  dev-env           Create and run side-by-side local development environments.
  dev-runtime       Activate or inspect the checkout used by the installed runtime.
  workflows         Run Viventium GlassHive-backed local work workflows.
  heal              Alias for workflows start/status/cancel/open-artifacts heal flow.
  feature-request   Alias for workflows feature-request flow.
  report-bug        Alias for workflows bug-report flow.
  bug-report        Compatibility alias for report-bug.
  prompt-workbench  Start, stop, open, or inspect the local Prompt Workbench.
  preflight         Detect and optionally install missing system prerequisites.
  reset             Factory-reset the local Viventium install state under App Support.
  start             Start the current Viventium stack using generated runtime env.
  status            Show live service health and access URLs.
  continuity-audit  Capture continuity metadata for the current install.
  memory-harden     Dry-run, apply, schedule, status, or roll back saved-memory hardening.
  transcripts       Configure the optional local meeting-transcripts source folder.
  memory-dedupe     Dry-run or apply saved-memory/provider-key dedupe and unique indexes.
  stop              Stop the current Viventium stack.
  snapshot          Capture a local state snapshot into App Support.
  restore           Inspect a snapshot and print or apply restore actions.
  uninstall         Remove the local Viventium install state and helper app.
  help              Show this help.
USAGE
}

subcommand_usage() {
  local command="${1:-}"
  case "$command" in
    start)
      cat <<'USAGE'
Usage:
  bin/viventium start [launcher options]

Starts the current Viventium stack using the generated config/runtime files.
Additional arguments are forwarded to:
  viventium_v0_4/viventium-librechat-start.sh

Examples:
  bin/viventium start
  bin/viventium start --skip-voice-gateway
  bin/viventium start --profile=compat
USAGE
      ;;
    stop)
      cat <<'USAGE'
Usage:
  bin/viventium stop [launcher options]

Stops the current Viventium stack and, for native installs, the local support services.
USAGE
      ;;
    install|bootstrap)
      cat <<'USAGE'
Usage:
  bin/viventium install [--headless --config-input <file>] [--no-start]

Runs the first-run setup flow, bootstraps components, compiles config, runs doctor,
and optionally starts the stack.
USAGE
      ;;
    configure|wizard)
      cat <<'USAGE'
Usage:
  bin/viventium configure [--headless --config-input <file>]

Re-runs the setup wizard and rewrites the generated config file.
USAGE
      ;;
    upgrade|update)
      cat <<'USAGE'
Usage:
  bin/viventium upgrade [--restart] [--skip-pull] [--allow-dirty]
  bin/viventium upgrade --check [--json]
  bin/viventium update [--restart] [--skip-pull] [--allow-dirty]

Refreshes the current branch, reruns aggregated preflight, refreshes pinned components,
recompiles the runtime files, reruns doctor, and optionally restarts the stack.

With --check, reports update availability and blockers without pulling, compiling,
installing helpers, or changing the running stack.
USAGE
      ;;
    status)
      cat <<'USAGE'
Usage:
  bin/viventium status

Shows the current live Viventium service health, including localhost and LAN URLs when available.
USAGE
      ;;
    continuity-audit)
      cat <<'USAGE'
Usage:
  bin/viventium continuity-audit
  bin/viventium continuity-audit --clear-recall-marker

Captures metadata-only continuity state for the current install under App Support state.
USAGE
      ;;
    memory-harden)
      cat <<'USAGE'
Usage:
  bin/viventium memory-harden dry-run [--user-email <email>]
  bin/viventium memory-harden apply [--run-id <id>] [--user-email <email>]
  bin/viventium memory-harden rollback --run-id <id>
  bin/viventium memory-harden status
  bin/viventium memory-harden ingest-transcripts --dry-run|--apply [--user-email <email>] [--transcript-rag-mode detailed_summary_only]
  bin/viventium memory-harden install-schedule [--schedule "0 3 * * *"]
  bin/viventium memory-harden uninstall-schedule

Runs local saved-memory hardening as an operator job. Raw proposals and rollback
snapshots stay under App Support state, not inside the public repo.
USAGE
      ;;
    transcripts)
      cat <<'USAGE'
Usage:
  bin/viventium transcripts source status [--json]
  bin/viventium transcripts source set <folder> [--json]
  bin/viventium transcripts source clear [--json]

Reads or updates runtime.memory_hardening.transcripts.source_dir in the canonical
local config.yaml, writes a local backup before changes, and recompiles runtime
files after set/clear.
USAGE
      ;;
    memory-dedupe)
      cat <<'USAGE'
Usage:
  bin/viventium memory-dedupe --dry-run [--json]
  bin/viventium memory-dedupe --apply [--create-indexes] [--json]

Repairs duplicate saved-memory keys and duplicate connected-provider key rows.
Dry-run is the default. Unique indexes are only created with --apply --create-indexes
after duplicate rows are gone.
USAGE
      ;;
    doctor)
      cat <<'USAGE'
Usage:
  bin/viventium doctor

Runs preflight checks against the current config and generated runtime files.
USAGE
      ;;
    register-link)
      cat <<'USAGE'
Usage:
  bin/viventium register-link <username> [--directory-base-url https://viventium.ai]

Registers the current public Viventium client URL as a vanity redirect under
viventium.ai/u/<username>. The local instance must already be running with a
public remote-access mode so the verification document is reachable.
USAGE
      ;;
    password-reset-link)
      cat <<'USAGE'
Usage:
  bin/viventium password-reset-link <email>

Prints a one-time password reset link locally for an existing account without
enabling the public browser password-reset endpoint.
USAGE
      ;;
    launch)
      cat <<'USAGE'
Usage:
  bin/viventium launch [launcher options]

Starts the current Viventium stack in the background and returns immediately.
USAGE
      ;;
    install-helper)
      cat <<'USAGE'
Usage:
  bin/viventium install-helper

Installs or refreshes the macOS Viventium status-bar helper.
USAGE
      ;;
    status-bar)
      cat <<'USAGE'
Usage:
  bin/viventium status-bar on
  bin/viventium status-bar off
  bin/viventium status-bar status

Turns the macOS Viventium status-bar helper on or off without touching the rest
of the local App Support state.
USAGE
      ;;
    runtime-checkout)
      cat <<'USAGE'
Usage:
  bin/viventium runtime-checkout status
  bin/viventium runtime-checkout use --this [--allow-protected-folder] [--no-helper-refresh]
  bin/viventium runtime-checkout use <path> [--allow-protected-folder] [--no-helper-refresh]
  bin/viventium runtime-checkout clear [--no-helper-refresh]

Chooses the checkout that local start/helper operations should use. The setting is
stored under App Support state and does not copy, delete, pull, reset, or modify
runtime databases or user configuration.

For the current checkout:
  bin/viventium runtime-checkout use --this --allow-protected-folder
USAGE
      ;;
    dev-env)
      cat <<'USAGE'
Usage:
  bin/viventium dev-env create <name> [--port-offset 1000] [--replace]
  bin/viventium dev-env list [--json]
  bin/viventium dev-env status <name> [--json]
  bin/viventium dev-env run <name> <viventium-command> [args...]

Creates side-by-side local development App Support state for app-facing
services while keeping heavy singleton services shared by default.
USAGE
      ;;
    dev-runtime)
      cat <<'USAGE'
Usage:
  bin/viventium dev-runtime status
  bin/viventium dev-runtime activate-current [--validate] [--restart] [--allow-protected-folder] [--allow-dirty-local-testing]
  bin/viventium dev-runtime clear

Developer-friendly wrapper over runtime-checkout. It does not copy code into
the installed path; it selects a checkout, validates it, and optionally restarts.
USAGE
      ;;
    workflows)
      cat <<'USAGE'
Usage:
  bin/viventium workflows status [--json]
  bin/viventium workflows start heal [--mode diagnose|apply] [--provider auto|codex|claude] [--reasoning-effort xhigh]
  bin/viventium workflows start feature-request --request <text> [--provider auto|codex|claude]
  bin/viventium workflows start bug-report --what-happened <text> [--steps-to-reproduce <text>] [--expected <text>] [--actual <text>] [--details <text>]
  bin/viventium workflows start bug-report --request <text>  # compatibility alias for --what-happened
  bin/viventium workflows approve [--slug <slug>]
  bin/viventium workflows cancel
  bin/viventium workflows open-artifacts

Runs Viventium local work workflows through GlassHive host workers when enabled.
When GlassHive host workers are unavailable, the command fails loud unless an
explicit degraded mode is requested.
USAGE
      ;;
    prompt-workbench)
      cat <<'USAGE'
Usage:
  bin/viventium prompt-workbench start [--port <port>] [--json]
  bin/viventium prompt-workbench open [--port <port>] [--json]
  bin/viventium prompt-workbench stop [--json]
  bin/viventium prompt-workbench status [--json]

Manages only the standalone local Prompt Workbench web app. Stop does not stop
the main Viventium runtime, LibreChat, or native support services.
USAGE
      ;;
    heal)
      cat <<'USAGE'
Usage:
  bin/viventium heal start [--mode diagnose|apply] [--provider auto|codex|claude] [--reasoning-effort xhigh]
  bin/viventium heal status [--json]
  bin/viventium heal cancel
  bin/viventium heal open-artifacts
USAGE
      ;;
    feature-request)
      cat <<'USAGE'
Usage:
  bin/viventium feature-request start --request <text> [--provider auto|codex|claude]
  bin/viventium feature-request approve [--slug <slug>]
  bin/viventium feature-request status [--json]
  bin/viventium feature-request cancel
  bin/viventium feature-request open-artifacts
USAGE
      ;;
    report-bug|bug-report)
      cat <<'USAGE'
Usage:
  bin/viventium report-bug start --what-happened <text> [--steps-to-reproduce <text>] [--expected <text>] [--actual <text>] [--details <text>]
  bin/viventium report-bug start --request <text>  # compatibility alias for --what-happened
  bin/viventium report-bug approve [--slug <slug>]
  bin/viventium report-bug status [--json]
  bin/viventium report-bug cancel
  bin/viventium report-bug open-artifacts
  bin/viventium bug-report ...  # compatibility alias
USAGE
      ;;
    shell-init)
      cat <<'USAGE'
Usage:
  bin/viventium shell-init [--print-command] [--apply] [--shell <name>] [--profile <path>]

Prints or applies the optional shell setup that makes `viventium` and `viv`
available from any folder by linking this checkout into `~/.local/bin` and
ensuring that directory is on your shell PATH.
USAGE
      ;;
    uninstall-helper)
      cat <<'USAGE'
Usage:
  bin/viventium uninstall-helper

Removes the macOS Viventium status-bar helper.
USAGE
      ;;
    preflight)
      cat <<'USAGE'
Usage:
  bin/viventium preflight [--apply]

Aggregates missing system prerequisites for the current config and optionally
installs them in one batch.
USAGE
      ;;
    reset)
      cat <<'USAGE'
Usage:
  bin/viventium reset [--yes]

Stops the current stack and removes the local Viventium install state under App Support so you
can run a clean install again from this checkout.
USAGE
      ;;
    compile-config)
      cat <<'USAGE'
Usage:
  bin/viventium compile-config

Renders runtime env and YAML files from the canonical config.yaml.
USAGE
      ;;
    bootstrap-components)
      cat <<'USAGE'
Usage:
  bin/viventium bootstrap-components

Fetches or updates the pinned component repos from components.lock.json.
USAGE
      ;;
    snapshot)
      cat <<'USAGE'
Usage:
  bin/viventium snapshot [--output-root <path>]

Attempts a complete owner-only logical snapshot of canonical config, history/memory/agents,
uploads, and schedules. Provider/channel credentials are excluded and require reauthentication.
When a complete capture prerequisite is unavailable, writes metadata-only evidence without
changing the prior last-good pointer until the new attempt is complete.
USAGE
      ;;
    restore)
      cat <<'USAGE'
Usage:
  bin/viventium restore [options]

Validates a bundle without changing target state, or restores a complete logical bundle into an
explicit empty App Support target, fresh checkout, and empty loopback Mongo database. Recall is
marked for rebuild and provider/channel/browser credentials require reauthentication.
USAGE
      ;;
    uninstall)
      cat <<'USAGE'
Usage:
  bin/viventium uninstall [--yes]

Stops the current stack, removes the Viventium App Support footprint, and uninstalls the macOS
status-bar helper. The repo checkout is left untouched.
USAGE
      ;;
    *)
      usage
      ;;
  esac
}

compile_config() {
  local compile_status=0
  refresh_repo_python
  ensure_app_support_layout "$APP_SUPPORT_DIR"
  if [[ -e "$GENERATED_ENV" || -L "$GENERATED_ENV" ]]; then
    "$PYTHON_BIN" "$REPO_ROOT/scripts/viventium/agent_migration_state.py" import-legacy \
      --repo-root "$REPO_ROOT" \
      --app-support-dir "$APP_SUPPORT_DIR" \
      --runtime-env "$GENERATED_ENV" >/dev/null
  fi
  export VIVENTIUM_LIBRECHAT_SOURCE_PHASE="compile"
  prepare_runtime_exports
  "$PYTHON_BIN" "$REPO_ROOT/scripts/viventium/config_compiler.py" \
    --config "$CONFIG_FILE" \
    --output-dir "$RUNTIME_DIR" \
    "$@" || compile_status=$?
  unset VIVENTIUM_LIBRECHAT_SOURCE_PHASE
  if [[ "$compile_status" -ne 0 ]]; then
    return "$compile_status"
  fi
  if [[ -f "$GENERATED_LIBRECHAT_YAML" ]]; then
    export VIVENTIUM_LIBRECHAT_SOURCE_OF_TRUTH="$GENERATED_LIBRECHAT_YAML"
  fi
}

sync_memory_hardening_schedule() {
  if [[ "$(uname -s)" != "Darwin" || ! -f "$GENERATED_ENV" ]]; then
    return 0
  fi
  local enabled schedule plist_path
  enabled="$(
    awk -F= '$1=="VIVENTIUM_MEMORY_HARDENING_ENABLED"{print $2; exit}' "$GENERATED_ENV" | sed "s/^'//;s/'$//"
  )"
  schedule="$(
    awk -F= '$1=="VIVENTIUM_MEMORY_HARDENING_SCHEDULE"{value=$0; sub(/^VIVENTIUM_MEMORY_HARDENING_SCHEDULE=/, "", value); print value; exit}' "$GENERATED_ENV" | sed "s/^'//;s/'$//"
  )"
  plist_path="$HOME/Library/LaunchAgents/ai.viventium.memory-harden.plist"
  local memory_harden_script="$REPO_ROOT/scripts/viventium/memory_harden.py"
  if [[ "$enabled" == "true" ]]; then
    if [[ ! -f "$memory_harden_script" ]]; then
      echo "Warning: memory hardening is enabled but memory_harden.py was not found." >&2
      return 1
    fi
    if ! "$PYTHON_BIN" "$memory_harden_script" \
      --repo-root "$REPO_ROOT" \
      --app-support-dir "$APP_SUPPORT_DIR" \
      --runtime-dir "$RUNTIME_DIR" \
      install-schedule --schedule "${schedule:-0 3 * * *}" --json >/dev/null; then
      echo "Warning: failed to install memory hardening schedule." >&2
      return 1
    fi
    echo "Memory hardening schedule installed."
  elif [[ "$enabled" == "false" && -f "$plist_path" ]]; then
    if [[ ! -f "$memory_harden_script" ]]; then
      echo "Warning: memory hardening cleanup skipped; memory_harden.py was not found." >&2
      return 0
    fi
    if ! "$PYTHON_BIN" "$memory_harden_script" \
      --repo-root "$REPO_ROOT" \
      --app-support-dir "$APP_SUPPORT_DIR" \
      --runtime-dir "$RUNTIME_DIR" \
      uninstall-schedule --json >/dev/null; then
      echo "Warning: failed to uninstall disabled memory hardening schedule." >&2
      return 1
    fi
    echo "Memory hardening schedule disabled."
  elif [[ -z "$enabled" && -f "$plist_path" ]]; then
    echo "Warning: generated config does not declare memory hardening enabled/disabled; preserving the existing LaunchAgent." >&2
  elif [[ -n "$enabled" && "$enabled" != "false" ]]; then
    echo "Warning: generated memory hardening enabled value '$enabled' is invalid; preserving the existing LaunchAgent." >&2
    return 1
  fi
}

apply_default_nightly_routines() {
  local config_path="${1:-$CONFIG_FILE}"
  [[ -f "$config_path" ]] || return 0
  "$PYTHON_BIN" "$REPO_ROOT/scripts/viventium/default_nightly_routines.py" \
    --config "$config_path" \
    --write \
    --quiet
}

CONFIG_TRANSACTION_DIR=""
CONFIG_CANDIDATE_FILE=""
CONFIG_TRANSACTION_BACKUP=""
CONFIG_TRANSACTION_HAD_EXISTING="false"
CONFIG_TRANSACTION_APPLIED=0

prepare_config_candidate() {
  local config_input="$1"
  local candidate_root="$APP_SUPPORT_DIR/state/config-candidates"
  local merged_input=""
  local transaction_args=()
  CONFIG_TRANSACTION_DIR="$(
    "$PYTHON_BIN" "$REPO_ROOT/scripts/viventium/config_transaction.py" allocate \
      --candidate-root "$candidate_root" \
      --app-support-dir "$APP_SUPPORT_DIR"
  )"
  merged_input="$CONFIG_TRANSACTION_DIR/merged-input.yaml"
  CONFIG_CANDIDATE_FILE="$CONFIG_TRANSACTION_DIR/config.yaml"

  transaction_args=(
    prepare
    --input "$config_input"
    --output "$merged_input"
    --app-support-dir "$APP_SUPPORT_DIR"
  )
  if [[ -f "$CONFIG_FILE" ]]; then
    transaction_args+=(--existing "$CONFIG_FILE")
  fi
  if ! "$PYTHON_BIN" "$REPO_ROOT/scripts/viventium/config_transaction.py" "${transaction_args[@]}"; then
    echo "Unable to prepare a configuration candidate from the supplied settings." >&2
    return 1
  fi

  WIZARD_ARGS=(--output "$CONFIG_CANDIDATE_FILE")
  WIZARD_ARGS+=(--preset "$merged_input" --non-interactive)
  if ! "$PYTHON_BIN" "$REPO_ROOT/scripts/viventium/wizard.py" "${WIZARD_ARGS[@]}"; then
    if [[ ! -s "$CONFIG_CANDIDATE_FILE" ]]; then
      echo "Config candidate was not created because the supplied settings failed validation." >&2
    fi
    return 1
  fi
  if [[ ! -s "$CONFIG_CANDIDATE_FILE" ]]; then
    echo "Config candidate was not created; the existing Viventium configuration was left unchanged." >&2
    return 1
  fi
  if ! apply_default_nightly_routines "$CONFIG_CANDIDATE_FILE"; then
    return 1
  fi
  if ! "$PYTHON_BIN" "$REPO_ROOT/scripts/viventium/config_compiler.py" \
    --config "$CONFIG_CANDIDATE_FILE" \
    --output-dir "$CONFIG_TRANSACTION_DIR/runtime" \
    --dry-run >/dev/null; then
    return 1
  fi
}

apply_config_candidate() {
  local transaction_status=""
  transaction_status="$(
    "$PYTHON_BIN" "$REPO_ROOT/scripts/viventium/config_transaction.py" apply \
      --candidate "$CONFIG_CANDIDATE_FILE" \
      --config "$CONFIG_FILE" \
      --backup-dir "$APP_SUPPORT_DIR/state/config-backups" \
      --app-support-dir "$APP_SUPPORT_DIR"
  )"
  CONFIG_TRANSACTION_BACKUP="$(
    "$PYTHON_BIN" -c 'import json,sys; print(json.loads(sys.argv[1])["backup_path"])' \
      "$transaction_status"
  )"
  CONFIG_TRANSACTION_HAD_EXISTING="$(
    "$PYTHON_BIN" -c 'import json,sys; print(str(json.loads(sys.argv[1])["had_existing"]).lower())' \
      "$transaction_status"
  )"
  CONFIG_TRANSACTION_APPLIED=1
  if [[ -n "$CONFIG_TRANSACTION_BACKUP" ]]; then
    echo "Backed up the previous config to $(display_safe_path "$CONFIG_TRANSACTION_BACKUP")" >&2
  fi
}

rollback_config_candidate() {
  [[ "$CONFIG_TRANSACTION_APPLIED" == "1" ]] || return 0
  local rollback_args=(
    rollback
    --config "$CONFIG_FILE"
    --had-existing "$CONFIG_TRANSACTION_HAD_EXISTING"
    --app-support-dir "$APP_SUPPORT_DIR"
  )
  if [[ -n "$CONFIG_TRANSACTION_BACKUP" ]]; then
    rollback_args+=(--backup "$CONFIG_TRANSACTION_BACKUP")
  fi
  "$PYTHON_BIN" "$REPO_ROOT/scripts/viventium/config_transaction.py" "${rollback_args[@]}" >/dev/null
  CONFIG_TRANSACTION_APPLIED=0
  if [[ "$CONFIG_TRANSACTION_HAD_EXISTING" == "true" ]]; then
    if ! compile_config; then
      echo "Config rollback succeeded, but generated runtime refresh failed; run bin/viventium compile-config." >&2
      return 1
    fi
  fi
  echo "Restored the previous canonical config after the failed operation." >&2
}

cleanup_config_candidate() {
  if [[ -z "$CONFIG_TRANSACTION_DIR" ]]; then
    return 0
  fi
  case "$CONFIG_TRANSACTION_DIR" in
    "$APP_SUPPORT_DIR/state/config-candidates/"*)
      rm -rf -- "$CONFIG_TRANSACTION_DIR"
      ;;
    *)
      echo "Refusing to remove unexpected config candidate path: $CONFIG_TRANSACTION_DIR" >&2
      return 1
      ;;
  esac
  CONFIG_TRANSACTION_DIR=""
  CONFIG_CANDIDATE_FILE=""
}

finish_config_candidate() {
  CONFIG_TRANSACTION_APPLIED=0
  cleanup_config_candidate
}

continuity_audit_root() {
  if declare -F continuity_audit_dir >/dev/null 2>&1; then
    continuity_audit_dir "$APP_SUPPORT_DIR"
    return 0
  fi
  printf '%s\n' "$APP_SUPPORT_DIR/state/continuity"
}

continuity_audit_path() {
  local label="${1:-continuity-audit}"
  printf '%s\n' "$(continuity_audit_root)/${label}.json"
}

capture_continuity_audit() {
  local label="${1:-continuity-audit}"
  local output_path="${2:-$(continuity_audit_path "$label")}"
  if [[ "${VIVENTIUM_CONTINUITY_AUDIT_SKIP_PYTHON_REFRESH:-0}" != "1" ]]; then
    refresh_repo_python
  fi
  ensure_app_support_layout "$APP_SUPPORT_DIR"
  prepare_runtime_exports
  "$PYTHON_BIN" "$REPO_ROOT/scripts/viventium/continuity_audit.py" capture \
    --repo-root "$REPO_ROOT" \
    --app-support-dir "$APP_SUPPORT_DIR" \
    --config-file "$CONFIG_FILE" \
    --runtime-dir "$RUNTIME_DIR" \
    --label "$label" \
    --output "$output_path" >/dev/null
  printf '%s\n' "$output_path"
}

display_safe_path() {
  local candidate="${1:-}"
  if declare -F public_safe_path_label >/dev/null 2>&1; then
    public_safe_path_label "$candidate"
  else
    printf '%s\n' "$candidate"
  fi
}

continuity_audit_status() {
  local audit_path="$1"
  if [[ ! -f "$audit_path" ]]; then
    printf '%s\n' "unknown"
    return 0
  fi
  "$PYTHON_BIN" - "$audit_path" <<'PY'
import json
import sys
from pathlib import Path

payload = json.loads(Path(sys.argv[1]).read_text(encoding="utf-8"))
print(str(payload.get("status") or "unknown"))
PY
}

remove_recall_rebuild_marker() {
  local runtime_profile="${VIVENTIUM_RUNTIME_PROFILE:-isolated}"
  local marker_file=""
  if declare -F recall_rebuild_required_file >/dev/null 2>&1; then
    marker_file="$(recall_rebuild_required_file "$APP_SUPPORT_DIR" "$runtime_profile")"
  else
    marker_file="$APP_SUPPORT_DIR/state/runtime/${runtime_profile}/continuity/recall-rebuild-required.json"
  fi
  if [[ -f "$marker_file" ]]; then
    rm -f "$marker_file"
    printf '%s\n' "$marker_file"
    return 0
  fi
  return 1
}

run_macos_helper_installer() {
  local mode="${1:-install}"
  shift || true
  "$REPO_ROOT/scripts/viventium/install_macos_helper.sh" \
    "$mode" \
    --repo-root "$REPO_ROOT" \
    --app-support-dir "$APP_SUPPORT_DIR" \
    "$@"
}

install_ownership_receipt_file() {
  printf '%s\n' "$APP_SUPPORT_DIR/state/install-ownership.json"
}

write_install_ownership_receipt() {
  local helper_owned="${1:-false}"
  local receipt_file=""
  receipt_file="$(install_ownership_receipt_file)"
  mkdir -p "$(dirname "$receipt_file")"
  "$PYTHON_BIN" - "$receipt_file" "$APP_SUPPORT_DIR" "$helper_owned" <<'PY'
import json
import os
import sys
import tempfile
from pathlib import Path

receipt_path = Path(sys.argv[1])
app_support_dir = str(Path(sys.argv[2]).expanduser().resolve())
helper_owned = sys.argv[3].strip().lower() == "true"
payload = {
    "schema_version": 1,
    "app_support_dir": app_support_dir,
    "helper_owned": helper_owned,
}
fd, temporary = tempfile.mkstemp(prefix=f".{receipt_path.name}.", dir=str(receipt_path.parent))
try:
    os.fchmod(fd, 0o600)
    with os.fdopen(fd, "w", encoding="utf-8") as handle:
        json.dump(payload, handle, sort_keys=True, separators=(",", ":"))
        handle.write("\n")
        handle.flush()
        os.fsync(handle.fileno())
    os.replace(temporary, receipt_path)
    os.chmod(receipt_path, 0o600)
finally:
    if os.path.exists(temporary):
        os.unlink(temporary)
PY
}

read_install_helper_ownership() {
  local receipt_file=""
  receipt_file="$(install_ownership_receipt_file)"
  [[ -f "$receipt_file" && ! -L "$receipt_file" ]] || {
    printf '%s\n' "unknown"
    return 0
  }
  "$PYTHON_BIN" - "$receipt_file" "$APP_SUPPORT_DIR" <<'PY'
import json
import os
import stat
import sys
from pathlib import Path

path = Path(sys.argv[1])
expected_app_support = str(Path(sys.argv[2]).expanduser().resolve())
try:
    metadata = os.lstat(path)
    if not stat.S_ISREG(metadata.st_mode) or metadata.st_uid != os.getuid() or stat.S_IMODE(metadata.st_mode) & 0o077:
        raise ValueError("unsafe receipt metadata")
    payload = json.loads(path.read_text(encoding="utf-8"))
    if payload.get("schema_version") != 1:
        raise ValueError("unsupported receipt")
    if str(Path(str(payload.get("app_support_dir") or "")).expanduser().resolve()) != expected_app_support:
        raise ValueError("receipt target mismatch")
    helper_owned = payload.get("helper_owned")
    if not isinstance(helper_owned, bool):
        raise ValueError("invalid helper ownership")
except Exception:
    print("unknown")
else:
    print("owned" if helper_owned else "not-owned")
PY
}

legacy_helper_ownership_matches_install() {
  local helper_config="$APP_SUPPORT_DIR/helper-config.json"
  local helper_bundle="${VIVENTIUM_HELPER_APP_BUNDLE:-${VIVENTIUM_HELPER_APP_DIR:-$HOME/Applications}/Viventium.app}"
  local owner_marker="$helper_bundle/Contents/Resources/viventium-owner.json"
  [[ -f "$helper_config" && ! -L "$helper_config" && -f "$owner_marker" && ! -L "$owner_marker" ]] || return 1
  "$PYTHON_BIN" - "$helper_config" "$owner_marker" "$APP_SUPPORT_DIR" <<'PY'
import json
import os
import stat
import sys
from pathlib import Path

config_path, marker_path = map(Path, sys.argv[1:3])
expected_app_support = str(Path(sys.argv[3]).expanduser().resolve())
for path in (config_path, marker_path):
    metadata = os.lstat(path)
    if not stat.S_ISREG(metadata.st_mode) or metadata.st_uid != os.getuid():
        raise SystemExit(1)
try:
    config = json.loads(config_path.read_text(encoding="utf-8"))
    marker = json.loads(marker_path.read_text(encoding="utf-8"))
except Exception:
    raise SystemExit(1)
configured_app_support = str(Path(str(config.get("appSupportDir") or "")).expanduser().resolve())
if configured_app_support != expected_app_support:
    raise SystemExit(1)
if marker.get("product") != "ai.viventium.helper" or marker.get("schema_version") != 1:
    raise SystemExit(1)
PY
}

run_macos_helper_install_command() {
  local skip_login_item="${1:-0}"
  shift || true

  if [[ "$skip_login_item" == "1" ]]; then
    if [[ "$#" -gt 0 ]]; then
      VIVENTIUM_HELPER_SKIP_LOGIN_ITEM=1 run_macos_helper_installer install "$@"
    else
      VIVENTIUM_HELPER_SKIP_LOGIN_ITEM=1 run_macos_helper_installer install
    fi
    return $?
  fi

  if [[ "$#" -gt 0 ]]; then
    run_macos_helper_installer install "$@"
  else
    run_macos_helper_installer install
  fi
}

maybe_install_macos_helper() {
  if [[ "${VIVENTIUM_SKIP_HELPER_INSTALL:-0}" == "1" ]]; then
    write_install_ownership_receipt false
    return 0
  fi
  [[ "$(uname -s)" == "Darwin" ]] || return 0
  local helper_args=()
  local defer_launch=0
  local helper_install_succeeded=0

  while [[ $# -gt 0 ]]; do
    case "${1:-}" in
      --no-launch)
        defer_launch=1
        shift
        ;;
      *)
        echo "Unknown helper install option: $1" >&2
        return 1
        ;;
    esac
  done

  if [[ "$defer_launch" == "1" || "${HEADLESS:-0}" == "1" || "${AUTO_START:-1}" != "1" ]]; then
    helper_args+=(--no-launch)
  fi

  if [[ "${HEADLESS:-0}" == "1" ]]; then
    if [[ ${#helper_args[@]} -gt 0 ]]; then
      if ! run_macos_helper_install_command 1 "${helper_args[@]}"; then
        echo "Warning: Viventium installed, but the macOS status-bar helper failed to install." >&2
      else
        helper_install_succeeded=1
      fi
    elif ! run_macos_helper_install_command 1; then
      echo "Warning: Viventium installed, but the macOS status-bar helper failed to install." >&2
    else
      helper_install_succeeded=1
    fi
    [[ "$helper_install_succeeded" == "1" ]] && write_install_ownership_receipt true
    return 0
  fi

  if [[ ${#helper_args[@]} -gt 0 ]]; then
    if ! run_macos_helper_install_command 0 "${helper_args[@]}"; then
      echo "Warning: Viventium installed, but the macOS status-bar helper failed to install." >&2
    else
      helper_install_succeeded=1
    fi
  elif ! run_macos_helper_install_command 0; then
    echo "Warning: Viventium installed, but the macOS status-bar helper failed to install." >&2
  else
    helper_install_succeeded=1
  fi
  [[ "$helper_install_succeeded" == "1" ]] && write_install_ownership_receipt true
}

launch_macos_helper_app() {
  [[ "${VIVENTIUM_SKIP_HELPER_INSTALL:-0}" == "1" ]] && return 0
  [[ "$(uname -s)" == "Darwin" ]] || return 0
  [[ "${HEADLESS:-0}" == "1" ]] && return 0

  local helper_app_bundle="${VIVENTIUM_HELPER_APP_BUNDLE:-$HOME/Applications/Viventium.app}"
  [[ -d "$helper_app_bundle" ]] || return 0

  /usr/bin/open -g "$helper_app_bundle" >/dev/null 2>&1 || true
}

run_status_bar_command() {
  if [[ "$(uname -s)" != "Darwin" ]]; then
    echo "The Viventium status-bar helper is only available on macOS." >&2
    exit 1
  fi

  local action="${1:-status}"
  shift || true
  if [[ "$#" -gt 0 ]]; then
    echo "Unknown status-bar option: $1" >&2
    exit 1
  fi

  case "$action" in
    on)
      set_helper_status_bar_visibility 1
      run_macos_helper_install_command 0 --no-launch
      echo "Viventium status-bar helper is enabled."
      echo "Launch ~/Applications/Viventium.app to show it immediately."
      ;;
    off)
      set_helper_status_bar_visibility 0
      pkill -x ViventiumHelper >/dev/null 2>&1 || true
      echo "Viventium status-bar helper is hidden."
      echo "Run bin/viventium status-bar on to bring it back."
      ;;
    status)
      if helper_status_bar_enabled; then
        echo "Viventium status-bar helper: on"
      else
        echo "Viventium status-bar helper: off"
      fi
      ;;
    *)
      echo "Unknown status-bar action: $action" >&2
      subcommand_usage status-bar >&2
      exit 1
      ;;
  esac
}

expand_user_path() {
  local candidate="${1:-}"
  case "$candidate" in
    "~")
      printf '%s\n' "$HOME"
      ;;
    "~/"*)
      printf '%s/%s\n' "$HOME" "${candidate#~/}"
      ;;
    *)
      printf '%s\n' "$candidate"
      ;;
  esac
}

json_string_field() {
  local json_file="${1:-}"
  local field_name="${2:-}"
  [[ -f "$json_file" && -n "$field_name" ]] || return 1
  refresh_repo_python
  "$PYTHON_BIN" - "$json_file" "$field_name" <<'PY'
import json
import sys
from pathlib import Path

path, field_name = sys.argv[1:]
try:
    payload = json.loads(Path(path).read_text(encoding="utf-8"))
except Exception:
    raise SystemExit(1)
value = payload.get(field_name)
if value is None:
    raise SystemExit(1)
print(str(value))
PY
}

write_runtime_checkout_setting() {
  local repo_root="${1:-}"
  local allow_protected="${2:-0}"
  local state_file=""
  state_file="$(runtime_checkout_file)"
  refresh_repo_python
  "$PYTHON_BIN" - "$state_file" "$repo_root" "$allow_protected" <<'PY'
import json
import os
import sys
from datetime import datetime, timezone
from pathlib import Path

state_file, repo_root, allow_protected = sys.argv[1:]
payload = {
    "repoRoot": str(Path(repo_root).expanduser().resolve()),
    "allowProtectedFolderAccess": allow_protected == "1",
    "updatedAt": datetime.now(timezone.utc).isoformat(),
    "source": "bin/viventium runtime-checkout",
}
path = Path(state_file)
path.parent.mkdir(parents=True, exist_ok=True)
tmp_path = path.with_name(f".{path.name}.tmp")
tmp_path.write_text(json.dumps(payload, indent=2) + "\n", encoding="utf-8")
os.replace(tmp_path, path)
PY
}

runtime_checkout_refresh_helper() {
  [[ "$(uname -s)" == "Darwin" ]] || return 0
  local active_repo=""
  active_repo="$(active_runtime_checkout_repo_root "$APP_SUPPORT_DIR" 2>/dev/null || true)"
  if [[ -n "$active_repo" ]] && path_is_viventium_runtime_repo_root "$active_repo"; then
    active_repo="$(canonicalize_existing_dir "$active_repo")"
  else
    active_repo="$REPO_ROOT"
  fi

  if [[ "$active_repo" != "$(canonicalize_existing_dir "$REPO_ROOT")" ]]; then
    echo "Refreshing helper from active checkout: $(display_safe_path "$active_repo")"
    "$active_repo/bin/viventium" \
      --app-support-dir "$APP_SUPPORT_DIR" \
      --config-file "$CONFIG_FILE" \
      --runtime-dir "$RUNTIME_DIR" \
      install-helper \
      --no-launch
  else
    run_macos_helper_install_command 0 --no-launch
  fi
  launch_macos_helper_app
  echo "Viventium status-bar helper refreshed and relaunched."
}

runtime_checkout_status() {
  local active_repo=""
  local helper_repo=""
  local owner_repo=""
  local state_file=""
  local helper_config=""
  local owner_file=""
  state_file="$(runtime_checkout_file)"
  helper_config="$(helper_config_file)"
  owner_file="$(stack_owner_state_file)"

  active_repo="$(active_runtime_checkout_repo_root "$APP_SUPPORT_DIR" 2>/dev/null || true)"
  if [[ -n "$active_repo" ]]; then
    if active_runtime_checkout_allows_protected_folder_access "$APP_SUPPORT_DIR"; then
      echo "Active runtime checkout: $(display_safe_path "$active_repo") (developer protected-folder access allowed)"
    else
      echo "Active runtime checkout: $(display_safe_path "$active_repo")"
    fi
  elif [[ -f "$state_file" ]]; then
    echo "Active runtime checkout: invalid setting at $(display_safe_path "$state_file")"
  else
    echo "Active runtime checkout: automatic"
  fi

  helper_repo="$(json_string_field "$helper_config" repoRoot 2>/dev/null || true)"
  if [[ -n "$helper_repo" ]]; then
    echo "Helper checkout: $(display_safe_path "$helper_repo")"
  else
    echo "Helper checkout: not installed"
  fi

  owner_repo="$(json_string_field "$owner_file" repoRoot 2>/dev/null || true)"
  if [[ -n "$owner_repo" ]]; then
    echo "Live stack owner: $(display_safe_path "$owner_repo")"
  else
    echo "Live stack owner: none recorded"
  fi

  echo "This command checkout: $(display_safe_path "$REPO_ROOT")"
}

runtime_checkout_command() {
  local action="${1:-status}"
  shift || true

  case "$action" in
    status)
      if [[ "$#" -gt 0 ]]; then
        echo "Unknown runtime-checkout status option: $1" >&2
        exit 1
      fi
      runtime_checkout_status
      ;;
    use)
      local target=""
      local allow_protected=0
      local refresh_helper=1

      while [[ $# -gt 0 ]]; do
        case "${1:-}" in
          --this)
            target="$REPO_ROOT"
            shift
            ;;
          --allow-protected-folder)
            allow_protected=1
            shift
            ;;
          --no-helper-refresh)
            refresh_helper=0
            shift
            ;;
          --help|-h)
            subcommand_usage runtime-checkout
            exit 0
            ;;
          -*)
            echo "Unknown runtime-checkout use option: $1" >&2
            exit 1
            ;;
          *)
            if [[ -n "$target" ]]; then
              echo "Only one runtime checkout path can be selected." >&2
              exit 1
            fi
            target="$1"
            shift
            ;;
        esac
      done

      if [[ -z "$target" ]]; then
        echo "Missing runtime checkout path. Use --this or pass a checkout path." >&2
        exit 1
      fi
      target="$(expand_user_path "$target")"
      if ! path_is_viventium_runtime_repo_root "$target"; then
        echo "Not a valid Viventium runtime checkout: $target" >&2
        echo "Expected bin/viventium, scripts/viventium/common.sh, and viventium_v0_4/viventium-librechat-start.sh." >&2
        exit 1
      fi
      target="$(canonicalize_existing_dir "$target")"

      if repo_root_uses_macos_protected_folder_access "$target" && [[ "$allow_protected" != "1" ]]; then
        echo "Refusing to select a checkout inside Documents, Desktop, or Downloads without explicit acknowledgement." >&2
        echo "Rerun with --allow-protected-folder if this is an intentional developer checkout. macOS may ask the helper for folder access." >&2
        exit 1
      fi

      ensure_app_support_layout "$APP_SUPPORT_DIR"
      write_runtime_checkout_setting "$target" "$allow_protected"
      echo "Active runtime checkout set to $(display_safe_path "$target")."
      if [[ "$allow_protected" == "1" && "$(uname -s)" == "Darwin" ]]; then
        echo "Developer protected-folder access is allowed for this checkout; macOS may prompt the helper for folder access."
      fi

      if [[ "$refresh_helper" == "1" ]]; then
        runtime_checkout_refresh_helper
      else
        echo "Skipped helper refresh; run bin/viventium install-helper --no-launch when ready."
      fi

      local owner_repo=""
      owner_repo="$(json_string_field "$(stack_owner_state_file)" repoRoot 2>/dev/null || true)"
      if [[ -n "$owner_repo" && "$(canonicalize_existing_dir "$owner_repo" 2>/dev/null || true)" != "$target" ]]; then
        echo "Current live stack still belongs to $(display_safe_path "$owner_repo"). Stop and start when you want this checkout to take over."
      fi
      ;;
    clear)
      local refresh_helper=1
      while [[ $# -gt 0 ]]; do
        case "${1:-}" in
          --no-helper-refresh)
            refresh_helper=0
            shift
            ;;
          --help|-h)
            subcommand_usage runtime-checkout
            exit 0
            ;;
          *)
            echo "Unknown runtime-checkout clear option: $1" >&2
            exit 1
            ;;
        esac
      done

      rm -f "$(runtime_checkout_file)"
      echo "Active runtime checkout cleared; helper/start will use automatic checkout resolution."
      if [[ "$refresh_helper" == "1" ]]; then
        runtime_checkout_refresh_helper
      else
        echo "Skipped helper refresh; run bin/viventium install-helper --no-launch when ready."
      fi
      ;;
    --help|-h|help)
      subcommand_usage runtime-checkout
      ;;
    *)
      echo "Unknown runtime-checkout action: $action" >&2
      subcommand_usage runtime-checkout >&2
      exit 1
      ;;
  esac
}

dev_env_command() {
  if [[ "${1:-}" == "--help" || "${1:-}" == "-h" || $# -lt 1 ]]; then
    subcommand_usage dev-env
    exit 0
  fi
  ensure_app_support_layout "$APP_SUPPORT_DIR"
  exec "$PYTHON_BIN" "$REPO_ROOT/scripts/viventium/dev_runtime.py" \
    --repo-root "$REPO_ROOT" \
    --app-support-dir "$APP_SUPPORT_DIR" \
    --config-file "$CONFIG_FILE" \
    "$@"
}

dev_runtime_command() {
  local action="${1:-status}"
  shift || true
  case "$action" in
    status)
      runtime_checkout_status
      ;;
    clear)
      runtime_checkout_command clear "$@"
      ;;
    activate-current)
      local validate=0
      local restart=0
      local allow_protected=0
      local allow_dirty=0
      while [[ $# -gt 0 ]]; do
        case "${1:-}" in
          --validate)
            validate=1
            shift
            ;;
          --restart)
            restart=1
            shift
            ;;
          --allow-protected-folder)
            allow_protected=1
            shift
            ;;
          --allow-dirty-local-testing)
            allow_dirty=1
            shift
            ;;
          --help|-h)
            subcommand_usage dev-runtime
            exit 0
            ;;
          *)
            echo "Unknown dev-runtime activate-current option: $1" >&2
            exit 1
            ;;
        esac
      done
      if [[ "$allow_dirty" != "1" ]]; then
        ensure_upgradeable_git_state 0
      fi
      local runtime_checkout_args=(use --this --no-helper-refresh)
      if [[ "$allow_protected" == "1" ]]; then
        runtime_checkout_args+=(--allow-protected-folder)
      fi
      runtime_checkout_command "${runtime_checkout_args[@]}"
      if [[ "$validate" == "1" ]]; then
        if ! compile_config; then
          echo "Runtime activation validation failed during config compilation; the running stack was not restarted." >&2
          return 1
        fi
        if ! "$REPO_ROOT/scripts/viventium/doctor.sh" \
          --config "$CONFIG_FILE" \
          --runtime-dir "$RUNTIME_DIR" \
          --repo-root "$REPO_ROOT" \
          --lock-file "$LOCK_FILE" \
          --prefer-existing-checkout-head; then
          echo "Runtime activation validation failed during doctor checks; the running stack was not restarted." >&2
          return 1
        fi
        if ! runtime_checkout_refresh_helper; then
          echo "Runtime activation validation could not refresh the helper; the running stack was not restarted." >&2
          return 1
        fi
      fi
      if [[ "$restart" == "1" ]]; then
        if is_stack_running; then
          stop_stack_for_upgrade
        fi
        restart_stack_after_upgrade
      fi
      ;;
    --help|-h|help)
      subcommand_usage dev-runtime
      ;;
    *)
      echo "Unknown dev-runtime action: $action" >&2
      subcommand_usage dev-runtime >&2
      exit 1
      ;;
  esac
}

workflows_command() {
  if [[ "${1:-}" == "--help" || "${1:-}" == "-h" || $# -lt 1 ]]; then
    subcommand_usage workflows
    exit 0
  fi
  ensure_app_support_layout "$APP_SUPPORT_DIR"
  if [[ -f "$CONFIG_FILE" ]]; then
    compile_config >/dev/null
  fi
  exec "$PYTHON_BIN" "$REPO_ROOT/scripts/viventium/workflows.py" \
    --repo-root "$REPO_ROOT" \
    --app-support-dir "$APP_SUPPORT_DIR" \
    --runtime-dir "$RUNTIME_DIR" \
    "$@"
}

