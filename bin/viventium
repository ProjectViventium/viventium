transcripts_command() {
  local subject="${1:-}"
  if [[ "$subject" == "--help" || "$subject" == "-h" || "$subject" == "help" || -z "$subject" ]]; then
    subcommand_usage transcripts
    return 0
  fi
  if [[ "$subject" != "source" ]]; then
    echo "Unknown transcripts subject: $subject" >&2
    subcommand_usage transcripts >&2
    return 1
  fi
  shift || true

  local action="${1:-status}"
  if [[ "$action" == "--help" || "$action" == "-h" || "$action" == "help" ]]; then
    subcommand_usage transcripts
    return 0
  fi
  shift || true

  ensure_app_support_layout "$APP_SUPPORT_DIR"
  if [[ ! -f "$CONFIG_FILE" ]]; then
    echo "Missing config: $CONFIG_FILE" >&2
    echo "Run: bin/viventium install" >&2
    return 1
  fi
  refresh_repo_python

  local config_tool="$REPO_ROOT/scripts/viventium/config_settings.py"
  local backup_dir="$APP_SUPPORT_DIR/state/config-backups"
  case "$action" in
    status)
      "$PYTHON_BIN" "$config_tool" \
        --config-file "$CONFIG_FILE" \
        transcripts-source-status \
        "$@"
      ;;
    set)
      if [[ $# -lt 1 ]]; then
        echo "Missing transcript source folder." >&2
        subcommand_usage transcripts >&2
        return 1
      fi
      acquire_cli_lock "$COMMAND"
      local folder="$1"
      shift || true
      local output=""
      output="$("$PYTHON_BIN" "$config_tool" \
        --config-file "$CONFIG_FILE" \
        --backup-dir "$backup_dir" \
        transcripts-source-set "$folder" \
        "$@")"
      compile_config >/dev/null
      sync_memory_hardening_schedule >/dev/null 2>&1 || true
      printf '%s\n' "$output"
      ;;
    clear)
      acquire_cli_lock "$COMMAND"
      local output=""
      output="$("$PYTHON_BIN" "$config_tool" \
        --config-file "$CONFIG_FILE" \
        --backup-dir "$backup_dir" \
        transcripts-source-clear \
        "$@")"
      compile_config >/dev/null
      sync_memory_hardening_schedule >/dev/null 2>&1 || true
      printf '%s\n' "$output"
      ;;
    *)
      echo "Unknown transcripts source action: $action" >&2
      subcommand_usage transcripts >&2
      return 1
      ;;
  esac
}

maybe_reexec_active_runtime_checkout() {
  [[ "${VIVENTIUM_DISABLE_ACTIVE_CHECKOUT_REEXEC:-0}" == "1" ]] && return 0
  local command_name="${1:-}"
  shift || true

  case "$command_name" in
    start|launch|stop|install-helper|uninstall-helper|status-bar|memory-harden|memory-dedupe|transcripts|workflows|heal|feature-request|report-bug|bug-report|prompt-workbench)
      ;;
    *)
      return 0
      ;;
  esac

  local active_repo=""
  active_repo="$(active_runtime_checkout_repo_root "$APP_SUPPORT_DIR" 2>/dev/null || true)"
  [[ -n "$active_repo" ]] || return 0
  path_is_viventium_runtime_repo_root "$active_repo" || return 0
  active_repo="$(canonicalize_existing_dir "$active_repo")"

  if [[ "$active_repo" == "$(canonicalize_existing_dir "$REPO_ROOT")" ]]; then
    return 0
  fi

  local active_lock_file="$active_repo/components.lock.json"
  echo "Using active runtime checkout: $(display_safe_path "$active_repo")" >&2
  VIVENTIUM_COMPONENTS_LOCK_FILE="$active_lock_file" exec "$active_repo/bin/viventium" \
    --app-support-dir "$APP_SUPPORT_DIR" \
    --config-file "$CONFIG_FILE" \
    --runtime-dir "$RUNTIME_DIR" \
    --lock-file "$active_lock_file" \
    "$command_name" \
    "$@"
}

yaml_file_has_unique_mapping_keys() {
  local yaml_file="$1"
  local timeout_seconds="${VIVENTIUM_PRIVATE_YAML_VALIDATE_TIMEOUT_SECONDS:-3}"
  [[ -f "$yaml_file" ]] || return 1
  "$PYTHON_BIN" - "$yaml_file" "$timeout_seconds" <<'PY'
import math
import signal
import sys
import yaml
from yaml.constructor import ConstructorError
from yaml.resolver import BaseResolver


class UniqueKeyLoader(yaml.SafeLoader):
    pass


def construct_mapping(loader, node, deep=False):
    mapping = {}
    for key_node, value_node in node.value:
        key = loader.construct_object(key_node, deep=deep)
        if key in mapping:
            raise ConstructorError(
                "while constructing a mapping",
                node.start_mark,
                f"found duplicate key ({key})",
                key_node.start_mark,
            )
        mapping[key] = loader.construct_object(value_node, deep=deep)
    return mapping


UniqueKeyLoader.add_constructor(BaseResolver.DEFAULT_MAPPING_TAG, construct_mapping)

def timeout_handler(signum, frame):
    raise TimeoutError("timed out while reading YAML")


timeout_seconds = max(1, int(math.ceil(float(sys.argv[2]))))
signal.signal(signal.SIGALRM, timeout_handler)
signal.alarm(timeout_seconds)
try:
    with open(sys.argv[1], "r", encoding="utf-8") as handle:
        yaml.load(handle, Loader=UniqueKeyLoader)
finally:
    signal.alarm(0)
PY
}

prepare_runtime_exports() {
  local runtime_profile="${VIVENTIUM_RUNTIME_PROFILE:-isolated}"
  export VIVENTIUM_ENV_FILE="$GENERATED_ENV"
  export VIVENTIUM_ENV_LOCAL_FILE="$GENERATED_LOCAL_ENV"
  export VIVENTIUM_CANONICAL_ENV_LOCK_EXISTING_KEYS="1"
  export VIVENTIUM_BASE_STATE_DIR="$APP_SUPPORT_DIR/state"
  export VIVENTIUM_STATE_ROOT="${VIVENTIUM_STATE_ROOT:-$APP_SUPPORT_DIR/state/runtime/${runtime_profile}}"
  export VIVENTIUM_PUBLIC_NETWORK_STATE_FILE="${VIVENTIUM_PUBLIC_NETWORK_STATE_FILE:-$VIVENTIUM_STATE_ROOT/public-network.json}"
  export VIVENTIUM_CALL_TUNNEL_LOG_DIR="${VIVENTIUM_CALL_TUNNEL_LOG_DIR:-$VIVENTIUM_STATE_ROOT/logs}"
  export VIVENTIUM_REMOTE_CALL_TUNNEL_SCRIPT="${VIVENTIUM_REMOTE_CALL_TUNNEL_SCRIPT:-$REPO_ROOT/scripts/viventium/remote_call_tunnel.py}"
  export VIVENTIUM_PRIVATE_REPO_DIR="${VIVENTIUM_PRIVATE_REPO_DIR:-$PRIVATE_REPO_DIR_DEFAULT}"
  export VIVENTIUM_PRIVATE_CURATED_DIR="${VIVENTIUM_PRIVATE_CURATED_DIR:-$PRIVATE_CURATED_DIR_DEFAULT}"
  if declare -F recall_rebuild_required_file >/dev/null 2>&1; then
    export VIVENTIUM_RECALL_REBUILD_REQUIRED_FILE="${VIVENTIUM_RECALL_REBUILD_REQUIRED_FILE:-$(recall_rebuild_required_file "$APP_SUPPORT_DIR" "$runtime_profile")}"
  else
    export VIVENTIUM_RECALL_REBUILD_REQUIRED_FILE="${VIVENTIUM_RECALL_REBUILD_REQUIRED_FILE:-$APP_SUPPORT_DIR/state/runtime/${runtime_profile}/continuity/recall-rebuild-required.json}"
  fi

  local source_phase="${VIVENTIUM_LIBRECHAT_SOURCE_PHASE:-runtime}"
  local private_root_env_local=""
  local private_librechat_env=""
  local private_source_of_truth=""
  local private_agents_bundle=""
  local private_telegram_env=""
  local generated_telegram_env="$RUNTIME_DIR/service-env/telegram.config.env"
  local generated_telegram_codex_env="$RUNTIME_DIR/service-env/telegram-codex.env"
  local generated_telegram_codex_settings="$RUNTIME_DIR/telegram-codex/settings.yaml"
  local generated_telegram_codex_projects="$RUNTIME_DIR/telegram-codex/projects.yaml"
  local private_source_valid=0

  if [[ -n "$VIVENTIUM_PRIVATE_CURATED_DIR" ]]; then
    private_root_env_local="$VIVENTIUM_PRIVATE_CURATED_DIR/configs/root.env.local"
    private_librechat_env="$VIVENTIUM_PRIVATE_CURATED_DIR/configs/librechat/librechat.env"
    private_source_of_truth="$VIVENTIUM_PRIVATE_CURATED_DIR/configs/librechat/source_of_truth/local.librechat.yaml"
    private_agents_bundle="$VIVENTIUM_PRIVATE_CURATED_DIR/configs/librechat/source_of_truth/local.viventium-agents.yaml"
    private_telegram_env="$VIVENTIUM_PRIVATE_CURATED_DIR/configs/telegram/config.env"
  fi

  if [[ -f "$private_root_env_local" ]]; then
    export VIVENTIUM_ENV_LOCAL_FILE="$private_root_env_local"
  fi
  if [[ -f "$private_librechat_env" ]]; then
    export VIVENTIUM_LIBRECHAT_CANONICAL_ENV_FILE="$private_librechat_env"
  fi
  if [[ -f "$private_source_of_truth" ]]; then
    if yaml_file_has_unique_mapping_keys "$private_source_of_truth"; then
      export VIVENTIUM_LIBRECHAT_PRIVATE_SOURCE_OF_TRUTH="$private_source_of_truth"
      private_source_valid=1
    else
      echo "Warning: ignoring unreadable or invalid private LibreChat source-of-truth YAML at $private_source_of_truth" >&2
      unset VIVENTIUM_LIBRECHAT_PRIVATE_SOURCE_OF_TRUTH
    fi
  else
    unset VIVENTIUM_LIBRECHAT_PRIVATE_SOURCE_OF_TRUTH
  fi
  if [[ "$source_phase" == "compile" && "$private_source_valid" == "1" ]]; then
    export VIVENTIUM_LIBRECHAT_SOURCE_OF_TRUTH="$private_source_of_truth"
  elif [[ "$source_phase" == "compile" ]]; then
    unset VIVENTIUM_LIBRECHAT_SOURCE_OF_TRUTH
  elif [[ -f "$GENERATED_LIBRECHAT_YAML" ]]; then
    export VIVENTIUM_LIBRECHAT_SOURCE_OF_TRUTH="$GENERATED_LIBRECHAT_YAML"
  elif [[ "$private_source_valid" == "1" ]]; then
    export VIVENTIUM_LIBRECHAT_SOURCE_OF_TRUTH="$private_source_of_truth"
  else
    unset VIVENTIUM_LIBRECHAT_SOURCE_OF_TRUTH
  fi
  if [[ -f "$private_agents_bundle" ]]; then
    if yaml_file_has_unique_mapping_keys "$private_agents_bundle"; then
      export LIBRECHAT_AGENTS_BUNDLE_FILE="$private_agents_bundle"
    else
      echo "Warning: ignoring unreadable or invalid private Viventium agents bundle at $private_agents_bundle" >&2
      unset LIBRECHAT_AGENTS_BUNDLE_FILE
    fi
  fi
  if [[ -f "$generated_telegram_env" ]]; then
    export VIVENTIUM_TELEGRAM_ENV_FILE="$generated_telegram_env"
  elif [[ -f "$private_telegram_env" ]]; then
    export VIVENTIUM_TELEGRAM_ENV_FILE="$private_telegram_env"
  fi
  if [[ -f "$generated_telegram_codex_env" ]]; then
    export VIVENTIUM_TELEGRAM_CODEX_ENV_FILE="$generated_telegram_codex_env"
  fi
  if [[ -f "$generated_telegram_codex_settings" ]]; then
    export VIVENTIUM_TELEGRAM_CODEX_SETTINGS_FILE="$generated_telegram_codex_settings"
  fi
  if [[ -f "$generated_telegram_codex_projects" ]]; then
    export VIVENTIUM_TELEGRAM_CODEX_PROJECTS_FILE="$generated_telegram_codex_projects"
  fi
}

install_progress_dir() {
  printf '%s\n' "$APP_SUPPORT_DIR/state/install"
}

write_install_stage() {
  local stage="$1"
  local progress_dir
  progress_dir="$(install_progress_dir)"
  mkdir -p "$progress_dir"
  printf '%s\n' "$stage" >"$progress_dir/stage.txt"
}

read_install_stage() {
  local progress_dir
  progress_dir="$(install_progress_dir)"
  if [[ -f "$progress_dir/stage.txt" ]]; then
    tr -d '\r\n' <"$progress_dir/stage.txt"
  fi
}

clear_install_stage() {
  local progress_dir
  progress_dir="$(install_progress_dir)"
  rm -f "$progress_dir/stage.txt" >/dev/null 2>&1 || true
  rmdir "$progress_dir" >/dev/null 2>&1 || true
}

backup_existing_install_config() {
  if [[ ! -f "$CONFIG_FILE" ]]; then
    return 0
  fi
  local progress_dir backup_dir timestamp backup_path
  progress_dir="$(install_progress_dir)"
  backup_dir="$progress_dir/backups"
  mkdir -p "$backup_dir"
  timestamp="$(date -u +%Y%m%dT%H%M%SZ)"
  backup_path="$backup_dir/config-$timestamp.yaml"
  cp "$CONFIG_FILE" "$backup_path"
  printf '%s\n' "$backup_path"
}

prompt_install_recovery_action() {
  local prior_stage="${1:-}"
  if [[ -z "$prior_stage" ]]; then
    printf 'resume\n'
    return 0
  fi

  echo "A previous install stopped during: $prior_stage" >&2
  if [[ ! -t 0 ]]; then
    printf 'resume\n'
    return 0
  fi

  local response=""
  printf 'Choose recovery action [resume/reconfigure/start-over] (default: resume): ' >&2
  IFS= read -r response || true
  response="$(printf '%s' "${response:-resume}" | tr '[:upper:]' '[:lower:]')"
  case "$response" in
    ""|resume|r)
      printf 'resume\n'
      ;;
    reconfigure|config|c)
      printf 'reconfigure\n'
      ;;
    start-over|startover|reset|s)
      printf 'start-over\n'
      ;;
    *)
      echo "Unknown recovery choice '$response'; resuming with the current config." >&2
      printf 'resume\n'
      ;;
  esac
}

print_install_recovery_guidance() {
  local failed_stage="${1:-unknown}"
  echo
  echo "Install stopped during stage: $failed_stage" >&2
  echo "Resume after fixing the blocker: bin/viventium install" >&2
  echo "Change installer choices first:  bin/viventium configure" >&2
}

print_install_summary() {
  local stack_started="${1:-0}"
  local args=(--config "$CONFIG_FILE" --runtime-dir "$RUNTIME_DIR" --repo-root "$REPO_ROOT")
  if [[ "$stack_started" == "1" ]]; then
    args+=(--probe-live)
  fi
  "$PYTHON_BIN" "$REPO_ROOT/scripts/viventium/install_summary.py" "${args[@]}"
}

needs_connected_accounts_guidance() {
  refresh_repo_python
  "$PYTHON_BIN" - "$CONFIG_FILE" "$RUNTIME_DIR" <<'PY'
from __future__ import annotations

import sys
from pathlib import Path

import yaml


def configured(node):
    return isinstance(node, dict) and bool(
        str(node.get("secret_ref") or "").strip() or str(node.get("secret_value") or "").strip()
    )


def parse_env_file(path):
    values = {}
    if not path.is_file():
        return values
    for raw_line in path.read_text(encoding="utf-8").splitlines():
        line = raw_line.strip()
        if not line or line.startswith("#") or "=" not in line:
            continue
        key, value = line.split("=", 1)
        value = value.strip()
        if (value.startswith("'") and value.endswith("'")) or (
            value.startswith('"') and value.endswith('"')
        ):
            value = value[1:-1]
        values[key.strip()] = value
    return values


def runtime_connected(config, runtime_env, provider):
    provider = str(provider or "").strip().lower()
    if provider not in {"openai", "anthropic"}:
        return False
    llm = config.get("llm", {}) or {}
    configured_connected = any(
        str(node.get("provider") or "").strip().lower() == provider
        and str(node.get("auth_mode") or "").strip().lower() == "connected_account"
        for node in (llm.get("primary", {}) or {}, llm.get("secondary", {}) or {})
    )
    if not configured_connected:
        return False
    env_key = {
        "openai": "VIVENTIUM_OPENAI_AUTH_MODE",
        "anthropic": "VIVENTIUM_ANTHROPIC_AUTH_MODE",
    }[provider]
    return (
        str(runtime_env.get("VIVENTIUM_LOCAL_SUBSCRIPTION_AUTH") or "").strip().lower()
        in {"1", "true", "yes", "on"}
        and str(runtime_env.get(env_key) or "").strip().lower() == "connected_account"
    )


config_path = Path(sys.argv[1])
runtime_dir = Path(sys.argv[2])
config = yaml.safe_load(config_path.read_text(encoding="utf-8")) or {}
runtime_env = {}
runtime_env.update(parse_env_file(runtime_dir / "runtime.env"))
runtime_env.update(parse_env_file(runtime_dir / "runtime.local.env"))
llm = config.get("llm", {}) or {}
primary = llm.get("primary", {}) or {}
secondary = llm.get("secondary", {}) or {}
extra_provider_keys = llm.get("extra_provider_keys", {}) or {}

foundation_present = any(
    provider in {"openai", "anthropic"} and auth_mode == "api_key" and configured(node)
    for provider, auth_mode, node in (
        (
            str(primary.get("provider") or "").strip().lower(),
            str(primary.get("auth_mode") or "").strip().lower(),
            primary,
        ),
        (
            str(secondary.get("provider") or "").strip().lower(),
            str(secondary.get("auth_mode") or "").strip().lower(),
            secondary,
        ),
    )
) or any(
    provider_name in {"openai", "anthropic"} and configured(node)
    for provider_name, node in extra_provider_keys.items()
 ) or any(
    runtime_connected(config, runtime_env, provider) for provider in ("openai", "anthropic")
)

integrations = config.get("integrations", {}) or {}
google_workspace_enabled = bool((integrations.get("google_workspace") or {}).get("enabled"))
ms365_enabled = bool((integrations.get("ms365") or {}).get("enabled"))

needs_guidance = (not foundation_present) or google_workspace_enabled or ms365_enabled
print("1" if needs_guidance else "0")
PY
}

print_connected_accounts_browser_reminder() {
  [[ "${HEADLESS:-0}" == "1" ]] && return 0
  if [[ "$(needs_connected_accounts_guidance)" != "1" ]]; then
    return 0
  fi

  echo
  echo "Important: after you create your account in the browser, click your account in the left sidebar,"
  echo "open Settings -> Connected Accounts, add an OpenAI or Anthropic API key so the shipped Viventium agents can run,"
  echo "and connect Google Workspace and/or Microsoft 365 there as well if you want those tasks on this user account."
}

open_default_browser() {
  [[ "${HEADLESS:-0}" == "1" ]] && return 0

  local _api_port _frontend_port _playground_port
  assign_runtime_ports _api_port _frontend_port _playground_port
  local url="http://localhost:${_frontend_port}"

  if [[ "$(uname -s)" == "Darwin" ]] && command -v open >/dev/null 2>&1; then
    open "$url" >/dev/null 2>&1 || true
  elif command -v xdg-open >/dev/null 2>&1; then
    xdg-open "$url" >/dev/null 2>&1 || true
  fi
}

PASSWORD_RESET_LINK_SCRIPT=""

prepare_password_reset_link_runtime() {
  local reset_librechat_dir="${VIVENTIUM_LIBRECHAT_DIR:-$REPO_ROOT/viventium_v0_4/LibreChat}"

  if ! reset_librechat_dir="$(cd "$reset_librechat_dir" 2>/dev/null && pwd -P)"; then
    echo "Password-reset link failed because the selected LibreChat checkout is missing: $reset_librechat_dir" >&2
    return 1
  fi
  PASSWORD_RESET_LINK_SCRIPT="$reset_librechat_dir/config/issue-password-reset-link.js"
  if [[ ! -f "$PASSWORD_RESET_LINK_SCRIPT" ]]; then
    echo "Password-reset link helper is missing from the selected LibreChat checkout: $PASSWORD_RESET_LINK_SCRIPT" >&2
    return 1
  fi

  if [[ -z "${DOMAIN_CLIENT:-}" ]]; then
    if [[ -n "${CLIENT_URL:-}" ]]; then
      export DOMAIN_CLIENT="$CLIENT_URL"
    elif [[ -n "${VIVENTIUM_PUBLIC_CLIENT_URL:-}" ]]; then
      export DOMAIN_CLIENT="$VIVENTIUM_PUBLIC_CLIENT_URL"
    else
      export DOMAIN_CLIENT="http://127.0.0.1:${VIVENTIUM_LC_FRONTEND_PORT:-3190}"
    fi
  fi
}

removal_backup_root() {
  printf '%s\n' "${VIVENTIUM_REMOVAL_BACKUP_ROOT:-$HOME/Library/Application Support/Viventium Removed}"
}

backup_install_state_for_removal() {
  local reason="${1:-reset}"
  local backup_root backup_dir timestamp
  backup_root="$(removal_backup_root)"
  case "$backup_root" in
    "$APP_SUPPORT_DIR"|"$APP_SUPPORT_DIR"/*)
      echo "Refusing removal backup root inside the active Viventium App Support directory: $backup_root" >&2
      return 1
      ;;
  esac
  timestamp="$(date -u +%Y%m%dT%H%M%SZ)"
  backup_dir="$backup_root/${timestamp}-${reason}"
  mkdir -p "$backup_root"
  chmod 700 "$backup_root" >/dev/null 2>&1 || true
  if [[ -e "$backup_dir" ]]; then
    echo "Refusing to overwrite an existing Viventium removal backup: $backup_dir" >&2
    return 1
  fi

  if [[ -e "$APP_SUPPORT_DIR" ]]; then
    # Services are drained before this function is called. Moving the entire
    # tree on the same local filesystem preserves databases, state, snapshots,
    # generated config, logs, and helper metadata without a torn live copy.
    mv -- "$APP_SUPPORT_DIR" "$backup_dir"
    chmod 700 "$backup_dir" >/dev/null 2>&1 || true
  elif [[ -f "$CONFIG_FILE" ]]; then
    mkdir -p "$backup_dir"
    chmod 700 "$backup_dir" >/dev/null 2>&1 || true
    cp "$CONFIG_FILE" "$backup_dir/config.yaml"
  else
    return 1
  fi

  printf '%s\n' "$backup_dir"
}

confirm_destructive_action() {
  local action_label="$1"
  local yes_flag="${2:-0}"
  local confirm_token="$3"

  if [[ "$yes_flag" == "1" ]]; then
    return 0
  fi

  if [[ ! -t 0 ]]; then
    echo "${action_label} requires --yes in non-interactive mode." >&2
    exit 1
  fi

  echo "${action_label} will only affect this Viventium install under:" >&2
  echo "  $APP_SUPPORT_DIR" >&2
  echo "It will not delete this git checkout." >&2
  printf 'Type %s to continue: ' "$confirm_token" >&2
  local response=""
  IFS= read -r response || true
  if [[ "$response" != "$confirm_token" ]]; then
    echo "${action_label} cancelled." >&2
    exit 1
  fi
}

drain_native_stack_before_state_removal() {
  # Destructive flows cannot rely on helper-detached cleanup alone because the
  # helper can return before native services have drained and before App Support
  # state is still present for command-line matching.
  prepare_runtime_exports
  if [[ -f "$GENERATED_ENV" ]]; then
    set +u
    # shellcheck disable=SC1090
    source "$GENERATED_ENV"
    if [[ -f "$GENERATED_LOCAL_ENV" ]]; then
      # shellcheck disable=SC1090
      source "$GENERATED_LOCAL_ENV"
    fi
    set -u
  fi
  "$REPO_ROOT/scripts/viventium/native_stack.sh" stop >/dev/null 2>&1 || true
}

reset_local_install_state() {
  local backup_dir=""

  if is_stack_running; then
    echo "Stopping the current Viventium stack before reset..."
    stop_stack_for_upgrade
  fi
  drain_native_stack_before_state_removal
  if [[ -e "$APP_SUPPORT_DIR" || -f "$CONFIG_FILE" ]]; then
    backup_dir="$(backup_install_state_for_removal "reset")"
  fi

  rm -rf "$APP_SUPPORT_DIR"
  if [[ -n "$backup_dir" ]]; then
    echo "Backed up the previous local install state to $backup_dir"
  fi
  echo "Factory reset complete. Next: bin/viventium install"
}

uninstall_local_installation() {
  local backup_dir=""
  local helper_ownership="unknown"

  if is_stack_running; then
    echo "Stopping the current Viventium stack before uninstall..."
    stop_stack_for_upgrade
  fi
  drain_native_stack_before_state_removal
  helper_ownership="$(read_install_helper_ownership)"
  if [[ "$helper_ownership" == "unknown" ]] && legacy_helper_ownership_matches_install; then
    helper_ownership="legacy-owned"
  fi
  if [[ -e "$APP_SUPPORT_DIR" || -f "$CONFIG_FILE" ]]; then
    backup_dir="$(backup_install_state_for_removal "uninstall")"
  fi

  case "$helper_ownership" in
    owned|legacy-owned)
      if [[ "$helper_ownership" == "legacy-owned" ]]; then
        echo "Verified legacy helper ownership for this install target."
      fi
      run_macos_helper_installer uninstall || true
      ;;
    not-owned)
      echo "Skipped macOS helper removal because this install's owner receipt records no helper ownership."
      ;;
    *)
      echo "Skipped macOS helper removal because helper ownership for this install target could not be proven."
      ;;
  esac
  rm -rf "$APP_SUPPORT_DIR"
  if [[ -n "$backup_dir" ]]; then
    echo "Backed up the previous local install state to $backup_dir"
  fi
  echo "Viventium has been removed from this Mac. The repo checkout was left in place."
}

read_runtime_ports() {
  local api_port="3180"
  local frontend_port="3190"
  local playground_port="3300"
  local sandpack_port="3191"

  if [[ -f "$GENERATED_ENV" ]]; then
    local loaded_ports
    loaded_ports="$(
      set +u
      # shellcheck disable=SC1090
      source "$GENERATED_ENV"
      if [[ -f "$GENERATED_LOCAL_ENV" ]]; then
        # shellcheck disable=SC1090
        source "$GENERATED_LOCAL_ENV"
      fi
      printf '%s %s %s %s\n' \
        "${VIVENTIUM_LC_API_PORT:-3180}" \
        "${VIVENTIUM_LC_FRONTEND_PORT:-3190}" \
        "${VIVENTIUM_PLAYGROUND_PORT:-3300}" \
        "${SANDPACK_BUNDLER_LISTEN_PORT:-3191}"
    )"
    read -r api_port frontend_port playground_port sandpack_port <<<"$loaded_ports"
  fi

  printf '%s %s %s %s\n' "$api_port" "$frontend_port" "$playground_port" "$sandpack_port"
}

assign_runtime_ports() {
  local api_var="${1:-}"
  local frontend_var="${2:-}"
  local playground_var="${3:-}"
  local sandpack_var="${4:-}"
  local loaded_ports=""
  local resolved_api_port="3180"
  local resolved_frontend_port="3190"
  local resolved_playground_port="3300"
  local resolved_sandpack_port="3191"

  loaded_ports="$(read_runtime_ports 2>/dev/null || printf '3180 3190 3300 3191\n')"
  # shellcheck disable=SC2086
  set -- $loaded_ports
  resolved_api_port="${1:-3180}"
  resolved_frontend_port="${2:-3190}"
  resolved_playground_port="${3:-3300}"
  resolved_sandpack_port="${4:-3191}"

  if [[ -n "$api_var" ]]; then
    printf -v "$api_var" '%s' "$resolved_api_port"
  fi
  if [[ -n "$frontend_var" ]]; then
    printf -v "$frontend_var" '%s' "$resolved_frontend_port"
  fi
  if [[ -n "$playground_var" ]]; then
    printf -v "$playground_var" '%s' "$resolved_playground_port"
  fi
  if [[ -n "$sandpack_var" ]]; then
    printf -v "$sandpack_var" '%s' "$resolved_sandpack_port"
  fi
}

read_generated_env_value() {
  local key="${1:-}"
  local default_value="${2:-}"
  [[ -n "$key" ]] || {
    printf '%s\n' "$default_value"
    return 0
  }

  if [[ ! -f "$GENERATED_ENV" && ! -f "$GENERATED_LOCAL_ENV" ]]; then
    printf '%s\n' "$default_value"
    return 0
  fi

  local value=""
  value="$(
    set +u
    if [[ -f "$GENERATED_ENV" ]]; then
      # shellcheck disable=SC1090
      source "$GENERATED_ENV"
    fi
    if [[ -f "$GENERATED_LOCAL_ENV" ]]; then
      # shellcheck disable=SC1090
      source "$GENERATED_LOCAL_ENV"
    fi
    printf '%s\n' "${!key:-}"
  )"

  if [[ -n "$value" ]]; then
    printf '%s\n' "$value"
  else
    printf '%s\n' "$default_value"
  fi
}

runtime_env_true() {
  local key="${1:-}"
  local default_value="${2:-false}"
  local value=""
  value="$(read_generated_env_value "$key" "$default_value")"
  value="$(printf '%s' "$value" | tr '[:upper:]' '[:lower:]')"
  [[ "$value" == "1" || "$value" == "true" || "$value" == "yes" || "$value" == "on" ]]
}

express_install_experience() {
  local value=""
  value="$(read_generated_env_value "VIVENTIUM_INSTALL_EXPERIENCE" "legacy")"
  value="$(printf '%s' "$value" | tr '[:upper:]' '[:lower:]')"
  [[ "$value" == "express" ]]
}

ensure_configured_prerequisites() {
  if ! express_install_experience; then
    return 0
  fi
  echo "Checking Easy Install prerequisites..."
  run_preflight apply
}

runtime_port_listening() {
  local port="${1:-}"
  [[ -n "$port" ]] || return 1
  viventium_port_listener_active "$port"
}

http_url_healthy() {
  local url="${1:-}"
  local timeout_seconds="${2:-2}"
  [[ -n "$url" ]] || return 1

  local code=""
  if command -v curl >/dev/null 2>&1; then
    code="$(curl -sS -L -o /dev/null --max-time "$timeout_seconds" -w '%{http_code}' "$url" 2>/dev/null || true)"
  else
    code="$(
      "$PYTHON_BIN" - "$url" "$timeout_seconds" <<'PY'
import sys
import urllib.error
import urllib.request

url = sys.argv[1]
timeout_seconds = float(sys.argv[2])
request = urllib.request.Request(url, method="GET")
try:
    with urllib.request.urlopen(request, timeout=timeout_seconds) as response:
        print(getattr(response, "status", 200))
except urllib.error.HTTPError as error:
    print(error.code)
except Exception:
    print("000")
PY
    )"
  fi

  [[ "$code" =~ ^(2|3)[0-9][0-9]$ ]]
}

http_json_status_up() {
  local url="${1:-}"
  local timeout_seconds="${2:-2}"
  [[ -n "$url" ]] || return 1

  "$PYTHON_BIN" - "$url" "$timeout_seconds" <<'PY'
import json
import sys
import urllib.request

url = sys.argv[1]
timeout_seconds = float(sys.argv[2])
request = urllib.request.Request(url, method="GET")
try:
    with urllib.request.urlopen(request, timeout=timeout_seconds) as response:
        if getattr(response, "status", 200) != 200:
            raise SystemExit(1)
        payload = json.load(response)
except Exception:
    raise SystemExit(1)

raise SystemExit(0 if isinstance(payload, dict) and payload.get("status") == "UP" else 1)
PY
}

http_url_reachable() {
  local url="${1:-}"
  local timeout_seconds="${2:-2}"
  [[ -n "$url" ]] || return 1

  local code=""
  if command -v curl >/dev/null 2>&1; then
    code="$(curl -sS -L -o /dev/null --max-time "$timeout_seconds" -w '%{http_code}' "$url" 2>/dev/null || true)"
  else
    code="$(
      "$PYTHON_BIN" - "$url" "$timeout_seconds" <<'PY'
import sys
import urllib.error
import urllib.request

url = sys.argv[1]
timeout_seconds = float(sys.argv[2])
request = urllib.request.Request(url, method="GET")
try:
    with urllib.request.urlopen(request, timeout=timeout_seconds) as response:
        print(getattr(response, "status", 200))
except urllib.error.HTTPError as error:
    print(error.code)
except Exception:
    print("000")
PY
    )"
  fi

  [[ "$code" =~ ^[1-4][0-9][0-9]$ ]]
}

local_http_surface_healthy() {
  local port="${1:-}"
  local path_suffix="${2:-/}"
  [[ -n "$port" ]] || return 1
  [[ -n "$path_suffix" ]] || path_suffix="/"

  http_url_healthy "http://localhost:${port}${path_suffix}" ||
    http_url_healthy "http://127.0.0.1:${port}${path_suffix}"
}

api_surface_healthy() {
  local port="${1:-}"
  local_http_surface_healthy "$port" "/api/health"
}

frontend_surface_healthy() {
  local port="${1:-}"
  local_http_surface_healthy "$port" "/"
}

playground_surface_healthy() {
  local port="${1:-}"
  [[ -n "$port" ]] || return 1

  local variant=""
  variant="$(read_generated_env_value "PLAYGROUND_VARIANT" "modern" | tr '[:upper:]' '[:lower:]')"
  if [[ "$variant" != "classic" ]]; then
    variant="modern"
  fi

  local app_dir="$REPO_ROOT/viventium_v0_4/agent-starter-react"
  if [[ "$variant" == "classic" ]]; then
    app_dir="$REPO_ROOT/viventium_v0_4/agents-playground"
  fi

  local source_ref=""
  if [[ -f "$app_dir/.viventium-source-ref" ]]; then
    source_ref="$(tr -d '[:space:]' < "$app_dir/.viventium-source-ref")"
  elif git -C "$app_dir" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    source_ref="$(git -C "$app_dir" rev-parse HEAD 2>/dev/null || true)"
  fi
  [[ "$source_ref" =~ ^[0-9a-f]{40}$ ]] || return 1

  "$PYTHON_BIN" "$REPO_ROOT/scripts/viventium/verify_playground_identity.py" \
    --base-url "http://127.0.0.1:${port}" \
    --variant "$variant" \
    --source-ref "$source_ref" \
    --timeout 2 \
    >/dev/null 2>&1
}

sandpack_surface_healthy() {
  local port="${1:-}"
  [[ -n "$port" ]] || return 1
  "$PYTHON_BIN" - "$port" <<'PY'
import sys
import urllib.request

port = int(sys.argv[1])
for host in ("127.0.0.1", "localhost"):
    try:
        request = urllib.request.Request(f"http://{host}:{port}/index.html", method="GET")
        with urllib.request.urlopen(request, timeout=2) as response:
            body = response.read(1024 * 1024)
            if getattr(response, "status", 200) == 200 and b'IS_ONPREM:"true"' in body:
                raise SystemExit(0)
    except Exception:
        continue
raise SystemExit(1)
PY
}

sandpack_runtime_required() {
  [[ -n "$(read_generated_env_value "SANDPACK_BUNDLER_URL" "")" || \
     -n "$(read_generated_env_value "SANDPACK_BUNDLER_LISTEN_PORT" "")" ]]
}

rag_api_surface_healthy() {
  local base_url=""
  base_url="$(read_generated_env_value "RAG_API_URL" "")"
  if [[ -z "$base_url" ]]; then
    local rag_port=""
    rag_port="$(read_generated_env_value "VIVENTIUM_RAG_API_PORT" "")"
    if [[ -n "$rag_port" ]]; then
      base_url="http://localhost:${rag_port}"
    fi
  fi
  base_url="${base_url%/}"
  [[ -n "$base_url" ]] || return 1

  http_json_status_up "${base_url}/health"
}

searxng_surface_healthy() {
  local base_url=""
  base_url="$(read_generated_env_value "SEARXNG_INSTANCE_URL" "http://localhost:8082")"
  base_url="${base_url%/}"
  # Cold SearXNG search requests can take a few seconds while engines wake up.
  # The root page responds much earlier and is enough to prove the local service
  # is accepting traffic for installer/startup readiness purposes.
  http_url_healthy "${base_url}/" 5
}

firecrawl_surface_healthy() {
  local base_url=""
  base_url="$(read_generated_env_value "FIRECRAWL_BASE_URL" "")"
  if [[ -z "$base_url" ]]; then
    base_url="$(read_generated_env_value "FIRECRAWL_API_URL" "http://localhost:3003")"
  fi
  base_url="${base_url%/}"

  if http_url_healthy "${base_url}/health"; then
    return 0
  fi

  if command -v curl >/dev/null 2>&1; then
    if curl -s --max-time 3 "${base_url}/" 2>/dev/null | grep -q "Firecrawl API"; then
      return 0
    fi
  fi

  if command -v docker >/dev/null 2>&1; then
    if docker ps -q --filter "name=^/viventium_firecrawl_api$" 2>/dev/null | head -1 | grep -q .; then
      return 0
    fi
  fi

  return 1
}

mcp_url_surface_reachable() {
  local env_key="${1:-}"
  local fallback_url="${2:-}"
  local url=""
  url="$(read_generated_env_value "$env_key" "$fallback_url")"
  url="${url%/}"
  [[ -n "$url" ]] || return 1
  http_url_reachable "$url" 3
}

runtime_pid_file_running() {
  local pid_file_name="${1:-}"
  [[ -n "$pid_file_name" ]] || return 1

  local runtime_profile="${VIVENTIUM_RUNTIME_PROFILE:-isolated}"
  local state_root=""
  state_root="$(read_generated_env_value "VIVENTIUM_STATE_ROOT" "")"
  if [[ -z "$state_root" ]]; then
    state_root="$APP_SUPPORT_DIR/state/runtime/$runtime_profile"
  fi

  local candidate pid
  for candidate in "$state_root/$pid_file_name" "$state_root/logs/$pid_file_name"; do
    [[ -f "$candidate" ]] || continue
    pid="$(tr -d '[:space:]' <"$candidate" 2>/dev/null || true)"
    if pid_is_running "$pid"; then
      return 0
    fi
  done

  return 1
}

telegram_bridge_surface_healthy() {
  local api_port=""
  local frontend_port=""
  local playground_port=""
  assign_runtime_ports api_port frontend_port playground_port
  (
    runtime_pid_file_running "telegram_bot.pid" ||
      runtime_pid_file_running "telegram_bot_deferred.pid"
  ) && api_surface_healthy "$api_port"
}

telegram_codex_surface_healthy() {
  runtime_pid_file_running "telegram_codex.pid"
}

optional_install_surfaces_healthy() {
  if runtime_env_true "START_SEARXNG" "false" && ! searxng_surface_healthy; then
    return 1
  fi
  if runtime_env_true "START_FIRECRAWL" "false" && ! firecrawl_surface_healthy; then
    return 1
  fi
  return 0
}

runtime_optional_surfaces_healthy() {
  if runtime_env_true "START_RAG_API" "false" && ! rag_api_surface_healthy; then
    return 1
  fi
  if runtime_env_true "START_GOOGLE_MCP" "false" && ! mcp_url_surface_reachable "GOOGLE_WORKSPACE_MCP_URL" "http://localhost:8111/mcp"; then
    return 1
  fi
  if runtime_env_true "START_MS365_MCP" "false" && ! mcp_url_surface_reachable "MS365_MCP_SERVER_URL" "http://localhost:6274/mcp"; then
    return 1
  fi
  if runtime_env_true "START_TELEGRAM" "false" && ! telegram_bridge_surface_healthy; then
    return 1
  fi
  if runtime_env_true "START_TELEGRAM_CODEX" "false" && ! telegram_codex_surface_healthy; then
    return 1
  fi
  optional_install_surfaces_healthy
}

pid_matches_repo_scope() {
  local pid="${1:-}"
  [[ -n "$pid" ]] || return 1

  local cmd
  cmd="$(ps -p "$pid" -o command= 2>/dev/null || true)"
  if [[ -n "$cmd" ]]; then
    case "$cmd" in
      "$REPO_ROOT"|"$REPO_ROOT"/*|*" $REPO_ROOT"|*" $REPO_ROOT"/*)
        return 0
        ;;
    esac
  fi

  return 1
}

pattern_running_in_repo() {
  local pattern="${1:-}"
  [[ -n "$pattern" ]] || return 1
  local pids
  pids="$(pgrep -f "$pattern" 2>/dev/null || true)"
  [[ -n "$pids" ]] || return 1

  local pid
  for pid in $pids; do
    if pid_matches_repo_scope "$pid"; then
      return 0
    fi
  done

  return 1
}

managed_process_running() {
  pattern_running_in_repo "npm ci" ||
    pattern_running_in_repo "npm install" ||
    pattern_running_in_repo "npm run build" ||
    pattern_running_in_repo "vite build" ||
    pattern_running_in_repo "node.*api/server" ||
    pattern_running_in_repo "next dev" ||
    pattern_running_in_repo "TelegramVivBot.*bot.py" ||
    pattern_running_in_repo "worker.py start" ||
    pattern_running_in_repo "main.py --transport"
}

is_stack_running() {
  local api_port=""
  local frontend_port=""
  local playground_port=""
  local sandpack_port=""
  assign_runtime_ports api_port frontend_port playground_port sandpack_port
  runtime_port_listening "$api_port" ||
    runtime_port_listening "$frontend_port" ||
    { sandpack_runtime_required && runtime_port_listening "$sandpack_port"; } ||
    runtime_port_listening "$playground_port" ||
    managed_process_running
}

all_user_surfaces_healthy() {
  local api_port=""
  local frontend_port=""
  local playground_port=""
  local sandpack_port=""
  assign_runtime_ports api_port frontend_port playground_port sandpack_port
  api_surface_healthy "$api_port" &&
    frontend_surface_healthy "$frontend_port" &&
    { ! sandpack_runtime_required || sandpack_surface_healthy "$sandpack_port"; } &&
    { express_install_experience || playground_surface_healthy "$playground_port"; }
}

install_surfaces_healthy() {
  # The installer should unblock as soon as the user-facing surfaces are ready.
  # Docker-backed web-search sidecars can keep warming in the background via the
  # launcher's late optional recovery worker without holding first-run success.
  all_user_surfaces_healthy
}

user_surface_healthy() {
  all_user_surfaces_healthy
}

capture_detached_start_log_offset() {
  local launch_log="${1:-}"
  local byte_count=0

  if [[ -f "$launch_log" ]]; then
    byte_count="$(wc -c <"$launch_log" 2>/dev/null | tr -d '[:space:]' || true)"
  fi
  if [[ ! "$byte_count" =~ ^[0-9]+$ ]]; then
    byte_count=0
  fi
  DETACHED_START_LOG_OFFSET="$byte_count"
}

launch_stack_detached() {
  ensure_app_support_layout "$APP_SUPPORT_DIR"
  if [[ ! -f "$CONFIG_FILE" ]]; then
    echo "Missing config: $CONFIG_FILE" >&2
    echo "Run: bin/viventium install" >&2
    exit 1
  fi
  local core_surfaces_healthy=1
  if user_surface_healthy; then
    core_surfaces_healthy=0
    if runtime_optional_surfaces_healthy; then
      echo "Viventium is already running."
      return 0
    fi
  fi
  if detached_launch_process_group_running; then
    echo "Viventium is already starting."
    return 0
  fi
  if [[ "$core_surfaces_healthy" == "0" ]]; then
    echo "Viventium core surfaces are running, but enabled sidecars need startup. Repairing..."
  elif is_stack_running; then
    echo "Detected Viventium processes, but no healthy user-facing surface. Restarting the local stack..."
    stop_stack_for_upgrade
  fi

  local launch_log="$APP_SUPPORT_DIR/logs/helper-start.log"
  mkdir -p "$(dirname "$launch_log")"
  capture_detached_start_log_offset "$launch_log"
  local child_pid
  child_pid="$(
    "$PYTHON_BIN" - "$launch_log" "$REPO_ROOT" "$APP_SUPPORT_DIR" "$CONFIG_FILE" "$RUNTIME_DIR" "$LOCK_FILE" "$@" <<'PY'
import os
import subprocess
import sys

launch_log, repo_root, app_support_dir, config_file, runtime_dir, lock_file, *extra_args = sys.argv[1:]
env = os.environ.copy()
env.pop("VIVENTIUM_CLI_LOCK_HELD", None)
env.pop("VIVENTIUM_CLI_LOCK_DIR", None)
env["VIVENTIUM_DETACHED_START"] = "1"

cmd = [
    os.path.join(repo_root, "bin", "viventium"),
    "--app-support-dir",
    app_support_dir,
    "--config-file",
    config_file,
    "--runtime-dir",
    runtime_dir,
    "--lock-file",
    lock_file,
    "start",
    "--restart",
    *extra_args,
]

with open(launch_log, "ab", buffering=0) as log:
    proc = subprocess.Popen(
        cmd,
        cwd=repo_root,
        stdin=subprocess.DEVNULL,
        stdout=log,
        stderr=subprocess.STDOUT,
        start_new_session=True,
        close_fds=True,
        env=env,
    )
    print(proc.pid)
PY
  )"
  DETACHED_START_PID="$child_pid"
  echo "Launched Viventium in the background (pid $child_pid)."
}

format_install_wait_elapsed() {
  local total_seconds="${1:-0}"
  printf '%dm%02ds' "$((total_seconds / 60))" "$((total_seconds % 60))"
}

pid_is_running() {
  local pid="${1:-}"
  [[ "$pid" =~ ^[0-9]+$ ]] || return 1
  ps -p "$pid" >/dev/null 2>&1
}

docker_container_name_matches() {
  local pattern="${1:-}"
  [[ -n "$pattern" ]] || return 1
  command -v docker >/dev/null 2>&1 || return 1
  docker ps -a --format '{{.Names}}' 2>/dev/null | grep -Eq "$pattern"
}

docker_container_running_matches() {
  local pattern="${1:-}"
  [[ -n "$pattern" ]] || return 1
  command -v docker >/dev/null 2>&1 || return 1
  docker ps --format '{{.Names}}' 2>/dev/null | grep -Eq "$pattern"
}

docker_install_prewarm_running() {
  local service="${1:-}"
  local pid_file="$APP_SUPPORT_DIR/state/install/docker-prewarm-${service}.pid"
  local pid=""

  [[ -f "$pid_file" ]] || return 1
  pid="$(tr -d '\r\n' <"$pid_file" 2>/dev/null || true)"
  pid_is_running "$pid"
}

searxng_install_wait_label() {
  if docker_install_prewarm_running "searxng"; then
    printf '%s\n' "SearXNG local search (Docker image warmup)"
    return 0
  fi
  if docker_container_running_matches '^viventium_searxng(_redis)?$'; then
    printf '%s\n' "SearXNG local search (Docker container starting)"
    return 0
  fi
  if docker_container_name_matches '^viventium_searxng(_redis)?$'; then
    printf '%s\n' "SearXNG local search (Docker container created)"
    return 0
  fi
  printf '%s\n' "SearXNG local search"
}

firecrawl_install_wait_label() {
  if docker_install_prewarm_running "firecrawl"; then
    printf '%s\n' "Firecrawl local scraper (Docker image warmup)"
    return 0
  fi
  if docker_container_running_matches '^viventium_firecrawl_'; then
    printf '%s\n' "Firecrawl local scraper (Docker container starting)"
    return 0
  fi
  if docker_container_name_matches '^viventium_firecrawl_'; then
    printf '%s\n' "Firecrawl local scraper (Docker container created)"
    return 0
  fi
  printf '%s\n' "Firecrawl local scraper"
}

launch_log_indicates_startup_failure() {
  local launch_log="${1:-}"
  local start_offset="${2:-${DETACHED_START_LOG_OFFSET:-0}}"
  [[ -f "$launch_log" ]] || return 1
  [[ "$start_offset" =~ ^[0-9]+$ ]] || start_offset=0

  local tail_output=""
  tail_output="$(tail -c "+$((start_offset + 1))" "$launch_log" 2>/dev/null | tail -n 200 || true)"
  [[ -n "$tail_output" ]] || return 1

  # The launcher owns one clean-tree retry after a dependency install error.
  # Do not let the detached-start watcher abort that recovery path; the final
  # dependency check/install error remains in the stream and is terminal.
  tail_output="$({
    printf '%s\n' "$tail_output" |
      grep -vF '[viventium] LibreChat dependency install failed; cleaning dependency trees and retrying once...' ||
      true
  })"
  [[ -n "$tail_output" ]] || return 1

  if printf '%s\n' "$tail_output" | grep -Eq \
    '(\[viventium\].*(Failed|failed|ERROR|Error)|\[viventium\].*Docker is not running([.]|$| \(required for)|Failed to switch pnpm|spawnSync .*pnpm.* ENOENT|ERR_PNPM|Shutting down\.\.\.|error during build:|Build failed in|npm error Lifecycle script|Could not resolve .* from)'
  then
    return 0
  fi

  printf '%s\n' "$tail_output" | grep -Eq \
    '(\[viventium\].*(LibreChat ports? .*skipping startup|LibreChat port [0-9]+.*skipping startup|Port [0-9]+ in use - skipping LibreChat startup|Playground port [0-9]+.*skipping playground startup))'
}

detached_start_failed_early() {
  local launch_log="${1:-}"

  # A required build can fail while optional sidecars or a wrapper process are
  # still alive. Explicit errors from this launch attempt are terminal and
  # must win over process-liveness signals.
  if launch_log_indicates_startup_failure "$launch_log"; then
    return 0
  fi

  if [[ -n "$DETACHED_START_PID" ]]; then
    if pid_is_running "$DETACHED_START_PID"; then
      return 1
    fi
    if detached_launch_process_group_running || is_stack_running || user_surface_healthy; then
      return 1
    fi
    return 0
  fi

  if detached_launch_process_group_running || is_stack_running || user_surface_healthy; then
    return 1
  fi
  return 0
}

install_waiting_on_surfaces() {
  local display_mode="${1:-verbose}"
  local api_port=""
  local frontend_port=""
  local playground_port=""
  local sandpack_port=""
  local waiting_on=()
  assign_runtime_ports api_port frontend_port playground_port sandpack_port

  if ! api_surface_healthy "$api_port"; then
    if [[ "$display_mode" == "compact" ]]; then
      waiting_on+=("API :$api_port")
    else
      waiting_on+=("LibreChat API :$api_port")
    fi
  fi
  if ! frontend_surface_healthy "$frontend_port"; then
    if [[ "$display_mode" == "compact" ]]; then
      waiting_on+=("Web :$frontend_port")
    else
      waiting_on+=("LibreChat Frontend :$frontend_port")
    fi
  fi
  if sandpack_runtime_required && ! sandpack_surface_healthy "$sandpack_port"; then
    if [[ "$display_mode" == "compact" ]]; then
      waiting_on+=("Artifacts :$sandpack_port")
    else
      waiting_on+=("Isolated browser runtime :$sandpack_port")
    fi
  fi
  if ! express_install_experience && ! playground_surface_healthy "$playground_port"; then
    if [[ "$display_mode" == "compact" ]]; then
      waiting_on+=("Playground :$playground_port")
    else
      waiting_on+=("Modern Playground :$playground_port")
    fi
  fi
  if runtime_env_true "START_SEARXNG" "false" && ! searxng_surface_healthy; then
    if [[ "$display_mode" == "compact" ]]; then
      waiting_on+=("SearXNG")
    else
      waiting_on+=("$(searxng_install_wait_label)")
    fi
  fi
  if runtime_env_true "START_FIRECRAWL" "false" && ! firecrawl_surface_healthy; then
    if [[ "$display_mode" == "compact" ]]; then
      waiting_on+=("Firecrawl")
    else
      waiting_on+=("$(firecrawl_install_wait_label)")
    fi
  fi

  if (( ${#waiting_on[@]} == 0 )); then
    printf '%s\n' "final health confirmation"
    return 0
  fi

  local formatted=""
  printf -v formatted '%s, ' "${waiting_on[@]}"
  printf '%s\n' "${formatted%, }"
}

install_wait_log_activity_summary() {
  local launch_log="${1:-}"
  [[ -f "$launch_log" ]] || return 0

  local cleaned_tail=""
  cleaned_tail="$(
    tail -n 240 "$launch_log" 2>/dev/null | \
      sed $'s/\033\\[[0-9;]*[[:alpha:]]//g'
  )"
  [[ -n "$cleaned_tail" ]] || return 0

  printf '%s\n' "$cleaned_tail" | awk '
    /Installing LibreChat dependencies/ { msg = "Installing LibreChat dependencies" }
    /Building LibreChat server packages for installer-managed runtime tasks/ { msg = "Preparing LibreChat runtime packages" }
    /Building LibreChat server packages/ { msg = "Building LibreChat server packages" }
    /Building LibreChat client package/ { msg = "Building LibreChat client package" }
    /Building LibreChat client bundle/ { msg = "Building LibreChat web app" }
    /Ensuring local conversation search is fully indexed/ { msg = "Indexing local conversation search" }
    /Starting LibreChat \(backend\+frontend\)/ { msg = "Starting LibreChat services" }
    /Server listening at http:\/\/localhost:[0-9]+/ { msg = "LibreChat API is responding" }
    /VITE v[0-9].*ready/ { msg = "LibreChat frontend is responding" }
    /Installing playground dependencies/ { msg = "Installing modern playground dependencies" }
    /Starting .*Playground/ { msg = "Starting modern playground" }
    /Playground pid:/ { msg = "Modern playground is starting" }
    /Installing voice gateway dependencies/ { msg = "Installing voice gateway dependencies" }
    /Starting Voice Gateway worker/ { msg = "Starting voice services" }
    /Detached launch is still waiting for parallel optional sidecars before exiting/ { msg = "Finalizing optional local sidecars" }
    END { print msg }
  '
}

install_wait_inline_enabled() {
  [[ "${HEADLESS:-0}" != "1" ]] || return 1
  [[ -t 1 ]] || return 1
  [[ "${TERM:-}" != "dumb" ]] || return 1
}

install_wait_spinner_frame() {
  local tick="${1:-0}"
  case $((tick % 4)) in
    0) printf '%s\n' '-' ;;
    1) printf '%s\n' '\' ;;
    2) printf '%s\n' '|' ;;
    *) printf '%s\n' '/' ;;
  esac
}

install_wait_pick_next_tagline() {
  local tick="${1:-0}"
  local count="${#INSTALL_WAIT_TAGLINES[@]}"
  if (( count == 0 )); then
    INSTALL_WAIT_TAGLINE=""
    INSTALL_WAIT_TAGLINE_INDEX=-1
    INSTALL_WAIT_TAGLINE_STARTED_TICK="$tick"
    return 1
  fi

  local next_index=0
  if (( count > 1 )); then
    next_index=$((RANDOM % count))
    if (( next_index == INSTALL_WAIT_TAGLINE_INDEX )); then
      next_index=$(((next_index + 1 + (RANDOM % (count - 1))) % count))
    fi
  fi

  INSTALL_WAIT_TAGLINE_INDEX="$next_index"
  INSTALL_WAIT_TAGLINE="${INSTALL_WAIT_TAGLINES[$next_index]}"
  INSTALL_WAIT_TAGLINE_STARTED_TICK="$tick"
}

install_wait_current_tagline() {
  local tick="${1:-0}"
  local destination="${2:-}"
  local enabled="${VIVENTIUM_INSTALL_FUN_TAGLINES:-1}"
  local chars_per_tick="${VIVENTIUM_INSTALL_TAGLINE_CHARS_PER_TICK:-10}"
  local hold_ticks="${VIVENTIUM_INSTALL_TAGLINE_HOLD_TICKS:-25}"
  case "$enabled" in
    0|false|FALSE|no|NO|off|OFF)
      return 0
      ;;
  esac

  if [[ ! "$chars_per_tick" =~ ^[0-9]+$ ]] || (( chars_per_tick < 1 )); then
    chars_per_tick=10
  fi
  if [[ ! "$hold_ticks" =~ ^[0-9]+$ ]] || (( hold_ticks < 0 )); then
    hold_ticks=25
  fi

  if [[ -z "$INSTALL_WAIT_TAGLINE" ]]; then
    install_wait_pick_next_tagline "$tick" || return 0
  fi

  local full_text="$INSTALL_WAIT_TAGLINE"
  local line_length="${#full_text}"
  if (( line_length == 0 )); then
    return 0
  fi

  local age_ticks=$((tick - INSTALL_WAIT_TAGLINE_STARTED_TICK))
  if (( age_ticks < 0 )); then
    age_ticks=0
  fi

  local typing_ticks=$(((line_length + chars_per_tick - 1) / chars_per_tick))
  if (( age_ticks >= typing_ticks + hold_ticks )); then
    install_wait_pick_next_tagline "$tick" || return 0
    full_text="$INSTALL_WAIT_TAGLINE"
    line_length="${#full_text}"
    age_ticks=0
  fi

  local visible_chars=$(((age_ticks + 1) * chars_per_tick))
  local rendered=""
  if (( visible_chars >= line_length )); then
    rendered="$full_text"
  else
    rendered="${full_text:0:visible_chars}_"
  fi

  if [[ -n "$destination" ]]; then
    printf -v "$destination" '%s' "$rendered"
    return 0
  fi

  printf '%s\n' "$rendered"
}

clear_install_wait_progress_frame() {
  if [[ "$INSTALL_WAIT_PROGRESS_ACTIVE" != "1" ]]; then
    printf '\r\033[2K'
    return 0
  fi

  printf '\r\033[2K'
  if (( INSTALL_WAIT_PROGRESS_LINES >= 2 )); then
    printf '\033[1A\r\033[2K'
  fi
}

render_install_wait_progress() {
  local elapsed="${1:-0}"
  local waiting_on="${2:-}"
  local launch_log="${3:-}"
  local current_step="${INSTALL_WAIT_CURRENT_STEP:-}"
  if [[ -z "$current_step" ]]; then
    current_step="$(install_wait_log_activity_summary "$launch_log" || true)"
  fi
  if [[ -z "$current_step" ]]; then
    current_step="Starting local services"
  fi

  if install_wait_inline_enabled; then
    local spinner=""
    local tagline=""
    local reset=$'\033[0m'
    local bold=$'\033[1m'
    local dim=$'\033[2m'
    local cyan=$'\033[36m'
    local yellow=$'\033[33m'
    local orange=$'\033[38;5;208m'
    local bright_white=$'\033[97m'
    local title=""
    local elapsed_label=""
    local step_label=""
    local waiting_label=""
    local tagline_label=""
    spinner="$(install_wait_spinner_frame "${INSTALL_WAIT_INLINE_TICK:-$elapsed}")"
    install_wait_current_tagline "${INSTALL_WAIT_INLINE_TICK:-0}" tagline
    title="${bold}${cyan}Starting Viventium${reset}"
    elapsed_label="${dim}$(format_install_wait_elapsed "$elapsed")${reset}"
    step_label="${bright_white}${current_step}${reset}"
    if [[ -n "$waiting_on" ]]; then
      waiting_label="${dim}Waiting for:${reset} ${yellow}${waiting_on}${reset}"
    fi
    if [[ -n "$tagline" ]]; then
      tagline_label="${dim}While you wait:${reset} ${orange}${tagline}${reset}"
    fi
    clear_install_wait_progress_frame
    printf '%s[%s%s%s]%s %s %s %s|%s %s' \
      "$dim" \
      "$cyan" \
      "$spinner" \
      "$dim" \
      "$reset" \
      "$title" \
      "$elapsed_label" \
      "$dim" \
      "$reset" \
      "$step_label"
    if [[ -n "$waiting_label" ]]; then
      printf ' %s|%s %s' "$dim" "$reset" "$waiting_label"
    fi
    if [[ -n "$tagline_label" ]]; then
      printf '\n\033[2K%s' "$tagline_label"
      INSTALL_WAIT_PROGRESS_LINES=2
    else
      INSTALL_WAIT_PROGRESS_LINES=1
    fi
    INSTALL_WAIT_PROGRESS_ACTIVE=1
    return 0
  fi

  local progress_message=""
  if [[ -n "$waiting_on" ]]; then
    progress_message="Still waiting for Viventium to finish starting ($(format_install_wait_elapsed "$elapsed") elapsed; current step: $current_step; waiting on: $waiting_on)."
  else
    progress_message="Still waiting for Viventium to finish starting ($(format_install_wait_elapsed "$elapsed") elapsed; current step: $current_step)."
  fi

  local repeat_interval="${VIVENTIUM_INSTALL_START_LOG_REPEAT_SECONDS:-60}"
  if [[ "$progress_message" != "$INSTALL_WAIT_LAST_MESSAGE" ]] ||
    (( elapsed - INSTALL_WAIT_LAST_MESSAGE_ELAPSED >= repeat_interval ))
  then
    echo "$progress_message"
    INSTALL_WAIT_LAST_MESSAGE="$progress_message"
    INSTALL_WAIT_LAST_MESSAGE_ELAPSED="$elapsed"
  fi
}

finish_install_wait_progress() {
  if install_wait_inline_enabled && [[ "$INSTALL_WAIT_PROGRESS_ACTIVE" == "1" ]]; then
    clear_install_wait_progress_frame
    printf '\n'
  fi
  INSTALL_WAIT_PROGRESS_ACTIVE=0
  INSTALL_WAIT_PROGRESS_LINES=0
  INSTALL_WAIT_LAST_MESSAGE=""
  INSTALL_WAIT_LAST_MESSAGE_ELAPSED=0
  INSTALL_WAIT_INLINE_TICK=0
  INSTALL_WAIT_CURRENT_STEP=""
  INSTALL_WAIT_TAGLINE_INDEX=-1
  INSTALL_WAIT_TAGLINE=""
  INSTALL_WAIT_TAGLINE_STARTED_TICK=0
}

install_first_run_build_expected() {
  local librechat_dir="$REPO_ROOT/viventium_v0_4/LibreChat"
  local playground_dir="$REPO_ROOT/viventium_v0_4/agent-starter-react"

  [[ -f "$librechat_dir/packages/api/dist/index.js" ]] || return 0
  [[ -f "$librechat_dir/packages/client/dist/index.js" ]] || return 0
  [[ -f "$librechat_dir/client/dist/index.html" ]] || return 0
  if ! express_install_experience && [[ ! -d "$playground_dir/node_modules" ]]; then
    return 0
  fi
  return 1
}

print_install_start_expectations() {
  local build_note_needed=0
  local docker_note_needed=0

  if install_first_run_build_expected; then
    build_note_needed=1
  fi
  if runtime_env_true "START_SEARXNG" "false" || runtime_env_true "START_FIRECRAWL" "false"; then
    docker_note_needed=1
  fi
  if [[ "$build_note_needed" != "1" && "$docker_note_needed" != "1" ]]; then
    return 0
  fi

  echo "Preparing first-run startup..."
  if [[ "$build_note_needed" == "1" ]]; then
    if express_install_experience; then
      echo "  - Building the Viventium web app locally. The deferred voice playground is not part of Easy Install startup."
    else
      echo "  - Building LibreChat and playground assets locally. On a clean Mac this can take around 10-15 minutes."
    fi
  fi
  if [[ "$docker_note_needed" == "1" ]]; then
    echo "  - Starting local web-search services in parallel through Docker Desktop."
  fi
}

print_install_timeout_log_excerpt() {
  local launch_log="${1:-}"
  local line_count="${2:-20}"
  [[ -f "$launch_log" ]] || return 0

  echo "Last lines from the detached start log:" >&2
  while IFS= read -r line; do
    echo "  $line" >&2
  done < <(tail -n "$line_count" "$launch_log")
}

wait_for_install_stack_health() {
  local timeout_seconds="${VIVENTIUM_INSTALL_START_HEALTH_TIMEOUT_SECONDS:-1800}"
  local poll_interval="${VIVENTIUM_INSTALL_START_POLL_SECONDS:-2}"
  local progress_interval="${VIVENTIUM_INSTALL_START_PROGRESS_SECONDS:-15}"
  local inline_render_interval="${VIVENTIUM_INSTALL_START_INLINE_PROGRESS_SECONDS:-0.2}"
  local inline_health_every_ticks=1
  local launch_log="$APP_SUPPORT_DIR/logs/helper-start.log"
  local deadline=$((SECONDS + timeout_seconds))
  local started_at="$SECONDS"
  local next_progress=$((SECONDS + progress_interval))
  local inline_progress=0
  local waiting_on="core service readiness"

  INSTALL_WAIT_CURRENT_STEP=""
  INSTALL_WAIT_INLINE_TICK=0

  if install_wait_inline_enabled; then
    if [[ ! "$inline_render_interval" =~ ^[0-9]+([.][0-9]+)?$ ]]; then
      inline_render_interval="0.2"
    fi
    inline_health_every_ticks="$(
      awk -v health="$poll_interval" -v render="$inline_render_interval" '
        BEGIN {
          if (render <= 0) {
            print 1
            exit
          }
          ticks = int((health / render) + 0.999)
          if (ticks < 1) {
            ticks = 1
          }
          print ticks
        }
      '
    )"
    if [[ ! "$inline_health_every_ticks" =~ ^[0-9]+$ ]] || (( inline_health_every_ticks < 1 )); then
      inline_health_every_ticks=1
    fi
    inline_progress=1
  fi

  while (( SECONDS < deadline )); do
    if [[ "$inline_progress" == "1" ]]; then
      if (( INSTALL_WAIT_INLINE_TICK % inline_health_every_ticks == 0 )); then
        if install_surfaces_healthy; then
          finish_install_wait_progress
          return 0
        fi
        if detached_start_failed_early "$launch_log"; then
          finish_install_wait_progress
          return 2
        fi
        waiting_on="$(install_waiting_on_surfaces compact || true)"
        if [[ -z "$waiting_on" ]]; then
          waiting_on="core service readiness"
        fi
        INSTALL_WAIT_CURRENT_STEP="$(install_wait_log_activity_summary "$launch_log" || true)"
      fi

      local elapsed="$((SECONDS - started_at))"
      render_install_wait_progress "$elapsed" "$waiting_on" "$launch_log"
      INSTALL_WAIT_INLINE_TICK=$((INSTALL_WAIT_INLINE_TICK + 1))
      sleep "$inline_render_interval"
      continue
    fi

    if install_surfaces_healthy; then
      finish_install_wait_progress
      return 0
    fi
    if detached_start_failed_early "$launch_log"; then
      finish_install_wait_progress
      return 2
    fi
    if [[ "$inline_progress" == "1" || SECONDS -ge next_progress ]]; then
      local elapsed="$((SECONDS - started_at))"
      local waiting_on=""
      if [[ "$inline_progress" == "1" ]]; then
        waiting_on="$(install_waiting_on_surfaces compact || true)"
      else
        waiting_on="$(install_waiting_on_surfaces verbose || true)"
      fi
      if [[ -z "$waiting_on" ]]; then
        waiting_on="core service readiness"
      fi
      render_install_wait_progress "$elapsed" "$waiting_on" "$launch_log"
      next_progress=$((SECONDS + progress_interval))
    fi
    sleep "$poll_interval"
  done

  finish_install_wait_progress
  return 1
}

start_stack_for_install() {
  local helper_grace_seconds="${VIVENTIUM_INSTALL_HELPER_GRACE_SECONDS:-8}"
  local helper_deadline=$((SECONDS + helper_grace_seconds))
  local launch_log="$APP_SUPPORT_DIR/logs/helper-start.log"
  local wait_status=0

  # Detached helper/launcher paths need their own CLI lock. Release the install
  # lock before we wait for helper auto-start or submit a detached launch.
  cleanup_cli_lock
  DETACHED_START_PID=""
  capture_detached_start_log_offset "$launch_log"

  if install_surfaces_healthy; then
    return 0
  fi

  print_install_start_expectations

  # Interactive macOS installs may have already launched the helper, which
  # auto-starts the stack. Give that path a brief window to claim startup
  # before submitting a detached launch ourselves.
  if [[ "$(uname -s)" == "Darwin" && "${HEADLESS:-0}" != "1" ]]; then
    while (( SECONDS < helper_deadline )); do
      if user_surface_healthy || is_stack_running; then
        break
      fi
      sleep 1
    done
  fi

  if ! user_surface_healthy && ! is_stack_running; then
    launch_stack_detached
  fi

  wait_for_install_stack_health
  wait_status=$?
  if [[ "$wait_status" == "0" ]]; then
    return 0
  fi

  local timeout_seconds="${VIVENTIUM_INSTALL_START_HEALTH_TIMEOUT_SECONDS:-1800}"
  local waiting_on=""
  local frontend_port=""
  waiting_on="$(install_waiting_on_surfaces || true)"
  if [[ -z "$waiting_on" ]]; then
    waiting_on="service readiness checks"
  fi
  assign_runtime_ports _ frontend_port _

  if [[ "$wait_status" == "2" ]]; then
    echo "Viventium stopped during startup before the required surfaces became healthy." >&2
  else
    echo "Viventium did not become healthy before the install start timeout (${timeout_seconds}s)." >&2
  fi
  echo "Still waiting on: $waiting_on" >&2
  if [[ -f "$launch_log" ]]; then
    echo "Check the detached start log: $launch_log" >&2
  fi
  print_install_timeout_log_excerpt "$launch_log"
  if [[ -n "$frontend_port" ]]; then
    echo "If package builds are still running, try again shortly at http://localhost:${frontend_port}." >&2
  fi
  return 1
}

restart_stack_after_upgrade() {
  local launch_log="$APP_SUPPORT_DIR/logs/helper-start.log"
  local timeout_seconds="${VIVENTIUM_INSTALL_START_HEALTH_TIMEOUT_SECONDS:-1800}"
  local wait_status=0
  local waiting_on=""

  # Upgrade already refreshed components and regenerated runtime outputs.
  # Restart should hand off to the detached launcher path instead of keeping
  # the upgrade process attached to the long-lived stack owner.
  if [[ "${UPGRADE_TRANSACTION_ACTIVE:-0}" != "1" ]]; then
    cleanup_cli_lock
  fi
  DETACHED_START_PID=""

  if install_surfaces_healthy; then
    return 0
  fi

  echo "Restarting Viventium..."
  launch_stack_detached

  wait_for_install_stack_health
  wait_status=$?
  if [[ "$wait_status" == "0" ]]; then
    return 0
  fi

  waiting_on="$(install_waiting_on_surfaces || true)"
  if [[ -z "$waiting_on" ]]; then
    waiting_on="service readiness checks"
  fi

  if [[ "$wait_status" == "2" ]]; then
    echo "Viventium stopped during restart before the required surfaces became healthy." >&2
  else
    echo "Viventium did not become healthy before the restart timeout (${timeout_seconds}s)." >&2
  fi
  echo "Still waiting on: $waiting_on" >&2
  if [[ -f "$launch_log" ]]; then
    echo "Check the detached start log: $launch_log" >&2
  fi
  print_install_timeout_log_excerpt "$launch_log"
  return 1
}

recover_running_stack_after_failed_upgrade() {
  local exit_status=$?

  # Prevent recursive signal/EXIT handling while rollback and recovery run.
  trap - EXIT INT TERM

  if [[ "$exit_status" -ne 0 && "${UPGRADE_TRANSACTION_ACTIVE:-0}" == "1" ]]; then
    echo "Upgrade did not complete. Restoring the verified pre-upgrade source, config, runtime, and stopped data checkpoint..." >&2
    if ! stop_stack_for_upgrade; then
      echo "Rollback paused because the changed runtime could not be stopped safely." >&2
      echo "The recovery transaction remains active at $(display_safe_path "$UPGRADE_TRANSACTION_DIR")." >&2
      cleanup_cli_lock
      exit "$exit_status"
    fi
    if upgrade_transaction_rollback; then
      if [[ "${UPGRADE_TRANSACTION_WAS_RUNNING:-0}" == "1" ]]; then
        if restart_stack_after_upgrade; then
          echo "The previous verified Viventium runtime and running state were restored." >&2
        else
          echo "The previous on-disk state was restored, but automatic restart failed. Run: bin/viventium launch" >&2
        fi
      else
        echo "The previous verified Viventium on-disk state was restored and remains stopped." >&2
      fi
    else
      echo "Rollback failed closed before overwriting unrecognized local work. The recovery transaction remains active." >&2
      echo "Resolve the reported local-state conflict, then rerun bin/viventium upgrade." >&2
    fi
  fi

  cleanup_cli_lock
  exit "$exit_status"
}

upgrade_transaction_active_info() {
  "${UPGRADE_TRANSACTION_PYTHON:-$PYTHON_BIN}" "$REPO_ROOT/scripts/viventium/upgrade_transaction.py" active \
    --app-support-dir "$APP_SUPPORT_DIR"
}

upgrade_transaction_begin() {
  local target_head="${1:-}"
  local args=(
    begin
    --repo-root "$REPO_ROOT"
    --app-support-dir "$APP_SUPPORT_DIR"
    --config-file "$CONFIG_FILE"
    --runtime-dir "$RUNTIME_DIR"
    --lock-file "$LOCK_FILE"
    --was-running "$([[ "${UPGRADE_STACK_WAS_RUNNING:-0}" == "1" ]] && printf true || printf false)"
  )
  if [[ -n "$target_head" ]]; then
    args+=(--target-head "$target_head")
  fi
  if [[ "${ALLOW_DIRTY:-0}" == "1" ]]; then
    args+=(--allow-dirty-parent)
  fi
  local result=""
  UPGRADE_TRANSACTION_PYTHON="$PYTHON_BIN"
  result="$("$UPGRADE_TRANSACTION_PYTHON" "$REPO_ROOT/scripts/viventium/upgrade_transaction.py" "${args[@]}")"
  UPGRADE_TRANSACTION_DIR="$(
    "$UPGRADE_TRANSACTION_PYTHON" -c 'import json,sys; print(json.loads(sys.argv[1])["transaction_path"])' "$result"
  )"
  UPGRADE_TRANSACTION_RUNNER="$(
    "$UPGRADE_TRANSACTION_PYTHON" -c 'import json,sys; print(json.loads(sys.argv[1])["transaction_runner"])' "$result"
  )"
  UPGRADE_TRANSACTION_WAS_RUNNING="${UPGRADE_STACK_WAS_RUNNING:-0}"
  UPGRADE_TRANSACTION_ACTIVE=1
}

upgrade_transaction_snapshot_stopped_state() {
  "$UPGRADE_TRANSACTION_PYTHON" "$UPGRADE_TRANSACTION_RUNNER" snapshot-stopped-state \
    --transaction "$UPGRADE_TRANSACTION_DIR" >/dev/null
}

upgrade_transaction_prepare_candidate() {
  local result=""
  result="$(
    "$UPGRADE_TRANSACTION_PYTHON" "$UPGRADE_TRANSACTION_RUNNER" prepare-candidate \
      --transaction "$UPGRADE_TRANSACTION_DIR"
  )"
  UPGRADE_CANDIDATE_CONFIG="$(
    "$UPGRADE_TRANSACTION_PYTHON" -c 'import json,sys; print(json.loads(sys.argv[1])["config_file"])' "$result"
  )"
  UPGRADE_CANDIDATE_RUNTIME="$(
    "$UPGRADE_TRANSACTION_PYTHON" -c 'import json,sys; print(json.loads(sys.argv[1])["runtime_dir"])' "$result"
  )"
}

upgrade_transaction_checkpoint() {
  local stage="$1"
  "$UPGRADE_TRANSACTION_PYTHON" "$UPGRADE_TRANSACTION_RUNNER" checkpoint \
    --transaction "$UPGRADE_TRANSACTION_DIR" \
    --stage "$stage" >/dev/null
}

upgrade_transaction_activate_candidate() {
  "$UPGRADE_TRANSACTION_PYTHON" "$UPGRADE_TRANSACTION_RUNNER" activate-candidate \
    --transaction "$UPGRADE_TRANSACTION_DIR" >/dev/null
}

upgrade_transaction_rollback() {
  local result=""
  result="$(
    "$UPGRADE_TRANSACTION_PYTHON" "$UPGRADE_TRANSACTION_RUNNER" rollback \
      --transaction "$UPGRADE_TRANSACTION_DIR"
  )" || return 1
  UPGRADE_TRANSACTION_ACTIVE=0
  return 0
}

upgrade_transaction_commit() {
  "$UPGRADE_TRANSACTION_PYTHON" "$UPGRADE_TRANSACTION_RUNNER" commit \
    --transaction "$UPGRADE_TRANSACTION_DIR" >/dev/null
  UPGRADE_TRANSACTION_ACTIVE=0
  trap cleanup_cli_lock EXIT INT TERM
}

recover_interrupted_upgrade_transaction() {
  local active_info=""
  active_info="$(upgrade_transaction_active_info)" || {
    local status=$?
    if [[ "$status" == "1" ]]; then
      return 0
    fi
    echo "Upgrade cannot continue because the prior transaction pointer is unreadable or unsafe." >&2
    exit "$status"
  }
  UPGRADE_TRANSACTION_DIR="$(
    "$PYTHON_BIN" -c 'import json,sys; print(json.loads(sys.argv[1])["transaction_path"])' "$active_info"
  )"
  UPGRADE_TRANSACTION_PYTHON="$PYTHON_BIN"
  UPGRADE_TRANSACTION_RUNNER="$(
    "$PYTHON_BIN" -c 'import json,sys; print(json.loads(sys.argv[1])["transaction_runner"])' "$active_info"
  )"
  UPGRADE_TRANSACTION_WAS_RUNNING="$(
    "$PYTHON_BIN" -c 'import json,sys; print(1 if json.loads(sys.argv[1])["was_running"] else 0)' "$active_info"
  )"
  UPGRADE_TRANSACTION_ACTIVE=1
  echo "An interrupted upgrade was found. Recovering its verified pre-upgrade checkpoint before any new mutation..." >&2
  if ! stop_stack_for_upgrade; then
    echo "Interrupted-upgrade recovery stopped because the current runtime could not be drained safely." >&2
    exit 1
  fi
  if ! upgrade_transaction_rollback; then
    echo "Interrupted-upgrade rollback refused to overwrite unrecognized local work." >&2
    exit 1
  fi
  if [[ "$UPGRADE_TRANSACTION_WAS_RUNNING" == "1" ]]; then
    if ! restart_stack_after_upgrade; then
      echo "The interrupted upgrade was rolled back, but the prior runtime did not restart." >&2
      exit 1
    fi
  fi
  echo "Interrupted upgrade rolled back successfully. Rerun the upgrade command to start a new transaction." >&2
  cleanup_cli_lock
  exit 4
}

stop_stack_for_upgrade() {
  "$REPO_ROOT/bin/viventium" \
    --app-support-dir "$APP_SUPPORT_DIR" \
    --config-file "$CONFIG_FILE" \
    --runtime-dir "$RUNTIME_DIR" \
    --lock-file "$LOCK_FILE" \
    stop
}

stop_native_stack_detached() {
  local stop_log="$APP_SUPPORT_DIR/logs/native-stop.log"
  mkdir -p "$(dirname "$stop_log")"
  local child_pid=""
  child_pid="$(
    "$PYTHON_BIN" - "$stop_log" "$REPO_ROOT" <<'PY'
import os
import subprocess
import sys

stop_log, repo_root = sys.argv[1:]
env = os.environ.copy()

cmd = [
    os.path.join(repo_root, "scripts", "viventium", "native_stack.sh"),
    "stop",
]

with open(stop_log, "ab", buffering=0) as log:
    proc = subprocess.Popen(
        cmd,
        cwd=repo_root,
        stdin=subprocess.DEVNULL,
        stdout=log,
        stderr=subprocess.STDOUT,
        start_new_session=True,
        close_fds=True,
        env=env,
    )
    print(proc.pid)
PY
  )"
  echo "[viventium] Native runtime cleanup continuing in background (pid ${child_pid}, log: ${stop_log})"
}

ensure_upgradeable_git_state() {
  local allow_dirty="${1:-0}"
  local require_remote="${2:-1}"
  local git_root
  git_root="$(git -C "$REPO_ROOT" rev-parse --show-toplevel 2>/dev/null || true)"
  if [[ -z "$git_root" ]]; then
    echo "Upgrade requires a git checkout: $REPO_ROOT" >&2
    exit 1
  fi

  local current_branch
  current_branch="$(git -C "$REPO_ROOT" rev-parse --abbrev-ref HEAD)"
  if [[ -z "$current_branch" || "$current_branch" == "HEAD" ]]; then
    echo "Upgrade requires a named branch checkout, not detached HEAD." >&2
    exit 1
  fi

  if [[ "$require_remote" == "1" ]]; then
    local configured_remote=""
    local merge_ref=""
    configured_remote="$(git -C "$REPO_ROOT" config --get "branch.${current_branch}.remote" || true)"
    merge_ref="$(git -C "$REPO_ROOT" config --get "branch.${current_branch}.merge" || true)"
    if [[ -z "$configured_remote" || "$merge_ref" != refs/heads/* ]]; then
      echo "Upgrade refused because the current branch has no configured Git remote branch." >&2
      echo "Configure its upstream, or use --skip-pull for an intentional local-only refresh." >&2
      exit 1
    fi
  fi

  # Parent tracked/untracked state is classified once by upgrade_check.py so managed
  # nested component directories are not mistaken for unrelated parent user work.
  # Keep the argument in this gate's interface because the structured check applies it.
  : "$allow_dirty"
}

fetch_current_branch_target() {
  local current_branch
  local configured_remote
  local merge_ref
  current_branch="$(git -C "$REPO_ROOT" rev-parse --abbrev-ref HEAD)"
  configured_remote="$(git -C "$REPO_ROOT" config --get "branch.${current_branch}.remote" || true)"
  merge_ref="$(git -C "$REPO_ROOT" config --get "branch.${current_branch}.merge" || true)"
  if [[ -z "$configured_remote" ]]; then
    echo "Upgrade requires the current branch to have a configured Git remote." >&2
    return 1
  fi
  if [[ "$merge_ref" != refs/heads/* ]]; then
    echo "Upgrade requires the current branch to track a normal remote branch." >&2
    return 1
  fi
  git -C "$REPO_ROOT" fetch "$configured_remote" "$merge_ref" >/dev/null
  git -C "$REPO_ROOT" rev-parse --verify FETCH_HEAD
}

fast_forward_current_branch_to_target() {
  local target_head="$1"
  if [[ -z "$target_head" ]]; then
    echo "Upgrade target commit is missing after fetch." >&2
    return 1
  fi
  git -C "$REPO_ROOT" merge --ff-only "$target_head"
}

capture_agent_source_ref() {
  local source_json=""
  source_json="$(
    "$PYTHON_BIN" "$REPO_ROOT/scripts/viventium/agent_migration_state.py" source-ref \
      --repo-root "$REPO_ROOT"
  )" || return 1
  "$PYTHON_BIN" -c '
import json, re, sys
value = str(json.loads(sys.argv[1]).get("source_ref") or "")
if not re.fullmatch(r"[a-f0-9]{40}", value):
    raise SystemExit("Upgrade source identity is invalid.")
print(value, end="")
' "$source_json"
}

ensure_no_pending_agent_migration() {
  local pending_state="$APP_SUPPORT_DIR/state/runtime/agent-managed-migration-pending.json"
  if [[ -e "$pending_state" || -L "$pending_state" ]]; then
    echo "Upgrade refused because the prior managed-agent migration has not finished." >&2
    echo "Run bin/viventium start to finish it, then retry the upgrade." >&2
    return 1
  fi
}

prepare_agent_migration_state() {
  local predecessor_ref="$1"
  local successor_ref="$2"
  local transaction_id="${UPGRADE_TRANSACTION_DIR##*/}"
  "$PYTHON_BIN" "$REPO_ROOT/scripts/viventium/agent_migration_state.py" prepare \
    --repo-root "$REPO_ROOT" \
    --app-support-dir "$APP_SUPPORT_DIR" \
    --predecessor-ref "$predecessor_ref" \
    --successor-ref "$successor_ref" \
    --transaction-id "$transaction_id" >/dev/null
}

if [[ $# -gt 0 ]]; then
  PARSED_ARGS=()
  parse_global_options "$@"
  set -- "${PARSED_ARGS[@]}"
fi

COMMAND="${1:-help}"
if [[ $# -gt 0 ]]; then
  shift
fi

SKIP_PYTHON_BOOTSTRAP=0
case "$COMMAND" in
  restore)
    SKIP_PYTHON_BOOTSTRAP=1
    ;;
  upgrade|update)
    # Register and checkpoint the upgrade before its candidate requirements can
    # mutate the product-owned bootstrap environment.
    SKIP_PYTHON_BOOTSTRAP=1
    ;;
esac
if [[ "$SKIP_PYTHON_BOOTSTRAP" == "1" ]]; then
  PYTHON_BIN="${VIVENTIUM_PYTHON_BIN:-$(command -v python3)}"
  export PYTHON_BIN
else
  refresh_repo_python
fi
maybe_reexec_active_runtime_checkout "$COMMAND" "$@"

case "$COMMAND" in
  install|bootstrap)
    acquire_cli_lock "$COMMAND"
    AUTO_START=1
    CONFIG_INPUT=""
    HEADLESS=0
    INSTALL_ARGS=()
    CURRENT_INSTALL_STAGE="configure"
    INSTALL_TRAP_ACTIVE=1
    trap 'install_status=$?; if [[ "${INSTALL_TRAP_ACTIVE:-0}" == "1" && "$install_status" -ne 0 ]]; then drain_failed_install_runtime || true; rollback_config_candidate || true; write_install_stage "$CURRENT_INSTALL_STAGE"; print_install_recovery_guidance "$CURRENT_INSTALL_STAGE"; fi; cleanup_config_candidate || true; exit "$install_status"' EXIT
    if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
      subcommand_usage install
      exit 0
    fi
    while [[ $# -gt 0 ]]; do
      case "${1:-}" in
        --no-start)
          AUTO_START=0
          shift
          ;;
        --headless|--non-interactive)
          HEADLESS=1
          shift
          ;;
        --config-input|--preset|--config)
          if [[ $# -lt 2 ]]; then
            echo "Missing value for $1" >&2
            exit 1
          fi
          CONFIG_INPUT="$2"
          shift 2
          ;;
        *)
          INSTALL_ARGS+=("$1")
          shift
          ;;
      esac
    done
    if [[ "$HEADLESS" != "1" ]]; then
      reattach_stdin_from_tty_if_available || true
    fi
    ensure_app_support_layout "$APP_SUPPORT_DIR"
    RECOVERY_ACTION="resume"
    if [[ -z "$CONFIG_INPUT" ]]; then
      PRIOR_INSTALL_STAGE="$(read_install_stage)"
      if [[ -n "$PRIOR_INSTALL_STAGE" && -f "$CONFIG_FILE" ]]; then
        RECOVERY_ACTION="$(prompt_install_recovery_action "$PRIOR_INSTALL_STAGE")"
        case "$RECOVERY_ACTION" in
          reconfigure)
            echo "Re-running installer setup with the current app support location." >&2
            ;;
          start-over)
            BACKUP_CONFIG_PATH="$(backup_existing_install_config)"
            if [[ -n "$BACKUP_CONFIG_PATH" ]]; then
              echo "Backed up the previous config to $BACKUP_CONFIG_PATH" >&2
            fi
            rm -f "$CONFIG_FILE"
            rm -rf "$RUNTIME_DIR"
            clear_install_stage
            ;;
          *)
            echo "Resuming with the current installer choices." >&2
            ;;
        esac
      fi
    fi
    if [[ ! -f "$CONFIG_FILE" || -n "$CONFIG_INPUT" || "$RECOVERY_ACTION" == "reconfigure" ]]; then
      write_install_stage "configure"
      if [[ -n "$CONFIG_INPUT" ]]; then
        prepare_config_candidate "$CONFIG_INPUT"
        apply_config_candidate
      elif [[ "$HEADLESS" == "1" ]]; then
        echo "install --headless requires --preset/--config-input/--config <file>" >&2
        exit 1
      else
        WIZARD_ARGS=(--output "$CONFIG_FILE")
        "$PYTHON_BIN" "$REPO_ROOT/scripts/viventium/wizard.py" "${WIZARD_ARGS[@]}"
      fi
    fi
    apply_default_nightly_routines
    CURRENT_INSTALL_STAGE="preflight"
    write_install_stage "$CURRENT_INSTALL_STAGE"
    run_preflight apply
    apply_default_nightly_routines
    CURRENT_INSTALL_STAGE="bootstrap-components"
    write_install_stage "$CURRENT_INSTALL_STAGE"
    bootstrap_components
    CURRENT_INSTALL_STAGE="compile-config"
    write_install_stage "$CURRENT_INSTALL_STAGE"
    if [[ ${#INSTALL_ARGS[@]} -gt 0 ]]; then
      compile_config "${INSTALL_ARGS[@]}"
    else
      compile_config
    fi
    echo "Config written to $CONFIG_FILE"
    echo "Generated runtime files in $RUNTIME_DIR"
    CURRENT_INSTALL_STAGE="doctor"
    write_install_stage "$CURRENT_INSTALL_STAGE"
    "$REPO_ROOT/scripts/viventium/doctor.sh" \
      --config "$CONFIG_FILE" \
      --runtime-dir "$RUNTIME_DIR" \
      --repo-root "$REPO_ROOT" \
      --lock-file "$LOCK_FILE"
    sync_memory_hardening_schedule
    CURRENT_INSTALL_STAGE="install-helper"
    write_install_stage "$CURRENT_INSTALL_STAGE"
    maybe_install_macos_helper --no-launch
    if [[ "$AUTO_START" == "1" ]]; then
      echo "Starting Viventium..."
      CURRENT_INSTALL_STAGE="start"
      write_install_stage "$CURRENT_INSTALL_STAGE"
      if ! start_stack_for_install; then
        print_install_summary 1
        exit 1
      fi
      INSTALL_TRAP_ACTIVE=0
      trap - EXIT
      finish_config_candidate
      clear_install_stage
      launch_macos_helper_app
      print_install_summary 1
      open_default_browser
      print_connected_accounts_browser_reminder
      exit 0
    fi
    INSTALL_TRAP_ACTIVE=0
    trap - EXIT
    finish_config_candidate
    clear_install_stage
    print_install_summary 0
    ;;
  upgrade|update)
    AUTO_RESTART=0
    SKIP_PULL=0
    ALLOW_DIRTY=0
    CHECK_ONLY=0
    CHECK_JSON=0
    while [[ $# -gt 0 ]]; do
      case "${1:-}" in
        --check)
          CHECK_ONLY=1
          shift
          ;;
        --json)
          CHECK_JSON=1
          shift
          ;;
        --restart)
          AUTO_RESTART=1
          shift
          ;;
        --skip-pull)
          SKIP_PULL=1
          shift
          ;;
        --allow-dirty)
          ALLOW_DIRTY=1
          shift
          ;;
        *)
          echo "Unknown upgrade option: $1" >&2
          exit 1
          ;;
      esac
    done
    if [[ "$CHECK_ONLY" == "1" ]]; then
      check_args=(--repo-root "$REPO_ROOT" --app-support-dir "$APP_SUPPORT_DIR")
      if [[ -f "$CONFIG_FILE" ]]; then
        check_args+=(--config-file "$CONFIG_FILE")
      fi
      if [[ "$CHECK_JSON" == "1" ]]; then
        check_args+=(--json)
      fi
      exec "$PYTHON_BIN" "$REPO_ROOT/scripts/viventium/upgrade_check.py" "${check_args[@]}"
    fi
    if [[ "$ALLOW_DIRTY" == "1" && "$SKIP_PULL" != "1" ]]; then
      echo "--allow-dirty is only safe with --skip-pull; refusing to fetch or merge into a dirty checkout." >&2
      exit 1
    fi
    ensure_app_support_layout "$APP_SUPPORT_DIR"
    acquire_cli_lock "$COMMAND"
    recover_interrupted_upgrade_transaction
    ensure_no_pending_agent_migration
    if [[ ! -f "$CONFIG_FILE" ]]; then
      echo "Missing config: $CONFIG_FILE" >&2
      echo "Run: bin/viventium install" >&2
      exit 1
    fi
    UPGRADE_REQUIRES_REMOTE=1
    if [[ "$SKIP_PULL" == "1" ]]; then
      UPGRADE_REQUIRES_REMOTE=0
    fi
    ensure_upgradeable_git_state "$ALLOW_DIRTY" "$UPGRADE_REQUIRES_REMOTE"
    UPGRADE_STACK_WAS_RUNNING=0
    if is_stack_running; then
      if [[ "$AUTO_RESTART" == "1" ]]; then
        UPGRADE_STACK_WAS_RUNNING=1
      else
        echo "Upgrade refused because the Viventium stack is currently running." >&2
        echo "Run: bin/viventium stop first, or rerun with --restart." >&2
        exit 1
      fi
    fi
    UPGRADE_SAFETY_ARGS=(
      --repo-root "$REPO_ROOT"
      --app-support-dir "$APP_SUPPORT_DIR"
      --no-fetch
      --json
    )
    if [[ -f "$CONFIG_FILE" ]]; then
      UPGRADE_SAFETY_ARGS+=(--config-file "$CONFIG_FILE")
    fi
    if [[ "$ALLOW_DIRTY" == "1" ]]; then
      UPGRADE_SAFETY_ARGS+=(--allow-dirty-parent)
    fi
    UPGRADE_SAFETY_STATUS=0
    UPGRADE_SAFETY_JSON="$("$PYTHON_BIN" "$REPO_ROOT/scripts/viventium/upgrade_check.py" "${UPGRADE_SAFETY_ARGS[@]}")" || UPGRADE_SAFETY_STATUS=$?
    if [[ "$UPGRADE_SAFETY_STATUS" -ne 0 ]]; then
      "$PYTHON_BIN" - "$UPGRADE_SAFETY_JSON" <<'PY' >&2
import json
import sys

try:
    report = json.loads(sys.argv[1])
except (IndexError, json.JSONDecodeError):
    print("Local upgrade safety inspection did not return readable status.")
    raise SystemExit(0)

for blocker in report.get("blockers", []):
    print(f"Upgrade blocker: {blocker}")
    if blocker == "dirty_checkout":
        print(
            "Preserve or remove the untracked/modified parent files, then retry. "
            "For an intentional local-only refresh, use --skip-pull --allow-dirty."
        )
for item in report.get("component_lock_drift", []):
    name = str(item.get("name") or "managed component")
    status = str(item.get("status") or "unsafe")
    print(f"Managed component blocker: {name} ({status})")
PY
      echo "Upgrade aborted before pull or component mutation because local safety blockers must be resolved first." >&2
      exit "$UPGRADE_SAFETY_STATUS"
    fi
    UPGRADE_AUDIT_TIMESTAMP="$(date -u +%Y%m%dT%H%M%SZ)"
    VIVENTIUM_CONTINUITY_AUDIT_SKIP_PYTHON_REFRESH=1
    PRE_UPGRADE_CONTINUITY_AUDIT="$(capture_continuity_audit "pre-upgrade-${UPGRADE_AUDIT_TIMESTAMP}")"
    unset VIVENTIUM_CONTINUITY_AUDIT_SKIP_PYTHON_REFRESH
    PRE_UPGRADE_CONTINUITY_STATUS="$(continuity_audit_status "$PRE_UPGRADE_CONTINUITY_AUDIT")"
    echo "Pre-upgrade continuity audit written to $(display_safe_path "$PRE_UPGRADE_CONTINUITY_AUDIT")"
    if [[ "$PRE_UPGRADE_CONTINUITY_STATUS" == "error" || "$PRE_UPGRADE_CONTINUITY_STATUS" == "unknown" ]]; then
      echo "Upgrade aborted because the pre-upgrade continuity audit is not trustworthy." >&2
      echo "Review $(display_safe_path "$PRE_UPGRADE_CONTINUITY_AUDIT") before changing the installed runtime." >&2
      exit 1
    fi
    UPGRADE_AGENT_PREDECESSOR_SOURCE_REF="$(capture_agent_source_ref)"
    UPGRADE_TARGET_HEAD=""
    if [[ "$SKIP_PULL" != "1" ]]; then
      # Fetch updates Git metadata only; if the network fails, the still-running
      # product and every mutable product surface remain untouched.
      UPGRADE_TARGET_HEAD="$(fetch_current_branch_target)"
    fi
    # Register rollback ownership and arm the trap while the old runtime is
    # still healthy. The mutable data checkpoint is taken only after shutdown.
    trap recover_running_stack_after_failed_upgrade EXIT INT TERM
    upgrade_transaction_begin "$UPGRADE_TARGET_HEAD"
    if [[ "$UPGRADE_STACK_WAS_RUNNING" == "1" ]]; then
      echo "Running Viventium stack detected. Stopping before component refresh..."
      if ! stop_stack_for_upgrade; then
        echo "Upgrade aborted because the running stack could not be stopped safely." >&2
        echo "No source pull or component refresh was attempted. Resolve the stop failure, then retry." >&2
        exit 1
      fi
    fi
    upgrade_transaction_snapshot_stopped_state
    upgrade_transaction_prepare_candidate
    if [[ "$SKIP_PULL" != "1" ]]; then
      fast_forward_current_branch_to_target "$UPGRADE_TARGET_HEAD"
    fi
    upgrade_transaction_checkpoint "source_pulled"
    apply_default_nightly_routines "$UPGRADE_CANDIDATE_CONFIG"
    (
      CONFIG_FILE="$UPGRADE_CANDIDATE_CONFIG"
      if ! run_preflight check; then
        echo "The upgrade candidate needs a prerequisite that is not installed yet." >&2
        echo "The current version will be restored; run bin/viventium preflight --apply, then retry the upgrade." >&2
        exit 1
      fi
    )
    refresh_repo_python
    apply_default_nightly_routines "$UPGRADE_CANDIDATE_CONFIG"
    (
      CONFIG_FILE="$UPGRADE_CANDIDATE_CONFIG"
      bootstrap_components_upgrade_checked
    )
    upgrade_transaction_checkpoint "components_refreshed"
    mkdir -p "$UPGRADE_CANDIDATE_RUNTIME"
    VIVENTIUM_LIBRECHAT_SOURCE_PHASE=compile \
    VIVENTIUM_LIBRECHAT_SOURCE_OF_TRUTH= \
    "$PYTHON_BIN" "$REPO_ROOT/scripts/viventium/config_compiler.py" \
      --config "$UPGRADE_CANDIDATE_CONFIG" \
      --output-dir "$UPGRADE_CANDIDATE_RUNTIME"
    "$REPO_ROOT/scripts/viventium/doctor.sh" \
      --config "$UPGRADE_CANDIDATE_CONFIG" \
      --runtime-dir "$UPGRADE_CANDIDATE_RUNTIME" \
      --repo-root "$REPO_ROOT" \
      --lock-file "$LOCK_FILE"
    UPGRADE_AGENT_SUCCESSOR_SOURCE_REF="$(capture_agent_source_ref)"
    prepare_agent_migration_state \
      "$UPGRADE_AGENT_PREDECESSOR_SOURCE_REF" \
      "$UPGRADE_AGENT_SUCCESSOR_SOURCE_REF"
    upgrade_transaction_checkpoint "candidate_validated"
    upgrade_transaction_activate_candidate
    upgrade_transaction_checkpoint "candidate_activated"
    POST_UPGRADE_CONTINUITY_AUDIT="$(capture_continuity_audit "post-upgrade-${UPGRADE_AUDIT_TIMESTAMP}")"
    POST_UPGRADE_CONTINUITY_STATUS="$(continuity_audit_status "$POST_UPGRADE_CONTINUITY_AUDIT")"
    echo "Post-upgrade continuity audit written to $(display_safe_path "$POST_UPGRADE_CONTINUITY_AUDIT")"
    case "$POST_UPGRADE_CONTINUITY_STATUS" in
      ok|warning)
        if [[ "$POST_UPGRADE_CONTINUITY_STATUS" == "warning" ]]; then
          echo "Upgrade continuity audit reported warnings. Review $(display_safe_path "$POST_UPGRADE_CONTINUITY_AUDIT") before concluding the install is fully aligned." >&2
        fi
        ;;
      error|unknown|*)
        echo "Upgrade candidate did not pass the post-activation continuity gate; rolling back." >&2
        echo "Review $(display_safe_path "$POST_UPGRADE_CONTINUITY_AUDIT") before retrying." >&2
        exit 1
        ;;
    esac
    if [[ "$AUTO_RESTART" == "1" ]]; then
      if ! restart_stack_after_upgrade; then
        exit 1
      fi
      upgrade_transaction_checkpoint "restart_healthy"
    fi
    upgrade_transaction_commit
    if ! maybe_install_macos_helper --no-launch; then
      echo "Warning: the core upgrade is healthy, but the macOS helper refresh failed. Run: bin/viventium install-helper" >&2
    fi
    if ! sync_memory_hardening_schedule; then
      echo "Warning: the core upgrade is healthy, but the maintenance schedule refresh needs attention." >&2
    fi
    if [[ "$AUTO_RESTART" == "1" ]]; then
      launch_macos_helper_app
      exit 0
    fi
    echo "Upgrade complete. Next: bin/viventium start (the helper remains closed so it cannot auto-start the stack)."
    ;;
  configure|wizard)
    acquire_cli_lock "$COMMAND"
    ensure_app_support_layout "$APP_SUPPORT_DIR"
    CONFIG_INPUT=""
    HEADLESS=0
    while [[ $# -gt 0 ]]; do
      case "${1:-}" in
        --headless|--non-interactive)
          HEADLESS=1
          shift
          ;;
        --config-input|--preset|--config)
          if [[ $# -lt 2 ]]; then
            echo "Missing value for $1" >&2
            exit 1
          fi
          CONFIG_INPUT="$2"
          shift 2
          ;;
        *)
          echo "Unknown configure option: $1" >&2
          exit 1
          ;;
      esac
    done
    if [[ "$HEADLESS" != "1" ]]; then
      reattach_stdin_from_tty_if_available || true
    fi
    if [[ -n "$CONFIG_INPUT" ]]; then
      if ! prepare_config_candidate "$CONFIG_INPUT"; then
        cleanup_config_candidate || true
        exit 1
      fi
      if ! apply_config_candidate; then
        cleanup_config_candidate || true
        exit 1
      fi
    elif [[ "$HEADLESS" == "1" ]]; then
      echo "configure --headless requires --preset/--config-input/--config <file>" >&2
      exit 1
    else
      WIZARD_ARGS=(--output "$CONFIG_FILE")
      "$PYTHON_BIN" "$REPO_ROOT/scripts/viventium/wizard.py" "${WIZARD_ARGS[@]}"
      apply_default_nightly_routines
    fi
    if ! compile_config || ! ensure_configured_prerequisites || ! sync_memory_hardening_schedule; then
      rollback_config_candidate || true
      cleanup_config_candidate || true
      exit 1
    fi
    finish_config_candidate
    ;;
  bootstrap-components)
    acquire_cli_lock "$COMMAND"
    bootstrap_components "$@"
    ;;
  compile-config)
    acquire_cli_lock "$COMMAND"
    apply_default_nightly_routines
    compile_config "$@"
    sync_memory_hardening_schedule
    ;;
  doctor)
    ensure_app_support_layout "$APP_SUPPORT_DIR"
    prepare_runtime_exports
    run_preflight check
    exec "$REPO_ROOT/scripts/viventium/doctor.sh" \
      --config "$CONFIG_FILE" \
      --runtime-dir "$RUNTIME_DIR" \
      --repo-root "$REPO_ROOT" \
      --lock-file "$LOCK_FILE" \
      "$@"
    ;;
  status)
    ensure_app_support_layout "$APP_SUPPORT_DIR"
    if [[ ! -f "$CONFIG_FILE" ]]; then
      echo "Missing config: $CONFIG_FILE" >&2
      echo "Run: bin/viventium install" >&2
      exit 1
    fi
    refresh_repo_python
    exec "$PYTHON_BIN" "$REPO_ROOT/scripts/viventium/install_summary.py" \
      --config "$CONFIG_FILE" \
      --runtime-dir "$RUNTIME_DIR" \
      --repo-root "$REPO_ROOT" \
      --probe-live
    ;;
  register-link)
    if [[ "${1:-}" == "--help" || "${1:-}" == "-h" || $# -lt 1 ]]; then
      subcommand_usage register-link
      exit 0
    fi
    reg_username="$1"; shift
    ensure_app_support_layout "$APP_SUPPORT_DIR"
    prepare_runtime_exports
    refresh_repo_python
    exec "$PYTHON_BIN" "$REPO_ROOT/scripts/viventium/directory_link.py" \
      --state-file "$VIVENTIUM_PUBLIC_NETWORK_STATE_FILE" \
      --username "$reg_username" \
      "$@"
    ;;
  password-reset-link)
    if [[ "${1:-}" == "--help" || "${1:-}" == "-h" || $# -lt 1 ]]; then
      subcommand_usage password-reset-link
      exit 0
    fi
    reset_email="$1"; shift
    ensure_app_support_layout "$APP_SUPPORT_DIR"
    compile_config
    prepare_runtime_exports
    if [[ -f "$GENERATED_ENV" ]]; then
      set -a
      # shellcheck disable=SC1090
      source "$GENERATED_ENV"
      if [[ -f "$GENERATED_LOCAL_ENV" ]]; then
        # shellcheck disable=SC1090
        source "$GENERATED_LOCAL_ENV"
      fi
      if [[ -f "$GENERATED_LIBRECHAT_ENV" ]]; then
        # shellcheck disable=SC1090
        source "$GENERATED_LIBRECHAT_ENV"
      fi
      set +a
    fi
    prepare_password_reset_link_runtime
    exec node "$PASSWORD_RESET_LINK_SCRIPT" \
      --email "$reset_email" \
      "$@"
    ;;
  launch)
    acquire_cli_lock "$COMMAND"
    if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
      subcommand_usage launch
      exit 0
    fi
    launch_stack_detached "$@"
    ;;
  install-helper)
    acquire_cli_lock "$COMMAND"
    if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
      subcommand_usage install-helper
      exit 0
    fi
    run_macos_helper_installer install "$@"
    write_install_ownership_receipt true
    ;;
  shell-init)
    if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
      subcommand_usage shell-init
      exit 0
    fi
    run_shell_init "$@"
    ;;
  continuity-audit)
    acquire_cli_lock "$COMMAND"
    if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
      subcommand_usage continuity-audit
      exit 0
    fi
    CLEAR_RECALL_MARKER=0
    while [[ $# -gt 0 ]]; do
      case "${1:-}" in
        --clear-recall-marker)
          CLEAR_RECALL_MARKER=1
          shift
          ;;
        *)
          echo "Unknown continuity-audit option: $1" >&2
          exit 1
          ;;
      esac
    done
    ensure_app_support_layout "$APP_SUPPORT_DIR"
    audit_path="$(capture_continuity_audit "manual-$(date -u +%Y%m%dT%H%M%SZ)")"
    echo "Continuity audit written to $(display_safe_path "$audit_path")"
    if [[ "$CLEAR_RECALL_MARKER" == "1" ]]; then
      if cleared_marker="$(remove_recall_rebuild_marker)"; then
        echo "Cleared recall rebuild-required marker at $(display_safe_path "$cleared_marker")"
      else
        echo "No recall rebuild-required marker was present."
      fi
    fi
    ;;
  memory-harden)
    if [[ "${1:-}" == "--help" || "${1:-}" == "-h" || $# -lt 1 ]]; then
      subcommand_usage memory-harden
      exit 0
    fi
    memory_harden_subcommand="${1:-}"
    if [[ "$memory_harden_subcommand" != "status" ]]; then
      acquire_cli_lock "$COMMAND"
    fi
    ensure_app_support_layout "$APP_SUPPORT_DIR"
    if [[ ! -f "$CONFIG_FILE" ]]; then
      echo "Missing config: $CONFIG_FILE" >&2
      echo "Run: bin/viventium install" >&2
      exit 1
    fi
    if [[ "$memory_harden_subcommand" != "status" ]]; then
      compile_config >/dev/null
    fi
    prepare_runtime_exports
    if [[ -f "$GENERATED_ENV" ]]; then
      set -a
      # shellcheck disable=SC1090
      source "$GENERATED_ENV"
      if [[ -f "$GENERATED_LOCAL_ENV" ]]; then
        # shellcheck disable=SC1090
        source "$GENERATED_LOCAL_ENV"
      fi
      if [[ -f "$GENERATED_LIBRECHAT_ENV" ]]; then
        # shellcheck disable=SC1090
        source "$GENERATED_LIBRECHAT_ENV"
      fi
      set +a
    fi
    exec "$PYTHON_BIN" "$REPO_ROOT/scripts/viventium/memory_harden.py" \
      --repo-root "$REPO_ROOT" \
      --app-support-dir "$APP_SUPPORT_DIR" \
      --runtime-dir "$RUNTIME_DIR" \
      "$@"
    ;;
  transcripts)
    transcripts_command "$@"
    ;;
  memory-dedupe)
    if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
      subcommand_usage memory-dedupe
      exit 0
    fi
    acquire_cli_lock "$COMMAND"
    ensure_app_support_layout "$APP_SUPPORT_DIR"
    if [[ ! -f "$CONFIG_FILE" ]]; then
      echo "Missing config: $CONFIG_FILE" >&2
      echo "Run: bin/viventium install" >&2
      exit 1
    fi
    compile_config >/dev/null
    prepare_runtime_exports
    if [[ -f "$GENERATED_ENV" ]]; then
      set -a
      # shellcheck disable=SC1090
      source "$GENERATED_ENV"
      if [[ -f "$GENERATED_LOCAL_ENV" ]]; then
        # shellcheck disable=SC1090
        source "$GENERATED_LOCAL_ENV"
      fi
      if [[ -f "$GENERATED_LIBRECHAT_ENV" ]]; then
        # shellcheck disable=SC1090
        source "$GENERATED_LIBRECHAT_ENV"
      fi
      set +a
    fi
    exec node "$REPO_ROOT/viventium_v0_4/LibreChat/scripts/viventium-memory-dedupe.js" "$@"
    ;;
  status-bar)
    acquire_cli_lock "$COMMAND"
    if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
      subcommand_usage status-bar
      exit 0
    fi
    run_status_bar_command "$@"
    ;;
  runtime-checkout)
    acquire_cli_lock "$COMMAND"
    if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
      subcommand_usage runtime-checkout
      exit 0
    fi
    runtime_checkout_command "$@"
    ;;
  dev-env)
    if [[ "${1:-}" == "--help" || "${1:-}" == "-h" || $# -lt 1 ]]; then
      subcommand_usage dev-env
      exit 0
    fi
    dev_env_command "$@"
    ;;
  dev-runtime)
    acquire_cli_lock "$COMMAND"
    if [[ "${1:-}" == "--help" || "${1:-}" == "-h" || $# -lt 1 ]]; then
      subcommand_usage dev-runtime
      exit 0
    fi
    dev_runtime_command "$@"
    ;;
  workflows)
    if [[ "${1:-}" == "--help" || "${1:-}" == "-h" || $# -lt 1 ]]; then
      subcommand_usage workflows
      exit 0
    fi
    workflows_command "$@"
    ;;
  prompt-workbench)
    if [[ "${1:-}" == "--help" || "${1:-}" == "-h" || $# -lt 1 ]]; then
      subcommand_usage prompt-workbench
      exit 0
    fi
    ensure_app_support_layout "$APP_SUPPORT_DIR"
    exec "$PYTHON_BIN" "$REPO_ROOT/scripts/viventium/prompt_workbench.py" \
      --repo-root "$REPO_ROOT" \
      --app-support-dir "$APP_SUPPORT_DIR" \
      "$@"
    ;;
  heal)
    if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
      subcommand_usage heal
      exit 0
    fi
    heal_command "$@"
    ;;
  feature-request)
    if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
      subcommand_usage feature-request
      exit 0
    fi
    feature_request_command "$@"
    ;;
  report-bug|bug-report)
    if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
      subcommand_usage report-bug
      exit 0
    fi
    report_bug_command "$@"
    ;;
  uninstall-helper)
    acquire_cli_lock "$COMMAND"
    if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
      subcommand_usage uninstall-helper
      exit 0
    fi
    run_macos_helper_installer uninstall "$@"
    ;;
  start)
    acquire_cli_lock "$COMMAND"
    if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
      subcommand_usage start
      exit 0
    fi
    ensure_app_support_layout "$APP_SUPPORT_DIR"
    if [[ ! -f "$CONFIG_FILE" ]]; then
      echo "Missing config: $CONFIG_FILE" >&2
      echo "Run: bin/viventium install" >&2
      exit 1
    fi
    bootstrap_components
    # === VIVENTIUM START ===
    # Feature: Canonical runtime regeneration on every start.
    # Purpose: prevent stale generated runtime files from surviving across installer/compiler
    # fixes and silently leaving the machine in an older behavior state than the current branch.
    # compile_config is cheap relative to stack startup and keeps start deterministic.
    # === VIVENTIUM END ===
    apply_default_nightly_routines
    compile_config
    sync_memory_hardening_schedule
    prepare_runtime_exports

    EXTRA_ARGS=()
    if [[ -f "$GENERATED_ENV" ]]; then
      set -a
      # shellcheck disable=SC1090
      source "$GENERATED_ENV"
      if [[ -f "$GENERATED_LOCAL_ENV" ]]; then
        # shellcheck disable=SC1090
        source "$GENERATED_LOCAL_ENV"
      fi
      set +a
      if [[ "${VIVENTIUM_INSTALL_MODE:-docker}" == "native" ]]; then
        write_stack_owner_state "$COMMAND"
        NATIVE_STACK_SKIP_MEILI=0
        if express_install_experience; then
          NATIVE_STACK_SKIP_MEILI=1
        fi
        VIVENTIUM_NATIVE_STACK_SKIP_LIVEKIT=1 \
          VIVENTIUM_NATIVE_STACK_SKIP_MEILI="$NATIVE_STACK_SKIP_MEILI" \
          "$REPO_ROOT/scripts/viventium/native_stack.sh" start
      else
        write_stack_owner_state "$COMMAND"
      fi
      if [[ "${VIVENTIUM_VOICE_ENABLED:-true}" != "true" ]]; then
        EXTRA_ARGS+=(--skip-voice-gateway --skip-livekit)
      fi
      if express_install_experience; then
        EXTRA_ARGS+=(--skip-playground)
      fi
    fi

    if [[ -z "${VIVENTIUM_CALL_SESSION_SECRET:-}" ]]; then
      echo "Missing VIVENTIUM_CALL_SESSION_SECRET in generated runtime env: $GENERATED_ENV" >&2
      echo "Run: bin/viventium compile-config or bin/viventium configure" >&2
      exit 1
    fi

    USER_SELECTED_PLAYGROUND=0
    NORMALIZED_ARGS=()
    while [[ $# -gt 0 ]]; do
      case "${1:-}" in
        --runtime-profile)
          if [[ $# -lt 2 ]]; then
            echo "Missing value for --runtime-profile" >&2
            exit 1
          fi
          NORMALIZED_ARGS+=("--profile=$2")
          shift 2
          ;;
        --profile)
          if [[ $# -lt 2 ]]; then
            echo "Missing value for --profile" >&2
            exit 1
          fi
          NORMALIZED_ARGS+=("--profile=$2")
          shift 2
          ;;
        --profile=*|--modern-playground|--classic-playground)
          if [[ "${1:-}" == "--modern-playground" || "${1:-}" == "--classic-playground" ]]; then
            USER_SELECTED_PLAYGROUND=1
          fi
          NORMALIZED_ARGS+=("$1")
          shift
          ;;
        *)
          NORMALIZED_ARGS+=("$1")
          shift
          ;;
      esac
    done

    START_CMD=("$REPO_ROOT/viventium_v0_4/viventium-librechat-start.sh")
    if [[ "$USER_SELECTED_PLAYGROUND" != "1" ]] && ! express_install_experience; then
      if [[ "${PLAYGROUND_VARIANT:-modern}" == "classic" ]]; then
        START_CMD+=(--classic-playground)
      else
        START_CMD+=(--modern-playground)
      fi
    fi
    if [[ ${#EXTRA_ARGS[@]} -gt 0 ]]; then
      START_CMD+=("${EXTRA_ARGS[@]}")
    fi
    if [[ ${#NORMALIZED_ARGS[@]} -gt 0 ]]; then
      START_CMD+=("${NORMALIZED_ARGS[@]}")
    fi
    # The CLI lock protects start preparation, config compilation, and runtime
    # handoff setup. It must not be held by the long-running stack supervisor;
    # otherwise status, Stop/Quit, and manual memory-hardening jobs are blocked
    # while Viventium is healthy and running.
    cleanup_cli_lock
    "${START_CMD[@]}"
    exit $?
    ;;
  stop)
    acquire_cli_lock "$COMMAND"
    if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
      subcommand_usage stop
      exit 0
    fi
    stop_status=0
    prepare_runtime_exports
    if [[ -f "$GENERATED_ENV" ]]; then
      # shellcheck disable=SC1090
      source "$GENERATED_ENV"
    fi
    write_stack_owner_state "$COMMAND"
    "$REPO_ROOT/viventium_v0_4/viventium-librechat-start.sh" --stop "$@" || stop_status=$?
    # Native state can linger across mode switches or older runs. Stop cleanup
    # should drain owned native services whenever they exist, not only when the
    # current config still says "native".
    if [[ "${VIVENTIUM_HELPER_STOP_BACKGROUND_NATIVE:-0}" == "1" ]]; then
      stop_native_stack_detached
    else
      "$REPO_ROOT/scripts/viventium/native_stack.sh" stop || stop_status=$?
    fi
    exit "$stop_status"
    ;;
  snapshot)
    acquire_cli_lock "$COMMAND"
    if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
      subcommand_usage snapshot
      exit 0
    fi
    ensure_app_support_layout "$APP_SUPPORT_DIR"
    prepare_runtime_exports
    exec "$REPO_ROOT/viventium_v0_4/viventium-local-state-snapshot.sh" \
      --output-root "$APP_SUPPORT_DIR/snapshots" \
      "$@"
    ;;
  restore)
    if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
      subcommand_usage restore
      exit 0
    fi
    VIVENTIUM_DEFAULT_CONFIG_HOME="$APP_SUPPORT_DIR" \
      VIVENTIUM_PYTHON_BIN="$PYTHON_BIN" \
      exec "$REPO_ROOT/scripts/viventium/restore.sh" "$@"
    ;;
  uninstall)
    acquire_cli_lock "$COMMAND"
    if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
      subcommand_usage uninstall
      exit 0
    fi
    UNINSTALL_YES=0
    while [[ $# -gt 0 ]]; do
      case "${1:-}" in
        --yes)
          UNINSTALL_YES=1
          shift
          ;;
        *)
          echo "Unknown uninstall option: $1" >&2
          exit 1
          ;;
      esac
    done
    confirm_destructive_action "Uninstall" "$UNINSTALL_YES" "UNINSTALL"
    uninstall_local_installation
    ;;
  preflight)
    acquire_cli_lock "$COMMAND"
    ensure_app_support_layout "$APP_SUPPORT_DIR"
    APPLY_PREFLIGHT=0
    while [[ $# -gt 0 ]]; do
      case "${1:-}" in
        --apply)
          APPLY_PREFLIGHT=1
          shift
          ;;
        *)
          echo "Unknown preflight option: $1" >&2
          exit 1
          ;;
      esac
    done
    if [[ "$APPLY_PREFLIGHT" == "1" ]]; then
      run_preflight apply
    else
      run_preflight check
    fi
    ;;
  reset)
    acquire_cli_lock "$COMMAND"
    if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
      subcommand_usage reset
      exit 0
    fi
    RESET_YES=0
    while [[ $# -gt 0 ]]; do
      case "${1:-}" in
        --yes)
          RESET_YES=1
          shift
          ;;
        *)
          echo "Unknown reset option: $1" >&2
          exit 1
          ;;
      esac
    done
    confirm_destructive_action "Factory reset" "$RESET_YES" "RESET"
    reset_local_install_state
    ;;
  help|-h|--help)
    if [[ $# -gt 0 ]]; then
      subcommand_usage "$1"
    else
      usage
    fi
    ;;
  *)
    echo "Unknown command: $COMMAND" >&2
    usage >&2
    exit 1
    ;;
esac
